---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    title: 'AI 语音机器人',
    description: '基于大语言模型的智能语音交互系统，支持多轮对话、情感识别和自定义话术流程，为企业提供智能外呼和客服解决方案。',
    tags: ['AI', 'LLM', 'Voice', 'SaaS'],
    link: '',
    github: '',
    status: 'active',
  },
  {
    title: '个人博客',
    description: '你正在看的这个网站。基于 Astro 6 构建的极简奢华风个人博客，支持暗色/亮色主题、Markdown 写作、Admin CMS 管理后台。',
    tags: ['Astro', 'Tailwind CSS', 'GitHub API'],
    link: 'https://siuserxiaowei.com',
    github: 'https://github.com/siuserxiaowei/blog',
    status: 'active',
  },
  {
    title: 'Admin CMS',
    description: '为个人博客打造的轻量级内容管理系统。纯静态 SPA 架构，通过 GitHub API 直接管理 Markdown 文章，零后端依赖。',
    tags: ['SPA', 'GitHub API', 'Markdown'],
    link: 'https://siuserxiaowei.com/admin',
    github: '',
    status: 'active',
  },
  {
    title: 'Claude Code 用量监控',
    description: '实时监控 Claude Code API 用量的自动化代理，自动采集数据、可视化展示，帮助开发者掌控 AI 开支。',
    tags: ['n8n', 'Automation', 'Monitoring'],
    link: '',
    github: '',
    status: 'active',
  },
];

const statusMap: Record<string, { label: string; color: string }> = {
  active: { label: '进行中', color: '#22c55e' },
  completed: { label: '已完成', color: 'var(--color-accent)' },
  archived: { label: '已归档', color: 'var(--text-secondary)' },
};
---

<BaseLayout title="项目 - siuser小伟" description="我的产品与项目展示">
  <Header />

  <main class="flex-1">
    <section class="mx-auto px-6 pt-16 pb-8 md:pt-24 md:pb-12" style="max-width: var(--container-max);">
      <div class="animate-fade-in stagger-1 flex items-center gap-3 mb-3">
        <p class="text-xs tracking-[0.2em] uppercase" style="color: var(--color-accent);">Projects</p>
        <span class="text-[10px] tracking-wider" style="font-family: var(--font-mono); color: var(--text-secondary); opacity: 0.5;">// 项目展示</span>
      </div>
      <h1 class="animate-fade-in stagger-2 text-3xl md:text-5xl mb-4" style="font-family: var(--font-heading); color: var(--text);" data-i18n="projects.title">
        项目展示
      </h1>
      <p class="animate-fade-in stagger-3 text-base mb-4" style="color: var(--text-secondary);" data-i18n="projects.desc">
        我参与和打造的一些产品与项目
      </p>
      <div class="animate-fade-in stagger-3 divider-accent mb-12"></div>
    </section>

    <section class="mx-auto px-6 pb-20" style="max-width: var(--container-max);">
      <div class="grid gap-6 md:grid-cols-2">
        {projects.map((project, index) => (
          <div
            class="group relative glass-card shine-hover gradient-border p-6 rounded-xl transition-all duration-300 hover:shadow-md hover:-translate-y-1"
          >
            <!-- Header -->
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg" style={`background: color-mix(in srgb, var(--color-accent) 12%, transparent); color: var(--color-accent); font-family: var(--font-mono); font-weight: 500;`}>
                  {String(index + 1).padStart(2, '0')}
                </div>
                <div>
                  <h3 class="text-base font-medium transition-colors duration-200 group-hover:text-[var(--color-accent)]" style="color: var(--text);">{project.title}</h3>
                  <div class="flex items-center gap-1.5 mt-0.5">
                    <span class="w-1.5 h-1.5 rounded-full" style={`background: ${statusMap[project.status].color};`}></span>
                    <span class="text-[11px]" style="color: var(--text-secondary); font-family: var(--font-mono);">{statusMap[project.status].label}</span>
                  </div>
                </div>
              </div>
              <!-- Arrow indicator -->
              <svg class="w-4 h-4 transition-all duration-200 group-hover:text-[var(--color-accent)] group-hover:translate-x-1" style="color: var(--text-secondary); opacity: 0.3;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>

            <!-- Description -->
            <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-4">
              {project.tags.map(tag => (
                <span class="text-[11px] px-2 py-0.5 rounded-full" style="background: var(--surface-2); color: var(--color-accent); font-family: var(--font-mono);">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex items-center gap-4 pt-3 border-t" style="border-color: var(--border);">
              {project.link && (
                <a href={project.link} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-[11px] transition-colors duration-200 hover:text-[var(--color-accent)]" style="color: var(--text-secondary); font-family: var(--font-mono);">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Visit
                </a>
              )}
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-[11px] transition-colors duration-200 hover:text-[var(--color-accent)]" style="color: var(--text-secondary); font-family: var(--font-mono);">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  Source
                </a>
              )}
              {!project.link && !project.github && (
                <span class="text-[11px]" style="color: var(--text-secondary); opacity: 0.4; font-family: var(--font-mono);">// not public yet</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
