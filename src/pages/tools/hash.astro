---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="哈希计算" description="MD5 / SHA-1 / SHA-256 / SHA-384 / SHA-512 文本与文件哈希" category="加密哈希" icon="#">
  <div class="tool-card mb-6">
    <label class="tool-label">输入文本</label>
    <textarea id="input" class="tool-textarea" placeholder="输入要计算哈希的文本..."></textarea>
    <div class="tool-status" id="status"><span class="dot"></span><span class="msg">输入后自动计算</span></div>
  </div>

  <div class="tool-card mb-6">
    <label class="tool-label">输出（点击复制）</label>
    <div class="space-y-3">
      {['MD5','SHA-1','SHA-256','SHA-384','SHA-512'].map(algo => (
        <div data-algo={algo} class="hash-row flex items-center gap-3 p-3 rounded-lg cursor-pointer transition-all" style="background: var(--bg); border: 1px solid var(--border);">
          <span class="text-xs font-bold w-20 shrink-0" style="color: var(--color-accent); font-family: var(--font-mono);">{algo}</span>
          <code class="flex-1 text-xs break-all" style="color: var(--text); font-family: var(--font-mono);" data-out>—</code>
          <span class="text-[10px] opacity-50" style="font-family: var(--font-mono);">CLICK</span>
        </div>
      ))}
    </div>
  </div>

  <div class="tool-card">
    <label class="tool-label">文件哈希</label>
    <div class="flex flex-wrap gap-3 items-center mb-3">
      <label class="tool-btn tool-btn-primary" for="file-input">选择文件</label>
      <input type="file" id="file-input" class="hidden" />
      <span id="file-name" class="text-xs" style="color: var(--text-secondary); font-family: var(--font-mono);">未选择文件</span>
    </div>
    <div class="space-y-2" id="file-results"></div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  const status = $('status'), msg = status.querySelector('.msg');
  const input = $('input');

  // Tiny MD5 implementation (public domain - blueimp md5 minified)
  // Using a compact MD5 since SubtleCrypto doesn't expose it.
  function md5(s){
    function toBytes(s){ return new TextEncoder().encode(s); }
    function add32(a,b){ return (a+b)&0xFFFFFFFF; }
    function rol(x,n){ return (x<<n)|(x>>>(32-n)); }
    function cmn(q,a,b,x,s,t){ return add32(rol(add32(add32(a,q),add32(x,t)),s),b); }
    function ff(a,b,c,d,x,s,t){ return cmn((b&c)|(~b&d),a,b,x,s,t); }
    function gg(a,b,c,d,x,s,t){ return cmn((b&d)|(c&~d),a,b,x,s,t); }
    function hh(a,b,c,d,x,s,t){ return cmn(b^c^d,a,b,x,s,t); }
    function ii(a,b,c,d,x,s,t){ return cmn(c^(b|~d),a,b,x,s,t); }
    const bytes = toBytes(s);
    const len = bytes.length;
    const padded = new Uint8Array(((len+8)>>6 << 6) + 64);
    padded.set(bytes); padded[len] = 0x80;
    const view = new DataView(padded.buffer);
    view.setUint32(padded.length-8, len*8, true);
    let a=0x67452301, b=0xefcdab89, c=0x98badcfe, d=0x10325476;
    for (let i=0; i<padded.length; i+=64){
      const x = []; for(let j=0;j<16;j++) x[j] = view.getUint32(i+j*4, true);
      const aa=a,bb=b,cc=c,dd=d;
      a=ff(a,b,c,d,x[0],7,-680876936);d=ff(d,a,b,c,x[1],12,-389564586);c=ff(c,d,a,b,x[2],17,606105819);b=ff(b,c,d,a,x[3],22,-1044525330);
      a=ff(a,b,c,d,x[4],7,-176418897);d=ff(d,a,b,c,x[5],12,1200080426);c=ff(c,d,a,b,x[6],17,-1473231341);b=ff(b,c,d,a,x[7],22,-45705983);
      a=ff(a,b,c,d,x[8],7,1770035416);d=ff(d,a,b,c,x[9],12,-1958414417);c=ff(c,d,a,b,x[10],17,-42063);b=ff(b,c,d,a,x[11],22,-1990404162);
      a=ff(a,b,c,d,x[12],7,1804603682);d=ff(d,a,b,c,x[13],12,-40341101);c=ff(c,d,a,b,x[14],17,-1502002290);b=ff(b,c,d,a,x[15],22,1236535329);
      a=gg(a,b,c,d,x[1],5,-165796510);d=gg(d,a,b,c,x[6],9,-1069501632);c=gg(c,d,a,b,x[11],14,643717713);b=gg(b,c,d,a,x[0],20,-373897302);
      a=gg(a,b,c,d,x[5],5,-701558691);d=gg(d,a,b,c,x[10],9,38016083);c=gg(c,d,a,b,x[15],14,-660478335);b=gg(b,c,d,a,x[4],20,-405537848);
      a=gg(a,b,c,d,x[9],5,568446438);d=gg(d,a,b,c,x[14],9,-1019803690);c=gg(c,d,a,b,x[3],14,-187363961);b=gg(b,c,d,a,x[8],20,1163531501);
      a=gg(a,b,c,d,x[13],5,-1444681467);d=gg(d,a,b,c,x[2],9,-51403784);c=gg(c,d,a,b,x[7],14,1735328473);b=gg(b,c,d,a,x[12],20,-1926607734);
      a=hh(a,b,c,d,x[5],4,-378558);d=hh(d,a,b,c,x[8],11,-2022574463);c=hh(c,d,a,b,x[11],16,1839030562);b=hh(b,c,d,a,x[14],23,-35309556);
      a=hh(a,b,c,d,x[1],4,-1530992060);d=hh(d,a,b,c,x[4],11,1272893353);c=hh(c,d,a,b,x[7],16,-155497632);b=hh(b,c,d,a,x[10],23,-1094730640);
      a=hh(a,b,c,d,x[13],4,681279174);d=hh(d,a,b,c,x[0],11,-358537222);c=hh(c,d,a,b,x[3],16,-722521979);b=hh(b,c,d,a,x[6],23,76029189);
      a=hh(a,b,c,d,x[9],4,-640364487);d=hh(d,a,b,c,x[12],11,-421815835);c=hh(c,d,a,b,x[15],16,530742520);b=hh(b,c,d,a,x[2],23,-995338651);
      a=ii(a,b,c,d,x[0],6,-198630844);d=ii(d,a,b,c,x[7],10,1126891415);c=ii(c,d,a,b,x[14],15,-1416354905);b=ii(b,c,d,a,x[5],21,-57434055);
      a=ii(a,b,c,d,x[12],6,1700485571);d=ii(d,a,b,c,x[3],10,-1894986606);c=ii(c,d,a,b,x[10],15,-1051523);b=ii(b,c,d,a,x[1],21,-2054922799);
      a=ii(a,b,c,d,x[8],6,1873313359);d=ii(d,a,b,c,x[15],10,-30611744);c=ii(c,d,a,b,x[6],15,-1560198380);b=ii(b,c,d,a,x[13],21,1309151649);
      a=ii(a,b,c,d,x[4],6,-145523070);d=ii(d,a,b,c,x[11],10,-1120210379);c=ii(c,d,a,b,x[2],15,718787259);b=ii(b,c,d,a,x[9],21,-343485551);
      a=add32(a,aa); b=add32(b,bb); c=add32(c,cc); d=add32(d,dd);
    }
    function hex(n){ let s=''; for(let i=0;i<4;i++){ s+=((n>>(i*8))&0xff).toString(16).padStart(2,'0'); } return s; }
    return hex(a)+hex(b)+hex(c)+hex(d);
  }

  async function sha(algo, buf){
    const h = await crypto.subtle.digest(algo, buf);
    return Array.from(new Uint8Array(h)).map(b=>b.toString(16).padStart(2,'0')).join('');
  }

  async function compute(text){
    const buf = new TextEncoder().encode(text);
    const algos = { 'MD5': null, 'SHA-1':'SHA-1', 'SHA-256':'SHA-256', 'SHA-384':'SHA-384', 'SHA-512':'SHA-512' };
    for (const [name, algo] of Object.entries(algos)) {
      const row = document.querySelector(`[data-algo="${name}"] [data-out]`);
      if (!text) { row.textContent = '—'; continue; }
      try {
        const h = algo ? await sha(algo, buf) : md5(text);
        row.textContent = h;
      } catch(e){ row.textContent = 'ERROR'; }
    }
  }

  let timer;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    msg.textContent = '计算中...';
    status.classList.remove('is-ok','is-err');
    timer = setTimeout(async () => {
      await compute(input.value);
      msg.textContent = '✓ 已计算';
      status.classList.add('is-ok');
    }, 150);
  });

  // Click to copy
  document.querySelectorAll('.hash-row').forEach(row => {
    row.onclick = () => {
      const v = row.querySelector('[data-out]').textContent;
      if (v && v !== '—') window.toolCopy(v);
    };
  });

  // File hash
  $('file-input').onchange = async e => {
    const f = e.target.files[0]; if (!f) return;
    $('file-name').textContent = f.name + ' (' + (f.size/1024).toFixed(1) + ' KB)';
    const buf = await f.arrayBuffer();
    const out = $('file-results');
    out.innerHTML = '';
    const algos = ['SHA-1','SHA-256','SHA-512'];
    for (const a of algos){
      const h = await sha(a, buf);
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 p-3 rounded-lg cursor-pointer';
      row.style.cssText = 'background: var(--bg); border: 1px solid var(--border);';
      row.innerHTML = `<span class="text-xs font-bold w-20 shrink-0" style="color: var(--color-accent); font-family: var(--font-mono);">${a}</span><code class="flex-1 text-xs break-all" style="color: var(--text); font-family: var(--font-mono);">${h}</code>`;
      row.onclick = () => window.toolCopy(h);
      out.appendChild(row);
    }
  };
})();
</script>
