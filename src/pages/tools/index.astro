---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

interface Tool {
  id: string;
  name: string;
  nameEn: string;
  desc: string;
  cat: string;
  status: 'live' | 'soon';
  href?: string;
}

const tools: Tool[] = [
  { id: 'json-formatter', name: 'JSON 格式化', nameEn: 'JSON Formatter', desc: '美化、压缩、校验 JSON,精确错误定位', cat: '数据格式', status: 'live' },
  { id: 'json-yaml', name: 'JSON ↔ YAML', nameEn: 'JSON YAML', desc: 'JSON 与 YAML 双向转换', cat: '数据格式', status: 'live' },
  { id: 'json-csv', name: 'JSON ↔ CSV', nameEn: 'JSON CSV', desc: 'JSON 数组与 CSV 互转,自动识别表头', cat: '数据格式', status: 'live' },
  { id: 'json-diff', name: 'JSON 差异对比', nameEn: 'JSON Diff', desc: '对比两个 JSON 找出新增/删除/修改字段', cat: '数据格式', status: 'live' },
  { id: 'xml-formatter', name: 'XML 格式化', nameEn: 'XML Formatter', desc: '美化、压缩、校验 XML', cat: '数据格式', status: 'live' },
  { id: 'sql-formatter', name: 'SQL 格式化', nameEn: 'SQL Formatter', desc: '美化 SQL 语句,支持多种方言', cat: '数据格式', status: 'live' },

  { id: 'base64', name: 'Base64 编解码', nameEn: 'Base64 Encoder', desc: '字符串/文件 Base64 编码与解码', cat: '编码转换', status: 'live' },
  { id: 'url-encode', name: 'URL 编解码', nameEn: 'URL Encoder', desc: 'URL 编码、百分比编码与还原', cat: '编码转换', status: 'live' },
  { id: 'html-entities', name: 'HTML 实体转义', nameEn: 'HTML Entities', desc: 'HTML 特殊字符与实体编码互转', cat: '编码转换', status: 'live' },
  { id: 'unicode', name: 'Unicode 转换', nameEn: 'Unicode Converter', desc: '文本与 Unicode 转义字符互转', cat: '编码转换', status: 'live' },
  { id: 'binary-text', name: '文本 ↔ 二进制', nameEn: 'Text Binary', desc: '文本与 ASCII 二进制 / 十六进制互转', cat: '编码转换', status: 'live' },
  { id: 'image-base64', name: '图片 ↔ Base64', nameEn: 'Image Base64', desc: '图片转 Data URI,可直接嵌入 HTML/CSS', cat: '编码转换', status: 'live' },
  { id: 'encoding-toolkit', name: '编码工具包', nameEn: 'Encoding Toolkit', desc: 'Base32 / Base58 / Hex / 摩尔斯 / ROT13', cat: '编码转换', status: 'live' },

  { id: 'hash', name: '哈希计算', nameEn: 'Hash', desc: 'MD5 / SHA-1 / SHA-256 / SHA-512 文本与文件', cat: '加密哈希', status: 'live' },
  { id: 'hmac', name: 'HMAC 签名', nameEn: 'HMAC', desc: '基于密钥的哈希消息认证码', cat: '加密哈希', status: 'live' },
  { id: 'jwt', name: 'JWT 解析', nameEn: 'JWT Parser', desc: '解析 JSON Web Token 头部与载荷', cat: '加密哈希', status: 'live' },
  { id: 'aes', name: 'AES 加解密', nameEn: 'AES', desc: 'AES-GCM 256 对称加密,密码派生密钥', cat: '加密哈希', status: 'live' },
  { id: 'otp', name: 'TOTP 验证器', nameEn: 'TOTP', desc: 'RFC 6238 实时 6 位验证码', cat: '加密哈希', status: 'live' },
  { id: 'basic-auth', name: 'Basic Auth 生成', nameEn: 'Basic Auth', desc: '生成 HTTP Basic 认证头', cat: '加密哈希', status: 'live' },

  { id: 'uuid', name: 'UUID 生成器', nameEn: 'UUID Generator', desc: '批量生成 UUID v4 / v7 / 短 ID', cat: '生成器', status: 'live' },
  { id: 'ulid', name: 'ULID 生成', nameEn: 'ULID', desc: '字典序可排序的唯一标识符', cat: '生成器', status: 'live' },
  { id: 'password', name: '密码生成器', nameEn: 'Password Generator', desc: '生成强密码,可控字符集与长度', cat: '生成器', status: 'live' },
  { id: 'token', name: 'Token 生成器', nameEn: 'Token Generator', desc: '生成 API token / 随机字符串', cat: '生成器', status: 'live' },
  { id: 'lorem', name: 'Lorem Ipsum', nameEn: 'Lorem Ipsum', desc: '生成中英文占位文本', cat: '生成器', status: 'live' },
  { id: 'qrcode', name: '二维码生成', nameEn: 'QR Code', desc: '文本 / 链接 / WiFi / vCard 二维码', cat: '生成器', status: 'live' },

  { id: 'timestamp', name: '时间戳转换', nameEn: 'Timestamp', desc: 'Unix 时间戳与日期互转,实时显示', cat: '时间日期', status: 'live' },
  { id: 'cron', name: 'Cron 表达式', nameEn: 'Cron Parser', desc: '解析 Cron 并预测未来 10 次执行', cat: '时间日期', status: 'live' },
  { id: 'date-diff', name: '日期计算器', nameEn: 'Date Diff', desc: '两日期相差、日期加减、年龄计算', cat: '时间日期', status: 'live' },

  { id: 'markdown-html', name: 'Markdown ↔ HTML', nameEn: 'Markdown HTML', desc: 'Markdown 与 HTML 双向转换,支持 GFM', cat: '文本处理', status: 'live' },
  { id: 'text-diff', name: '文本对比', nameEn: 'Text Diff', desc: '两段文本逐行高亮差异', cat: '文本处理', status: 'live' },
  { id: 'case-converter', name: '大小写转换', nameEn: 'Case Converter', desc: 'camel / snake / kebab / Pascal 等', cat: '文本处理', status: 'live' },
  { id: 'text-stats', name: '文本统计', nameEn: 'Text Stats', desc: '字数/字符/行数/段落/中英文/阅读时长', cat: '文本处理', status: 'live' },
  { id: 'regex', name: '正则测试', nameEn: 'Regex Tester', desc: '正则匹配高亮、捕获组、替换', cat: '文本处理', status: 'live' },
  { id: 'slug', name: 'Slug 生成', nameEn: 'Slugify', desc: '生成 URL 友好的 slug', cat: '文本处理', status: 'live' },
  { id: 'line-tools', name: '行处理', nameEn: 'Line Tools', desc: '排序 / 去重 / 反转 / 加前后缀', cat: '文本处理', status: 'live' },
  { id: 'html-stripper', name: 'HTML 去标签', nameEn: 'HTML Stripper', desc: '提取纯文本,可仅去属性/注释/script', cat: '文本处理', status: 'live' },
  { id: 'ascii-art', name: 'ASCII 艺术字', nameEn: 'ASCII Art', desc: '文本转大字体 ASCII 艺术', cat: '文本处理', status: 'live' },

  { id: 'url-parser', name: 'URL 解析', nameEn: 'URL Parser', desc: '解析 URL 各组成部分与查询参数', cat: '网络工具', status: 'live' },
  { id: 'http-status', name: 'HTTP 状态码', nameEn: 'HTTP Status', desc: 'HTTP 状态码完整速查表', cat: '网络工具', status: 'live' },
  { id: 'mime-types', name: 'MIME 类型查询', nameEn: 'MIME Types', desc: '文件扩展名与 MIME 类型互查', cat: '网络工具', status: 'live' },
  { id: 'user-agent', name: 'UA 解析', nameEn: 'User Agent', desc: '识别浏览器、操作系统、设备', cat: '网络工具', status: 'live' },
  { id: 'ipv4-subnet', name: 'IPv4 子网', nameEn: 'IPv4 Subnet', desc: 'CIDR 解析、网络号、广播、范围', cat: '网络工具', status: 'live' },
  { id: 'curl-to-fetch', name: 'curl → 代码', nameEn: 'curl to code', desc: '把 curl 命令转成 fetch / axios 代码', cat: '网络工具', status: 'live' },
  { id: 'og-generator', name: 'Open Graph', nameEn: 'OG Meta', desc: '生成 OG + Twitter Card 元标签,实时预览', cat: '网络工具', status: 'live' },

  { id: 'color', name: '颜色转换', nameEn: 'Color Converter', desc: 'HEX/RGB/HSL/HSV/CMYK 互转,EyeDropper 取色', cat: '颜色图像', status: 'live' },
  { id: 'gradient', name: '渐变生成', nameEn: 'Gradient Maker', desc: '可视化生成 CSS linear/radial/conic 渐变', cat: '颜色图像', status: 'live' },
  { id: 'svg-placeholder', name: 'SVG 占位图', nameEn: 'SVG Placeholder', desc: '自定义尺寸/颜色/文字的 SVG 占位图', cat: '颜色图像', status: 'live' },
  { id: 'image-resize', name: '图片压缩', nameEn: 'Image Resize', desc: '本地压缩,WebP/JPG/PNG 输出', cat: '颜色图像', status: 'live' },
  { id: 'favicon', name: 'Favicon 生成', nameEn: 'Favicon', desc: '一键生成多尺寸 PNG favicon + HTML', cat: '颜色图像', status: 'live' },

  { id: 'mermaid', name: 'Mermaid 预览', nameEn: 'Mermaid', desc: '实时渲染流程图/时序图/饼图/甘特图', cat: '开发辅助', status: 'live' },
  { id: 'chmod', name: 'Chmod 计算', nameEn: 'Chmod Calc', desc: 'Linux 文件权限可视化计算', cat: '开发辅助', status: 'live' },
  { id: 'rem-px', name: 'REM ↔ PX', nameEn: 'REM PX', desc: '前端字号单位换算 + 对照表', cat: '开发辅助', status: 'live' },
  { id: 'keycode', name: 'Keycode 速查', nameEn: 'Keycode', desc: '按键代码、修饰符、Unicode', cat: '开发辅助', status: 'live' },
  { id: 'number-base', name: '进制转换', nameEn: 'Base Convert', desc: '二进制/八进制/十进制/十六进制互转', cat: '开发辅助', status: 'live' },
  { id: 'css-formatter', name: 'CSS 格式化', nameEn: 'CSS Formatter', desc: '美化与压缩 CSS', cat: '开发辅助', status: 'live' },
  { id: 'js-formatter', name: 'JS / HTML 格式化', nameEn: 'JS HTML Formatter', desc: 'Prettier 格式化 JS / TS / HTML', cat: '开发辅助', status: 'live' },
  { id: 'math-eval', name: '数学计算器', nameEn: 'Math Eval', desc: '支持 sin/cos/log/sqrt 等函数与历史', cat: '开发辅助', status: 'live' },
  { id: 'temp-percent', name: '温度 / 百分比', nameEn: 'Temp & Percent', desc: '°C/°F/K 互转 + 百分比计算', cat: '开发辅助', status: 'live' },
  { id: 'roman', name: '罗马数字', nameEn: 'Roman Numeral', desc: '阿拉伯数字 ↔ 罗马数字', cat: '开发辅助', status: 'live' },
  { id: 'wx2x', name: '公众号 → X', nameEn: 'WeChat to X', desc: '微信公众号文章转 X (Twitter) Articles', cat: '开发辅助', status: 'live', href: '/tools/wx2x' },
  { id: 'english-learning', name: '英语学习导航', nameEn: 'English Learning', desc: '语雀英语学习清单整理版，支持搜索和分类浏览', cat: '学习资源', status: 'live' },
];

const toolById = new Map(tools.map((tool) => [tool.id, tool]));
const categories = [...new Set(tools.map((tool) => tool.cat))];
const liveCount = tools.filter((tool) => tool.status === 'live').length;

const categoryMeta: Record<string, { code: string; desc: string }> = {
  数据格式: { code: 'DATA', desc: '结构化输入的清洗、转换、对比和格式化。' },
  编码转换: { code: 'CODEC', desc: 'Base64、URL、Unicode、二进制等编码互转。' },
  加密哈希: { code: 'CRYPTO', desc: '哈希、签名、Token 与基础安全校验。' },
  生成器: { code: 'GEN', desc: '批量生成标识符、密码、二维码和占位内容。' },
  时间日期: { code: 'TIME', desc: '时间戳、Cron、日期差值这些时间类速查。' },
  文本处理: { code: 'TEXT', desc: '统计、对比、清洗、命名转换和 Markdown 处理。' },
  网络工具: { code: 'NET', desc: 'URL、HTTP、MIME、UA、CIDR 和接口调试辅助。' },
  颜色图像: { code: 'PIXEL', desc: '颜色、渐变、占位图、图片压缩与图标生成。' },
  开发辅助: { code: 'DEV', desc: '前端、终端、键盘、权限和数学相关小工具。' },
  学习资源: { code: 'LEARN', desc: '学习导航和内容整理类资源入口。' },
};

const featuredIds = [
  'json-formatter',
  'password',
  'timestamp',
  'regex',
  'curl-to-fetch',
  'color',
  'english-learning',
  'wx2x',
];

const featuredTools = featuredIds.map((id) => toolById.get(id)).filter(Boolean) as Tool[];

const categoryGroups = categories.map((cat) => {
  const items = tools.filter((tool) => tool.cat === cat);
  return {
    cat,
    items,
    live: items.filter((tool) => tool.status === 'live').length,
    meta: categoryMeta[cat] || { code: cat.slice(0, 4).toUpperCase(), desc: '常用工具集合。' },
  };
});

const getToolHref = (tool: Tool) => tool.href || `/tools/${tool.id}`;
const getToolMark = (tool: Tool) => {
  const normalized = tool.nameEn
    .replace(/[↔→]/g, ' ')
    .replace(/[^a-zA-Z0-9+]+/g, ' ')
    .trim();
  const upper = normalized.toUpperCase();
  const common = ['JSON', 'YAML', 'CSV', 'XML', 'SQL', 'JWT', 'AES', 'OTP', 'UUID', 'ULID', 'URL', 'HTML', 'CSS', 'MIME', 'HTTP', 'OG', 'HMAC', 'TOTP'];
  const matched = common.find((item) => upper.includes(item));
  if (matched) return matched.slice(0, 4);
  if (upper.includes('BASE64')) return '64';
  const parts = normalized.split(/\s+/).filter(Boolean);
  return parts
    .slice(0, 2)
    .map((part) => part.replace(/[^a-zA-Z0-9]/g, '').slice(0, 1).toUpperCase())
    .join('') || tool.id.slice(0, 2).toUpperCase();
};
---

<BaseLayout
  title="工具箱 · siuser小伟"
  description="开发者日常工具集合 - JSON / Base64 / 哈希 / 时间戳 / 二维码 / 颜色等纯前端在线工具"
>
  <Header />

  <main class="tools-page pt-28 pb-24">
    <div class="tools-container mx-auto px-4 sm:px-6">
      <section class="tools-hero scroll-reveal">
        <div class="tools-hero-copy arsenal-panel">
          <p class="section-kicker">Arsenal / Tool Repository</p>
          <h1 class="tools-title display-serif">
            高频小动作，<br />
            都收进这座<em>工具仓库</em>。
          </h1>
          <p class="tools-lede">
            JSON、加密、编码、时间、网络、文本和学习资源集中陈列。像查库存一样检索，像拿工具一样打开，尽量留在浏览器本地完成。
          </p>

          <div class="tools-hero-stats">
            <div>
              <span class="k">Live tools</span>
              <strong>{liveCount}</strong>
            </div>
            <div>
              <span class="k">Categories</span>
              <strong>{categories.length}</strong>
            </div>
            <div>
              <span class="k">Runtime</span>
              <strong>浏览器本地</strong>
            </div>
            <div>
              <span class="k">Upload</span>
              <strong>Zero</strong>
            </div>
          </div>
        </div>

        <aside class="tools-command-panel arsenal-panel" aria-label="工具搜索和分类筛选">
          <div class="command-head">
            <span>Command search</span>
            <strong>{liveCount} ready</strong>
          </div>

          <label class="tools-search-label" for="tool-search">搜索工具</label>
          <div class="tools-search-box">
            <span class="search-mark">/</span>
            <input id="tool-search" type="search" placeholder="JSON、Token、颜色、英语、curl..." autocomplete="off" />
            <kbd>⌘K</kbd>
          </div>

          <div class="tools-chip-row" aria-label="按分类筛选">
            <button class="tools-chip is-active" data-cat-filter="all" type="button" aria-pressed="true">全部 · {liveCount}</button>
            {categories.map((cat) => {
              const n = tools.filter((tool) => tool.cat === cat).length;
              return (
                <button class="tools-chip" data-cat-filter={cat} type="button" aria-pressed="false">{cat} · {n}</button>
              );
            })}
          </div>
        </aside>
      </section>

      <section class="featured-section scroll-reveal" data-feature-section>
        <div class="section-row">
          <div>
            <p class="section-kicker">Featured Tools</p>
            <h2 class="section-h2 display-serif">精选工具。</h2>
          </div>
          <p class="directory-note" id="featured-count">{featuredTools.length} 个高频入口</p>
        </div>

        <div class="featured-grid">
          {featuredTools.map((tool, index) => {
            const href = tool.status === 'live' ? getToolHref(tool) : '#';
            return (
              <a
                href={href}
                data-feature-card
                data-tool-name={`${tool.name} ${tool.nameEn} ${tool.desc} ${tool.cat}`.toLowerCase()}
                data-tool-cat={tool.cat}
                class:list={['featured-tool-card', tool.status === 'soon' && 'is-soon']}
                aria-disabled={tool.status === 'soon' ? 'true' : undefined}
              >
                <div class="featured-rank">0{index + 1}</div>
                <div class="featured-head">
                  <span class="tool-card-icon">{getToolMark(tool)}</span>
                  <span class="tool-status-pill is-live">{tool.status === 'live' ? '已上线' : '排队中'}</span>
                </div>
                <div>
                  <p class="tool-card-cat">{tool.cat}</p>
                  <h3 class="featured-title">{tool.name}</h3>
                  <p class="tool-card-desc">{tool.desc}</p>
                </div>
                <div class="tool-card-foot">
                  <span>{tool.nameEn}</span>
                  <em>OPEN</em>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <section class="tools-directory scroll-reveal">
        <div class="section-row">
          <div>
            <p class="section-kicker">All Tools</p>
            <h2 class="section-h2 display-serif">全部工具。</h2>
          </div>
          <p class="directory-note" id="directory-count">{liveCount} 项全部可用</p>
        </div>

        <div id="empty-state" class="tools-empty hidden">
          <p class="empty-mark">EMPTY</p>
          <p>没有匹配结果。换个关键词或清除分类筛选。</p>
        </div>

        <div class="category-stack">
          {categoryGroups.map((group) => (
            <section class="category-block" data-category-group={group.cat}>
              <div class="category-head">
                <div class="category-title-row">
                  <span class="category-code">{group.meta.code}</span>
                  <div>
                    <h3>{group.cat}</h3>
                    <p>{group.meta.desc}</p>
                  </div>
                </div>
                <span class="category-count">{group.live} / {group.items.length} live</span>
              </div>

              <div class="tool-grid">
                {group.items.map((tool) => {
                  const href = tool.status === 'live' ? getToolHref(tool) : '#';
                  return (
                    <a
                      href={href}
                      data-tool-card
                      data-tool-name={`${tool.name} ${tool.nameEn} ${tool.desc} ${tool.cat}`.toLowerCase()}
                      data-tool-cat={tool.cat}
                      class:list={['tool-card-item', tool.status === 'soon' && 'is-soon']}
                      aria-disabled={tool.status === 'soon' ? 'true' : undefined}
                    >
                      <div class="tool-card-head">
                        <span class="tool-card-icon">{getToolMark(tool)}</span>
                        <span class="tool-status-pill is-live">{tool.status === 'live' ? '已上线' : '排队中'}</span>
                      </div>
                      <div class="tool-card-body">
                        <p class="tool-card-cat">{tool.cat}</p>
                        <h4 class="tool-card-title">{tool.name}</h4>
                        <p class="tool-card-desc">{tool.desc}</p>
                      </div>
                      <div class="tool-card-foot">
                        <span>{tool.nameEn}</span>
                        <em>OPEN</em>
                      </div>
                    </a>
                  );
                })}
              </div>
            </section>
          ))}
        </div>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .tools-page {
    min-height: 100vh;
    color: var(--text);
    position: relative;
    overflow-x: hidden;
    background:
      repeating-linear-gradient(90deg, color-mix(in srgb, var(--color-accent-2) 10%, transparent) 0 1px, transparent 1px 96px),
      repeating-linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 8%, transparent) 0 1px, transparent 1px 96px),
      linear-gradient(180deg, var(--bg) 0%, var(--bg-elevated) 46%, var(--bg) 100%);
  }

  .tools-page::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(115deg, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 34%, color-mix(in srgb, var(--color-accent-2) 8%, transparent) 100%);
    opacity: 0.32;
  }

  .tools-container {
    width: 100%;
    max-width: min(1240px, 100%);
    position: relative;
    z-index: 1;
  }

  .tools-page .section-kicker,
  .tools-page h1,
  .tools-page h2,
  .tools-page h3,
  .tools-page h4,
  .tools-page p,
  .tools-page span,
  .tools-page strong,
  .tools-page button,
  .tools-page input,
  .tools-page kbd,
  .tools-page em {
    letter-spacing: 0;
  }

  .tools-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    gap: 1rem;
    align-items: stretch;
    margin-bottom: 2.4rem;
  }

  .arsenal-panel {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: 0 24px 70px -48px rgba(0, 0, 0, 0.75);
  }

  .tools-hero-copy {
    display: flex;
    min-height: 25rem;
    flex-direction: column;
    justify-content: space-between;
    padding: 2rem;
