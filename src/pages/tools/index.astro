<script is:inline>
  (() => {
    const search = document.getElementById('tool-search');
    const directoryCards = Array.from(document.querySelectorAll('[data-tool-card]'));
    const featureCards = Array.from(document.querySelectorAll('[data-feature-card]'));
    const groups = Array.from(document.querySelectorAll('[data-category-group]'));
    const chips = Array.from(document.querySelectorAll('[data-cat-filter]'));
    const empty = document.getElementById('empty-state');
    const directoryCount = document.getElementById('directory-count');
    const featuredCount = document.getElementById('featured-count');
    const featuredSection = document.querySelector('[data-feature-section]');
    const revealElements = document.querySelectorAll('.scroll-reveal');
    let activeCategory = 'all';

    const matchesFilters = (card, query) => {
      const matchesQuery = !query || (card.dataset.toolName || '').includes(query);
      const matchesCategory = activeCategory === 'all' || card.dataset.toolCat === activeCategory;
      return matchesQuery && matchesCategory;
    };

    const syncDirectory = () => {
      const query = (search?.value || '').trim().toLowerCase();
      let visibleDirectoryCount = 0;
      let visibleFeaturedCount = 0;

      directoryCards.forEach((card) => {
        const visible = matchesFilters(card, query);
        card.classList.toggle('hidden', !visible);
        if (visible) visibleDirectoryCount += 1;
      });

      featureCards.forEach((card) => {
        const visible = matchesFilters(card, query);
        card.classList.toggle('hidden', !visible);
        if (visible) visibleFeaturedCount += 1;
      });

      groups.forEach((group) => {
        const visibleInGroup = directoryCards.some((card) => (
          card.dataset.toolCat === group.getAttribute('data-category-group') &&
          !card.classList.contains('hidden')
        ));
        group.classList.toggle('hidden', !visibleInGroup);
      });

      if (directoryCount) {
        directoryCount.textContent = activeCategory === 'all' && !query
          ? `${visibleDirectoryCount} 项全部可用`
          : `${visibleDirectoryCount} 项匹配`;
      }

      if (featuredCount) {
        featuredCount.textContent = activeCategory === 'all' && !query
          ? `${visibleFeaturedCount} 个高频入口`
          : `${visibleFeaturedCount} 个精选匹配`;
      }

      featuredSection?.classList.toggle('hidden', visibleFeaturedCount === 0);
      empty?.classList.toggle('hidden', visibleDirectoryCount > 0);
    };

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        activeCategory = chip.getAttribute('data-cat-filter') || 'all';
        chips.forEach((item) => item.classList.remove('is-active'));
        chips.forEach((item) => item.setAttribute('aria-pressed', 'false'));
        chip.classList.add('is-active');
        chip.setAttribute('aria-pressed', 'true');
        syncDirectory();
      });
    });

    search?.addEventListener('input', syncDirectory);

    // Cmd/Ctrl + K focuses the search
    window.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        search?.focus();
      }
    });

    syncDirectory();

    if (revealElements.length) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });

      revealElements.forEach((element) => observer.observe(element));
    }
  })();
</script>
