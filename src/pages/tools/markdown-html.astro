---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="Markdown ↔ HTML" description="Markdown 与 HTML 双向转换,GFM 兼容" category="文本处理" icon="M↓">
  <div class="tool-card">
    <div class="tool-toolbar">
      <button class="tool-btn tool-btn-primary" id="btn-md2html">MD → HTML</button>
      <button class="tool-btn" id="btn-html2md">HTML → MD</button>
      <button class="tool-btn" id="btn-preview">切换预览</button>
      <button class="tool-btn tool-btn-ghost" id="btn-copy">复制结果</button>
      <button class="tool-btn tool-btn-ghost" id="btn-sample">示例</button>
    </div>
    <div class="tool-grid-2 mt-3">
      <div>
        <label class="tool-label">输入</label>
        <textarea id="src" class="tool-textarea" style="min-height: 360px;" placeholder="# Hello"></textarea>
      </div>
      <div>
        <label class="tool-label">输出</label>
        <textarea id="out" class="tool-textarea hidden" style="min-height: 360px;"></textarea>
        <div id="preview" class="tool-output prose-area" style="min-height: 360px;"></div>
      </div>
    </div>
  </div>
</ToolLayout>

<style>
  .prose-area { color: var(--text); }
  .prose-area h1, .prose-area h2, .prose-area h3 { color: var(--color-accent); margin: 1em 0 0.5em; font-family: var(--font-heading); }
  .prose-area h1 { font-size: 1.6em; }
  .prose-area h2 { font-size: 1.3em; }
  .prose-area p { margin: 0.7em 0; line-height: 1.7; }
  .prose-area code { background: var(--surface-2); padding: 0.1em 0.4em; border-radius: 4px; font-family: var(--font-mono); font-size: 0.9em; }
  .prose-area pre { background: var(--surface-2); padding: 1em; border-radius: 8px; overflow-x: auto; margin: 1em 0; }
  .prose-area pre code { background: transparent; padding: 0; }
  .prose-area ul, .prose-area ol { padding-left: 1.5em; margin: 0.7em 0; }
  .prose-area li { margin: 0.3em 0; }
  .prose-area a { color: var(--color-accent); text-decoration: underline; }
  .prose-area blockquote { border-left: 3px solid var(--color-accent); padding-left: 1em; color: var(--text-secondary); margin: 1em 0; }
  .prose-area hr { border: none; border-top: 1px solid var(--border); margin: 1.5em 0; }
  .prose-area table { border-collapse: collapse; width: 100%; margin: 1em 0; }
  .prose-area th, .prose-area td { border: 1px solid var(--border); padding: 0.5em 0.8em; }
  .prose-area th { background: var(--surface-2); }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/turndown@7.1.3/dist/turndown.js"></script>
<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  let mode = 'preview';

  function md2html(){
    if (typeof marked === 'undefined') return setTimeout(md2html, 200);
    marked.setOptions({ gfm: true, breaks: true });
    const html = marked.parse($('src').value || '');
    $('out').value = html;
    $('preview').innerHTML = html;
  }
  function html2md(){
    if (typeof TurndownService === 'undefined') return setTimeout(html2md, 200);
    const td = new TurndownService({ headingStyle:'atx', codeBlockStyle:'fenced' });
    const md = td.turndown($('src').value || '');
    $('out').value = md;
    $('preview').textContent = md;
  }

  $('btn-md2html').onclick = () => { mode='html'; md2html(); };
  $('btn-html2md').onclick = () => { mode='md'; html2md(); };
  $('btn-preview').onclick = () => {
    $('out').classList.toggle('hidden');
    $('preview').classList.toggle('hidden');
  };
  $('btn-copy').onclick = () => $('out').value && window.toolCopy($('out').value);
  $('btn-sample').onclick = () => {
    $('src').value = '# 标题一\n\n这是一段 **加粗** 与 *斜体* 文本,还有 `inline code`。\n\n## 列表\n- 项 1\n- 项 2\n\n```js\nconsole.log("Hello")\n```\n\n> 引用块\n\n[链接](https://siuserxiaowei.com)';
    md2html();
  };

  $('src').addEventListener('input', () => mode==='md' ? html2md() : md2html());
  setTimeout(() => { $('btn-sample').click(); }, 400);
})();
</script>
