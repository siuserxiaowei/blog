---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="正则表达式测试" description="实时高亮匹配,支持捕获组与替换" category="文本处理" icon="/.*/" >
  <div class="tool-card mb-6">
    <label class="tool-label">正则表达式</label>
    <div class="flex gap-2 items-center">
      <span class="text-lg" style="color: var(--text-secondary); font-family: var(--font-mono);">/</span>
      <input id="pattern" class="tool-input flex-1" style="font-family: var(--font-mono);" placeholder="\d{3,}" />
      <span class="text-lg" style="color: var(--text-secondary); font-family: var(--font-mono);">/</span>
      <input id="flags" class="tool-input" style="max-width: 100px;" value="gi" />
    </div>
    <div class="tool-toolbar mt-2">
      {[['IP','\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b'],['Email','[\\w.+-]+@[\\w-]+\\.[\\w.-]+'],['URL','https?://[\\w.-]+(?:/[\\w./?=&%-]*)?'],['手机号','1[3-9]\\d{9}'],['日期','\\d{4}-\\d{2}-\\d{2}']].map(([n,r])=>(
        <button class="tool-btn preset" data-r={r}>{n}</button>
      ))}
    </div>
    <div class="tool-status" id="status"><span class="dot"></span><span class="msg">输入正则与文本</span></div>
  </div>

  <div class="tool-card mb-6">
    <label class="tool-label">测试文本</label>
    <textarea id="text" class="tool-textarea" style="min-height: 180px;" placeholder="待匹配文本"></textarea>
    <label class="tool-label mt-3">匹配高亮</label>
    <pre id="hl" class="tool-output" style="min-height: 100px; line-height: 1.6;"></pre>
  </div>

  <div class="tool-card">
    <label class="tool-label">替换</label>
    <input id="replace" class="tool-input" placeholder="替换为...(支持 $1 $2 捕获组)" />
    <label class="tool-label mt-3">替换结果</label>
    <pre id="rep-out" class="tool-output" style="min-height: 100px;"></pre>
    <label class="tool-label mt-3">匹配列表</label>
    <pre id="matches" class="tool-output" style="min-height: 100px;"></pre>
  </div>
</ToolLayout>

<style>
  #hl mark { background: var(--color-accent); color: var(--color-bg-dark); padding: 0 2px; border-radius: 3px; }
</style>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  const status = $('status'), msg = status.querySelector('.msg');
  const setStatus = (t,k) => { msg.textContent = t; status.classList.remove('is-ok','is-err'); if(k) status.classList.add('is-'+k); };

  function run(){
    const p = $('pattern').value, f = $('flags').value, t = $('text').value;
    if (!p) { $('hl').textContent = t; $('matches').textContent = '—'; $('rep-out').textContent = t; setStatus('等待输入'); return; }
    let re;
    try { re = new RegExp(p, f); } catch(e){ setStatus('✗ '+e.message,'err'); return; }
    try {
      const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;');
      const hl = esc(t).replace(re, m => `<mark>${esc(m)}</mark>`);
      $('hl').innerHTML = hl;
      const matches = [...t.matchAll(re.flags.includes('g') ? re : new RegExp(p, f+'g'))];
      $('matches').textContent = matches.length === 0 ? '无匹配' :
        matches.map((m,i)=>`#${i+1} @${m.index}: ${JSON.stringify(m[0])}${m.length>1?' | groups: '+JSON.stringify(m.slice(1)):''}`).join('\n');
      $('rep-out').textContent = t.replace(re, $('replace').value);
      setStatus(`✓ 共 ${matches.length} 个匹配`, 'ok');
    } catch(e){ setStatus('✗ '+e.message,'err'); }
  }

  ['pattern','flags','text','replace'].forEach(id => $(id).addEventListener('input', run));
  document.querySelectorAll('.preset').forEach(b => b.onclick = () => { $('pattern').value = b.dataset.r; run(); });
  run();
})();
</script>
