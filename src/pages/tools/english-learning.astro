const allItems = sections.flatMap(section =>
  section.items.map(item => ({
    ...item,
    sectionId: section.id,
    sectionName: section.name,
  }))
);

const totalCount = allItems.length;
const sectionCount = sections.length;

function getHostname(url: string) {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
}
---

<ToolLayout
  title="英语学习导航"
  description="把语雀里的英语学习资源整理成一个可搜索、可筛选的工具页，词典、听力、写作、测试和学习路线一页收齐。"
  category="学习资源"
  icon="🆎"
>
  <section class="resource-hero tool-card">
    <div class="resource-hero-top">
      <div>
        <p class="resource-kicker">SOURCE CURATED</p>
        <h2>英语学习工具与资源导航</h2>
      </div>
      <a class="tool-btn tool-btn-ghost" href={sourceUrl} target="_blank" rel="noreferrer">
        查看语雀原文
      </a>
    </div>

    <p class="resource-intro">
      这页内容来自你给的语雀清单，按用途做了去重整理。更适合直接检索和跳转，而不是在长文里一条条翻。
    </p>

    <div class="resource-meta-grid">
      <div class="resource-meta-card">
        <span class="k">资源数量</span>
        <strong>{totalCount}</strong>
      </div>
      <div class="resource-meta-card">
        <span class="k">分类数量</span>
        <strong>{sectionCount}</strong>
      </div>
      <div class="resource-meta-card">
        <span class="k">整理方式</span>
        <strong>去重 + 分组</strong>
      </div>
    </div>

    <div class="resource-controls">
      <input
        id="resource-search"
        type="search"
        class="tool-input"
        placeholder="搜索词典、发音、雅思、语法、写作、测试..."
      />
      <div class="resource-chip-row">
        <button class="resource-chip is-active" type="button" data-filter="all">全部</button>
        {sections.map(section => (
          <button class="resource-chip" type="button" data-filter={section.id}>{section.name}</button>
        ))}
      </div>
    </div>
  </section>

  <section id="resource-empty" class="resource-empty hidden">
    <div class="resource-empty-icon">∅</div>
    <p>没有匹配到结果，换个关键词试试。</p>
  </section>

  <div class="resource-sections">
    {sections.map(section => (
      <section class="resource-section tool-card" data-section={section.id}>
        <div class="resource-section-head">
          <div class="resource-section-title">
            <span class="resource-section-icon">{section.icon}</span>
            <div>
              <h3>{section.name}</h3>
              <p>{section.items.length} 个站点</p>
            </div>
          </div>
        </div>

        <div class="resource-grid">
          {section.items.map(item => (
            <a
              class="resource-card"
              href={item.url}
              target="_blank"
              rel="noreferrer"
              data-resource-card
              data-searchable={`${item.title} ${item.desc || ''} ${section.name} ${getHostname(item.url)}`.toLowerCase()}
            >
              <div class="resource-card-top">
                <strong>{item.title}</strong>
                <span>{getHostname(item.url)}</span>
              </div>
              {item.desc && <p>{item.desc}</p>}
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</ToolLayout>

<script is:inline>
  (() => {
    const search = document.getElementById('resource-search');
    const chips = Array.from(document.querySelectorAll('.resource-chip'));
    const sections = Array.from(document.querySelectorAll('[data-section]'));
    const cards = Array.from(document.querySelectorAll('[data-resource-card]'));
    const empty = document.getElementById('resource-empty');
    let currentFilter = 'all';

    function sync() {
      const keyword = (search?.value || '').trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach(card => {
        const element = card;
        const matchesKeyword = !keyword || (element.dataset.searchable || '').includes(keyword);
        const parent = element.closest('[data-section]');
        const matchesFilter = currentFilter === 'all' || parent?.getAttribute('data-section') === currentFilter;
        const visible = matchesKeyword && matchesFilter;
        element.classList.toggle('hidden', !visible);
        if (visible) visibleCount += 1;
      });

      sections.forEach(section => {
        const hasVisibleCard = section.querySelector('[data-resource-card]:not(.hidden)');
        section.classList.toggle('hidden', !hasVisibleCard);
      });

      empty?.classList.toggle('hidden', visibleCount > 0);
    }

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        currentFilter = chip.getAttribute('data-filter') || 'all';
        chips.forEach(item => item.classList.remove('is-active'));
        chip.classList.add('is-active');
        sync();
      });
    });

    search?.addEventListener('input', sync);
    sync();
  })();
</script>

