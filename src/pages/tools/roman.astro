---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="罗马数字" description="阿拉伯数字 ↔ 罗马数字互转" category="开发辅助" icon="Ⅻ">
  <div class="tool-card">
    <div class="tool-grid-2">
      <div>
        <label class="tool-label">阿拉伯数字</label>
        <input id="num" type="number" min="1" max="3999" value="2026" class="tool-input" style="font-family: var(--font-mono); font-size: 1.5rem;" />
        <p class="text-xs mt-2" style="color: var(--text-secondary);">范围: 1 - 3999</p>
      </div>
      <div>
        <label class="tool-label">罗马数字</label>
        <input id="rom" class="tool-input" style="font-family: var(--font-mono); font-size: 1.5rem; text-transform: uppercase;" placeholder="MMXXVI" />
        <p class="text-xs mt-2" style="color: var(--text-secondary);">支持: I V X L C D M</p>
      </div>
    </div>

    <div class="tool-status" id="status"><span class="dot"></span><span class="msg">输入数字或罗马数字</span></div>

    <div class="grid grid-cols-2 md:grid-cols-7 gap-2 mt-6">
      {[['I',1],['V',5],['X',10],['L',50],['C',100],['D',500],['M',1000]].map(([s,v])=>(
        <div class="text-center p-3 rounded-lg" style="background: var(--bg); border: 1px solid var(--border);">
          <div class="text-2xl font-bold" style="color: var(--color-accent); font-family: var(--font-mono);">{s}</div>
          <div class="text-xs" style="color: var(--text-secondary);">{v}</div>
        </div>
      ))}
    </div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  const status = $('status'), msg = status.querySelector('.msg');
  const setStatus = (t,k) => { msg.textContent = t; status.classList.remove('is-ok','is-err'); if(k) status.classList.add('is-'+k); };

  const map = [['M',1000],['CM',900],['D',500],['CD',400],['C',100],['XC',90],['L',50],['XL',40],['X',10],['IX',9],['V',5],['IV',4],['I',1]];

  function toRoman(n){
    if (n<1||n>3999) throw new Error('范围 1-3999');
    let s = '';
    for (const [r,v] of map){ while (n >= v){ s += r; n -= v; } }
    return s;
  }
  function fromRoman(s){
    s = s.toUpperCase();
    if (!/^[IVXLCDM]+$/.test(s)) throw new Error('仅 I V X L C D M');
    let n = 0;
    for (let i=0;i<s.length;i++){
      const cur = map.find(m => m[0]===s[i])?.[1] || 0;
      const nxt = map.find(m => m[0]===s[i+1])?.[1] || 0;
      n += cur < nxt ? -cur : cur;
    }
    if (toRoman(n) !== s) throw new Error('非规范表达');
    return n;
  }

  $('num').addEventListener('input', () => {
    try { $('rom').value = toRoman(+$('num').value); setStatus('✓','ok'); } catch(e){ setStatus('✗ '+e.message,'err'); }
  });
  $('rom').addEventListener('input', () => {
    try { $('num').value = fromRoman($('rom').value); setStatus('✓','ok'); } catch(e){ setStatus('✗ '+e.message,'err'); }
  });
  $('num').dispatchEvent(new Event('input'));
})();
</script>
