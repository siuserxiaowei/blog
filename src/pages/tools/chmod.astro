---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="Chmod 计算器" description="Linux 文件权限可视化计算,八进制 ↔ 字符" category="开发辅助" icon="🔓">
  <div class="tool-card">
    <table style="width: 100%; border-collapse: separate; border-spacing: 0 0.5rem;">
      <thead>
        <tr>
          <th></th>
          {['Read (r=4)','Write (w=2)','Execute (x=1)'].map(h => (
            <th class="text-xs uppercase tracking-wider px-3 py-2" style="color: var(--color-accent); font-family: var(--font-mono); text-align: center;">{h}</th>
          ))}
          <th class="text-xs uppercase tracking-wider px-3 py-2" style="color: var(--color-accent); font-family: var(--font-mono); text-align: center;">总和</th>
        </tr>
      </thead>
      <tbody>
        {['user','group','other'].map(role => (
          <tr>
            <td class="px-3 py-3 text-sm font-medium" style="color: var(--text); text-transform: capitalize;">{role}</td>
            {['r','w','x'].map(perm => (
              <td class="px-3 py-3 text-center" style="background: var(--bg); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
                <input type="checkbox" data-role={role} data-perm={perm} class="w-5 h-5 cursor-pointer perm" />
              </td>
            ))}
            <td class="px-3 py-3 text-center font-bold" style="background: var(--bg); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); color: var(--color-accent); font-family: var(--font-mono);" data-sum={role}>0</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="grid md:grid-cols-2 gap-3 mt-6">
      <div class="tool-meta-item">
        <div class="k">八进制</div>
        <div class="v" id="octal" style="font-size: 1.5rem; color: var(--color-accent);">000</div>
      </div>
      <div class="tool-meta-item">
        <div class="k">符号表示</div>
        <div class="v" id="symbolic" style="font-size: 1.5rem; color: var(--color-accent);">---------</div>
      </div>
    </div>

    <div class="mt-4">
      <label class="tool-label">命令</label>
      <code id="cmd" class="block p-4 rounded-lg cursor-pointer" style="background: var(--bg); border: 1px solid var(--border); font-family: var(--font-mono); color: var(--text); font-size: 1rem;">chmod 000 file</code>
    </div>

    <div class="mt-4">
      <label class="tool-label">从八进制反推</label>
      <input id="from-octal" class="tool-input" placeholder="755" maxlength="4" style="font-family: var(--font-mono); font-size: 1.2rem;" />
    </div>

    <div class="tool-toolbar mt-4">
      {[['644','文件 默认'],['755','可执行/目录'],['600','私密'],['700','私有目录'],['777','全部权限⚠']].map(([o,n])=>(
        <button class="tool-btn preset" data-octal={o}>{o} <span style="opacity:0.6;font-size:0.7rem;">{n}</span></button>
      ))}
    </div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  const vals = { r:4, w:2, x:1 };
  function update(){
    let octal = '';
    let sym = '';
    ['user','group','other'].forEach(role => {
      let sum = 0;
      ['r','w','x'].forEach(perm => {
        const chk = document.querySelector(`[data-role="${role}"][data-perm="${perm}"]`).checked;
        sum += chk ? vals[perm] : 0;
        sym += chk ? perm : '-';
      });
      document.querySelector(`[data-sum="${role}"]`).textContent = sum;
      octal += sum;
    });
    $('octal').textContent = octal;
    $('symbolic').textContent = sym;
    $('cmd').textContent = `chmod ${octal} file`;
  }
  document.querySelectorAll('.perm').forEach(c => c.onchange = update);
  $('cmd').onclick = () => window.toolCopy($('cmd').textContent);

  function setOctal(o){
    o = String(o).padStart(3,'0').slice(-3);
    ['user','group','other'].forEach((role,i) => {
      const v = parseInt(o[i]) || 0;
      ['r','w','x'].forEach(perm => {
        document.querySelector(`[data-role="${role}"][data-perm="${perm}"]`).checked = !!(v & vals[perm]);
      });
    });
    update();
  }
  $('from-octal').addEventListener('input', e => setOctal(e.target.value));
  document.querySelectorAll('.preset').forEach(b => b.onclick = () => setOctal(b.dataset.octal));
  update();
})();
</script>
