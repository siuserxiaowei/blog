---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="HTTP 状态码" description="HTTP 状态码完整速查表,带分类与中英文说明" category="网络工具" icon="🚦">
  <div class="tool-card mb-6">
    <label class="tool-label">搜索</label>
    <input id="q" class="tool-input" placeholder="输入数字或关键词,如 404 / Not Found / 重定向" />
  </div>

  <div id="groups"></div>
</ToolLayout>

<script is:inline>
(function(){
  const codes = [
    [100,'Continue','继续','客户端应继续请求'],
    [101,'Switching Protocols','切换协议','服务器同意切换协议'],
    [102,'Processing','处理中','服务器正在处理请求'],
    [200,'OK','成功','请求成功'],
    [201,'Created','已创建','已创建新资源'],
    [202,'Accepted','已接受','请求已接受但未处理'],
    [204,'No Content','无内容','成功但无返回内容'],
    [206,'Partial Content','部分内容','成功处理部分 GET 请求'],
    [301,'Moved Permanently','永久重定向','资源已永久迁移'],
    [302,'Found','临时重定向','资源临时位于其他 URI'],
    [304,'Not Modified','未修改','缓存仍可使用'],
    [307,'Temporary Redirect','临时重定向','保持原方法的临时重定向'],
    [308,'Permanent Redirect','永久重定向','保持原方法的永久重定向'],
    [400,'Bad Request','请求错误','客户端请求语法错误'],
    [401,'Unauthorized','未授权','需要身份验证'],
    [402,'Payment Required','需要付款','保留状态码'],
    [403,'Forbidden','禁止访问','服务器拒绝执行请求'],
    [404,'Not Found','未找到','资源不存在'],
    [405,'Method Not Allowed','方法不允许','请求方法不被资源支持'],
    [406,'Not Acceptable','无法接受','服务器无法满足 Accept 头'],
    [408,'Request Timeout','请求超时','客户端超时'],
    [409,'Conflict','冲突','请求与服务器状态冲突'],
    [410,'Gone','已永久删除','资源已被永久删除'],
    [413,'Payload Too Large','请求体过大','请求实体过大'],
    [414,'URI Too Long','URI 过长','URI 超出服务器处理能力'],
    [415,'Unsupported Media Type','媒体类型不支持','服务器不支持该媒体类型'],
    [418,'I\'m a teapot','我是茶壶','复活节彩蛋,RFC 2324'],
    [422,'Unprocessable Entity','实体无法处理','语法正确但语义错误'],
    [429,'Too Many Requests','请求过多','触发限流'],
    [451,'Unavailable For Legal Reasons','因法律原因不可用','法律原因导致无法访问'],
    [500,'Internal Server Error','服务器错误','服务器发生未知错误'],
    [501,'Not Implemented','未实现','服务器不支持请求功能'],
    [502,'Bad Gateway','网关错误','上游服务器响应无效'],
    [503,'Service Unavailable','服务不可用','服务器临时无法处理请求'],
    [504,'Gateway Timeout','网关超时','上游服务器超时'],
    [505,'HTTP Version Not Supported','HTTP 版本不支持','服务器不支持请求的 HTTP 版本']
  ];
  const groupMeta = {
    1: ['1xx Informational','信息响应', '#60a5fa'],
    2: ['2xx Success','成功响应', '#4ade80'],
    3: ['3xx Redirection','重定向', '#fbbf24'],
    4: ['4xx Client Error','客户端错误', '#fb923c'],
    5: ['5xx Server Error','服务端错误', '#f87171']
  };

  function render(filter=''){
    filter = filter.trim().toLowerCase();
    const wrap = document.getElementById('groups'); wrap.innerHTML = '';
    [1,2,3,4,5].forEach(g => {
      const list = codes.filter(c => Math.floor(c[0]/100)===g)
        .filter(c => !filter || String(c[0]).includes(filter) || c[1].toLowerCase().includes(filter) || c[2].includes(filter));
      if (!list.length) return;
      const meta = groupMeta[g];
      const block = document.createElement('div');
      block.className = 'tool-card mb-6';
      block.innerHTML = `<div class="flex items-center gap-3 mb-4"><span class="w-1 h-5 rounded-full" style="background:${meta[2]};"></span><h3 class="text-base font-semibold" style="color:${meta[2]};">${meta[0]} · ${meta[1]}</h3><span class="text-xs" style="color:var(--text-secondary);font-family:var(--font-mono);">${list.length}</span></div>`;
      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-1 md:grid-cols-2 gap-2';
      list.forEach(c => {
        const card = document.createElement('div');
        card.className = 'p-3 rounded-lg cursor-pointer';
        card.style.cssText = `background: var(--bg); border: 1px solid var(--border);`;
        card.onmouseover = () => card.style.borderColor = meta[2];
        card.onmouseout = () => card.style.borderColor = 'var(--border)';
        card.onclick = () => window.toolCopy(`${c[0]} ${c[1]}`);
        card.innerHTML = `<div class="flex items-baseline gap-3 mb-1"><span class="text-2xl font-bold" style="color:${meta[2]};font-family:var(--font-mono);">${c[0]}</span><span class="text-sm" style="color:var(--text);">${c[1]}</span></div><p class="text-xs leading-relaxed" style="color:var(--text-secondary);">${c[2]} · ${c[3]}</p>`;
        grid.appendChild(card);
      });
      block.appendChild(grid);
      wrap.appendChild(block);
    });
  }

  document.getElementById('q').addEventListener('input', e => render(e.target.value));
  render();
})();
</script>
