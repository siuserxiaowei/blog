---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="Cron 表达式" description="解析 Cron 表达式并预测未来 10 次执行时间" category="时间日期" icon="⏰">
  <div class="tool-card mb-6">
    <label class="tool-label">表达式（5 段:分 时 日 月 周）</label>
    <input id="cron" class="tool-input" value="*/5 9-18 * * 1-5" placeholder="例如: */5 9-18 * * 1-5" />
    <div class="tool-toolbar mt-3">
      {[
        ['每分钟','* * * * *'],
        ['每 5 分钟','*/5 * * * *'],
        ['每小时','0 * * * *'],
        ['每天 9 点','0 9 * * *'],
        ['工作日 9 点','0 9 * * 1-5'],
        ['每月 1 号','0 0 1 * *'],
        ['每周一','0 0 * * 1']
      ].map(([n,v]) => (
        <button class="tool-btn preset" data-cron={v}>{n}</button>
      ))}
    </div>
    <div class="tool-status" id="status"><span class="dot"></span><span class="msg">输入表达式后解析</span></div>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <div class="tool-card">
      <label class="tool-label">人类可读说明</label>
      <p id="desc" class="text-base mt-2" style="color: var(--color-accent); font-family: var(--font-mono);">—</p>
      <div class="grid grid-cols-5 gap-2 mt-4">
        <div class="text-center"><div class="text-[10px] uppercase tracking-wider mb-1" style="color: var(--text-secondary); font-family: var(--font-mono);">分</div><div class="text-sm" id="seg-0" style="color: var(--text); font-family: var(--font-mono);">—</div></div>
        <div class="text-center"><div class="text-[10px] uppercase tracking-wider mb-1" style="color: var(--text-secondary); font-family: var(--font-mono);">时</div><div class="text-sm" id="seg-1" style="color: var(--text); font-family: var(--font-mono);">—</div></div>
        <div class="text-center"><div class="text-[10px] uppercase tracking-wider mb-1" style="color: var(--text-secondary); font-family: var(--font-mono);">日</div><div class="text-sm" id="seg-2" style="color: var(--text); font-family: var(--font-mono);">—</div></div>
        <div class="text-center"><div class="text-[10px] uppercase tracking-wider mb-1" style="color: var(--text-secondary); font-family: var(--font-mono);">月</div><div class="text-sm" id="seg-3" style="color: var(--text); font-family: var(--font-mono);">—</div></div>
        <div class="text-center"><div class="text-[10px] uppercase tracking-wider mb-1" style="color: var(--text-secondary); font-family: var(--font-mono);">周</div><div class="text-sm" id="seg-4" style="color: var(--text); font-family: var(--font-mono);">—</div></div>
      </div>
    </div>
    <div class="tool-card">
      <label class="tool-label">未来 10 次执行</label>
      <pre class="tool-output" id="next" style="min-height: 200px;">—</pre>
    </div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  const status = $('status'), msg = status.querySelector('.msg');
  const setStatus = (t,k) => { msg.textContent = t; status.classList.remove('is-ok','is-err'); if(k) status.classList.add('is-'+k); };

  const ranges = [[0,59],[0,23],[1,31],[1,12],[0,6]];
  const labels = ['分钟','小时','日','月','星期'];

  function expand(seg, [lo, hi]){
    if (seg === '*') return Array.from({length: hi-lo+1}, (_,i)=>i+lo);
    let out = new Set();
    seg.split(',').forEach(part => {
      let step = 1, range = part;
      if (part.includes('/')){ [range, step] = part.split('/'); step = parseInt(step); }
      let from = lo, to = hi;
      if (range !== '*'){
        if (range.includes('-')){ const [a,b]=range.split('-').map(Number); from=a; to=b; }
        else { from=to=Number(range); }
      }
      for (let i=from; i<=to; i+=step) out.add(i);
    });
    return [...out].filter(n=>n>=lo&&n<=hi).sort((a,b)=>a-b);
  }

  function describe(seg, idx){
    const lbl = labels[idx];
    if (seg === '*') return `每${lbl}`;
    if (seg.startsWith('*/')) return `每 ${seg.slice(2)} ${lbl}`;
    if (/^\d+$/.test(seg)) return `${lbl} = ${seg}`;
    if (seg.includes('-')) return `${lbl} ${seg}`;
    return `${lbl} ${seg}`;
  }

  function nextRuns(parts, n){
    const sets = parts.map((s,i)=>new Set(expand(s, ranges[i])));
    const out = [];
    let d = new Date(); d.setSeconds(0); d.setMilliseconds(0); d.setMinutes(d.getMinutes()+1);
    let safety = 0;
    while (out.length < n && safety++ < 366*24*60){
      const ok = sets[0].has(d.getMinutes()) && sets[1].has(d.getHours())
        && sets[2].has(d.getDate()) && sets[3].has(d.getMonth()+1)
        && sets[4].has(d.getDay());
      if (ok) out.push(new Date(d));
      d.setMinutes(d.getMinutes()+1);
    }
    return out;
  }

  function parse(){
    const v = $('cron').value.trim();
    const parts = v.split(/\s+/);
    if (parts.length !== 5) { setStatus('✗ 应为 5 段(分 时 日 月 周)','err'); return; }
    try {
      parts.forEach((p,i)=>expand(p, ranges[i]));
      parts.forEach((p,i)=>$('seg-'+i).textContent = p);
      $('desc').textContent = parts.map((p,i)=>describe(p,i)).join(' · ');
      const next = nextRuns(parts, 10);
      $('next').textContent = next.map((d,i)=>{
        const diff = ((d.getTime()-Date.now())/1000);
        const rel = diff < 60 ? `${Math.floor(diff)} 秒后` : diff < 3600 ? `${Math.floor(diff/60)} 分钟后` : diff < 86400 ? `${Math.floor(diff/3600)} 小时后` : `${Math.floor(diff/86400)} 天后`;
        return `${String(i+1).padStart(2,' ')}. ${d.toLocaleString('zh-CN',{hour12:false})}  (${rel})`;
      }).join('\n');
      setStatus('✓ 表达式有效','ok');
    } catch(e){ setStatus('✗ '+e.message,'err'); }
  }

  $('cron').addEventListener('input', parse);
  document.querySelectorAll('.preset').forEach(b => b.onclick = () => { $('cron').value = b.dataset.cron; parse(); });
  parse();
})();
</script>
