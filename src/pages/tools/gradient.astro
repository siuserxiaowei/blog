---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="渐变生成" description="可视化生成 CSS 线性 / 径向 / 锥形渐变" category="颜色图像" icon="🌈">
  <div class="tool-card">
    <div class="grid md:grid-cols-3 gap-3 mb-3">
      <div>
        <label class="tool-label">类型</label>
        <select id="type" class="tool-select">
          <option value="linear">linear-gradient</option>
          <option value="radial">radial-gradient</option>
          <option value="conic">conic-gradient</option>
        </select>
      </div>
      <div id="angle-wrap">
        <label class="tool-label">角度: <span id="angle-v" style="color: var(--color-accent);">135</span>°</label>
        <input id="angle" type="range" min="0" max="360" value="135" class="w-full" />
      </div>
      <div>
        <label class="tool-label">操作</label>
        <button class="tool-btn tool-btn-primary w-full" id="btn-add">+ 加色块</button>
      </div>
    </div>

    <label class="tool-label">色块（拖动滑块改变位置）</label>
    <div id="stops" class="space-y-2 mb-4"></div>

    <div id="preview" style="height: 300px; border-radius: 16px; border: 1px solid var(--border);"></div>

    <label class="tool-label mt-4">CSS 代码</label>
    <pre id="code" class="tool-output" style="min-height: 80px;"></pre>
    <div class="tool-toolbar mt-2"><button class="tool-btn tool-btn-primary" id="btn-copy">复制 CSS</button></div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  let stops = [
    { color: '#c9a96e', pos: 0 },
    { color: '#1a1a1e', pos: 100 }
  ];

  function render(){
    const wrap = $('stops'); wrap.innerHTML = '';
    stops.forEach((s, i) => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 p-2 rounded-lg';
      row.style.cssText = 'background: var(--bg); border: 1px solid var(--border);';
      row.innerHTML = `<input type="color" value="${s.color}" data-i="${i}" data-k="color" style="width: 40px; height: 32px; border: none; background: transparent; padding: 0; cursor: pointer;" /><input type="range" min="0" max="100" value="${s.pos}" data-i="${i}" data-k="pos" class="flex-1" /><span style="font-family: var(--font-mono); color: var(--text-secondary); min-width: 48px; text-align: right;">${s.pos}%</span><button data-i="${i}" data-k="del" class="text-sm" style="color: #f87171; cursor: pointer; background: transparent; border: none;">×</button>`;
      wrap.appendChild(row);
    });
    wrap.querySelectorAll('input,button').forEach(el => {
      el.oninput = el.onclick = e => {
        const i = +el.dataset.i, k = el.dataset.k;
        if (k === 'del') stops.splice(i, 1);
        else if (k === 'pos') stops[i].pos = +el.value;
        else stops[i].color = el.value;
        update();
      };
    });
    update();
  }

  function update(){
    $('angle-wrap').style.display = $('type').value === 'radial' ? 'none' : '';
    $('angle-v').textContent = $('angle').value;
    const t = $('type').value;
    const sorted = [...stops].sort((a,b)=>a.pos-b.pos);
    const colorList = sorted.map(s => `${s.color} ${s.pos}%`).join(', ');
    let css;
    if (t === 'linear') css = `linear-gradient(${$('angle').value}deg, ${colorList})`;
    else if (t === 'radial') css = `radial-gradient(circle, ${colorList})`;
    else css = `conic-gradient(from ${$('angle').value}deg, ${colorList})`;
    $('preview').style.background = css;
    $('code').textContent = `background: ${css};`;
    render._render = false;
    if (render._needRefresh){
      render._needRefresh = false;
      render();
    }
  }

  $('btn-add').onclick = () => { stops.push({ color:'#'+Math.floor(Math.random()*0xffffff).toString(16).padStart(6,'0'), pos: 50 }); render(); };
  $('btn-copy').onclick = () => window.toolCopy($('code').textContent);
  $('type').onchange = update;
  $('angle').oninput = update;
  render();
})();
</script>
