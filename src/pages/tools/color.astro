---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="颜色转换" description="HEX / RGB / HSL / HSV / CMYK 互转,带浏览器取色 API" category="颜色图像" icon="🎨">
  <div class="tool-card mb-6">
    <div class="grid md:grid-cols-2 gap-6 items-center">
      <div>
        <input id="picker" type="color" value="#c9a96e" style="width: 100%; height: 200px; border: 1px solid var(--border); border-radius: 12px; cursor: pointer; background: transparent;" />
        <div class="tool-toolbar mt-3">
          <button class="tool-btn" id="btn-eyedropper">🎯 屏幕取色</button>
          <button class="tool-btn" id="btn-random">🎲 随机</button>
        </div>
      </div>
      <div class="space-y-3" id="formats"></div>
    </div>
  </div>

  <div class="tool-card">
    <label class="tool-label">配色方案</label>
    <div class="grid grid-cols-5 gap-2 mt-3" id="palette"></div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  const picker = $('picker');

  function hex2rgb(h){ h = h.replace('#',''); return [parseInt(h.slice(0,2),16), parseInt(h.slice(2,4),16), parseInt(h.slice(4,6),16)]; }
  function rgb2hex(r,g,b){ return '#'+[r,g,b].map(x=>Math.round(x).toString(16).padStart(2,'0')).join(''); }
  function rgb2hsl(r,g,b){
    r/=255; g/=255; b/=255;
    const mx=Math.max(r,g,b), mn=Math.min(r,g,b);
    let h, s, l=(mx+mn)/2;
    if (mx===mn) h=s=0;
    else {
      const d=mx-mn;
      s = l>0.5 ? d/(2-mx-mn) : d/(mx+mn);
      switch(mx){ case r: h=(g-b)/d+(g<b?6:0); break; case g: h=(b-r)/d+2; break; case b: h=(r-g)/d+4; }
      h*=60;
    }
    return [h,s*100,l*100];
  }
  function rgb2hsv(r,g,b){
    r/=255; g/=255; b/=255;
    const mx=Math.max(r,g,b), mn=Math.min(r,g,b), d=mx-mn;
    let h=0, s=mx===0?0:d/mx, v=mx;
    if (d){ switch(mx){ case r: h=(g-b)/d+(g<b?6:0); break; case g: h=(b-r)/d+2; break; case b: h=(r-g)/d+4; } h*=60; }
    return [h,s*100,v*100];
  }
  function rgb2cmyk(r,g,b){
    r/=255; g/=255; b/=255;
    const k = 1-Math.max(r,g,b);
    if (k===1) return [0,0,0,100];
    return [(1-r-k)/(1-k)*100, (1-g-k)/(1-k)*100, (1-b-k)/(1-k)*100, k*100];
  }

  function render(){
    const hex = picker.value;
    const [r,g,b] = hex2rgb(hex);
    const [h,s,l] = rgb2hsl(r,g,b);
    const [hv,sv,vv] = rgb2hsv(r,g,b);
    const [c,m,y,k] = rgb2cmyk(r,g,b);
    document.body.style.setProperty('--demo-color', hex);

    const formats = {
      'HEX': hex.toUpperCase(),
      'RGB': `rgb(${r}, ${g}, ${b})`,
      'RGBA': `rgba(${r}, ${g}, ${b}, 1)`,
      'HSL': `hsl(${Math.round(h)}, ${Math.round(s)}%, ${Math.round(l)}%)`,
      'HSV': `hsv(${Math.round(hv)}, ${Math.round(sv)}%, ${Math.round(vv)}%)`,
      'CMYK': `cmyk(${Math.round(c)}%, ${Math.round(m)}%, ${Math.round(y)}%, ${Math.round(k)}%)`
    };
    const wrap = $('formats'); wrap.innerHTML = '';
    Object.entries(formats).forEach(([k,v]) => {
      const d = document.createElement('div');
      d.className = 'flex items-center gap-3 p-3 rounded-lg cursor-pointer transition-all';
      d.style.cssText = 'background: var(--bg); border: 1px solid var(--border);';
      d.innerHTML = `<span class="text-xs font-bold w-14 shrink-0" style="color: var(--color-accent); font-family: var(--font-mono);">${k}</span><code class="flex-1 text-sm" style="color: var(--text); font-family: var(--font-mono);">${v}</code>`;
      d.onclick = () => window.toolCopy(v);
      wrap.appendChild(d);
    });

    // palette: 5 shades
    const pal = $('palette'); pal.innerHTML = '';
    for (let i=0;i<5;i++){
      const lt = 20 + i*15;
      const sh = `hsl(${Math.round(h)}, ${Math.round(s)}%, ${lt}%)`;
      const el = document.createElement('div');
      el.style.cssText = `background: ${sh}; height: 80px; border-radius: 8px; cursor: pointer; display: flex; align-items: end; padding: 0.5rem; color: white; font-family: var(--font-mono); font-size: 0.65rem; text-shadow: 0 1px 2px rgba(0,0,0,0.4);`;
      el.textContent = sh;
      el.onclick = () => window.toolCopy(sh);
      pal.appendChild(el);
    }
  }

  picker.oninput = render;
  $('btn-random').onclick = () => { picker.value = '#'+Math.floor(Math.random()*0xffffff).toString(16).padStart(6,'0'); render(); };
  $('btn-eyedropper').onclick = async () => {
    if (!('EyeDropper' in window)) { window.toolToast('浏览器不支持 EyeDropper API','err'); return; }
    try { const r = await new EyeDropper().open(); picker.value = r.sRGBHex; render(); } catch(e){}
  };
  render();
})();
</script>
