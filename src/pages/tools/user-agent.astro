---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="UA 解析" description="解析 User-Agent,识别浏览器、操作系统、设备" category="网络工具" icon="💻">
  <div class="tool-card">
    <div class="tool-toolbar">
      <button class="tool-btn tool-btn-primary" id="btn-parse">解析</button>
      <button class="tool-btn" id="btn-current">使用当前浏览器</button>
    </div>
    <textarea id="ua" class="tool-textarea mt-3" style="min-height: 100px;" placeholder="Mozilla/5.0..."></textarea>
    <div class="grid md:grid-cols-2 gap-3 mt-4" id="info"></div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);

  function parse(ua){
    const m = {};
    // Browser
    let browser = 'Unknown', version = '';
    if (/Edg\/(\S+)/.test(ua)) { browser='Edge'; version=RegExp.$1; }
    else if (/OPR\/(\S+)/.test(ua) || /Opera\/(\S+)/.test(ua)) { browser='Opera'; version=RegExp.$1; }
    else if (/Firefox\/(\S+)/.test(ua)) { browser='Firefox'; version=RegExp.$1; }
    else if (/Chrome\/(\S+)/.test(ua)) { browser='Chrome'; version=RegExp.$1; }
    else if (/Safari\/(\S+)/.test(ua) && /Version\/(\S+)/.test(ua)) { browser='Safari'; version=RegExp.$1; }
    else if (/MSIE (\S+);/.test(ua) || /Trident.*rv:(\S+)\)/.test(ua)) { browser='IE'; version=RegExp.$1; }
    m['浏览器'] = browser;
    m['浏览器版本'] = version || '—';

    // OS
    let os = 'Unknown';
    if (/Windows NT 10\.0/.test(ua)) os = 'Windows 10/11';
    else if (/Windows NT 6\.3/.test(ua)) os = 'Windows 8.1';
    else if (/Windows NT 6\.1/.test(ua)) os = 'Windows 7';
    else if (/Mac OS X (\S+)/.test(ua)) os = 'macOS ' + RegExp.$1.replace(/_/g,'.');
    else if (/Android (\S+)/.test(ua)) os = 'Android ' + RegExp.$1.replace(/;/,'');
    else if (/iPhone OS (\S+)/.test(ua) || /iPad.*OS (\S+)/.test(ua)) os = 'iOS ' + RegExp.$1.replace(/_/g,'.').replace(/;/,'');
    else if (/Linux/.test(ua)) os = 'Linux';
    m['操作系统'] = os;

    // Device
    let device = '桌面';
    if (/Mobile|Android|iPhone/.test(ua) && !/iPad|Tablet/.test(ua)) device = '手机';
    else if (/iPad|Tablet/.test(ua)) device = '平板';
    m['设备类型'] = device;

    // Engine
    let engine = 'Unknown';
    if (/Gecko\/[\d.]+/.test(ua)) engine = 'Gecko';
    else if (/AppleWebKit\/(\S+)/.test(ua)) engine = 'WebKit ' + RegExp.$1;
    else if (/Trident/.test(ua)) engine = 'Trident';
    m['渲染引擎'] = engine;

    // CPU
    if (/x64|x86_64/.test(ua)) m['架构'] = 'x86_64';
    else if (/arm64|aarch64/.test(ua)) m['架构'] = 'ARM64';
    else if (/i686/.test(ua)) m['架构'] = 'x86';
    else m['架构'] = '—';

    return m;
  }

  $('btn-parse').onclick = () => {
    const ua = $('ua').value.trim();
    if (!ua) return;
    const r = parse(ua);
    const wrap = $('info'); wrap.innerHTML = '';
    Object.entries(r).forEach(([k,v])=>{
      const d = document.createElement('div');
      d.className = 'tool-meta-item cursor-pointer';
      d.innerHTML = `<div class="k">${k}</div><div class="v">${v}</div>`;
      d.onclick = () => window.toolCopy(String(v));
      wrap.appendChild(d);
    });
  };
  $('btn-current').onclick = () => { $('ua').value = navigator.userAgent; $('btn-parse').click(); };
  $('btn-current').click();
})();
</script>
