---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout title="密码生成器" description="生成强密码,可控长度、字符集、排除易混淆字符" category="生成器" icon="🔑">
  <div class="tool-card mb-6">
    <div class="grid md:grid-cols-2 gap-4">
      <div>
        <label class="tool-label">长度: <span id="len-val" style="color: var(--color-accent);">20</span></label>
        <input id="len" type="range" min="6" max="64" value="20" class="w-full" />
      </div>
      <div>
        <label class="tool-label">数量</label>
        <input id="count" type="number" min="1" max="100" value="10" class="tool-input" />
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-4">
      <label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text);"><input type="checkbox" id="lower" checked /> 小写 a-z</label>
      <label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text);"><input type="checkbox" id="upper" checked /> 大写 A-Z</label>
      <label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text);"><input type="checkbox" id="digit" checked /> 数字 0-9</label>
      <label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text);"><input type="checkbox" id="sym" /> 符号 !@#</label>
      <label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text);"><input type="checkbox" id="exclude" checked /> 排除易混淆字符 0Ol1I</label>
    </div>
    <div class="tool-toolbar mt-4">
      <button class="tool-btn tool-btn-primary" id="btn-gen">生成密码</button>
      <button class="tool-btn tool-btn-ghost" id="btn-copy">复制全部</button>
    </div>
  </div>

  <div class="tool-card">
    <label class="tool-label">生成结果（点击单个复制）</label>
    <div id="results" class="space-y-2"></div>
  </div>
</ToolLayout>

<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  $('len').oninput = () => $('len-val').textContent = $('len').value;

  function gen(){
    const L = parseInt($('len').value);
    const N = Math.min(100, parseInt($('count').value)||1);
    let chars = '';
    if ($('lower').checked) chars += 'abcdefghijklmnopqrstuvwxyz';
    if ($('upper').checked) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    if ($('digit').checked) chars += '0123456789';
    if ($('sym').checked) chars += '!@#$%^&*()-_=+[]{};:,.<>?';
    if ($('exclude').checked) chars = chars.replace(/[0Ol1I]/g,'');
    if (!chars) { window.toolToast('至少勾选一种字符集','err'); return; }

    const arr = [];
    for (let i=0;i<N;i++){
      const r = crypto.getRandomValues(new Uint32Array(L));
      let s = '';
      for (let j=0;j<L;j++) s += chars[r[j] % chars.length];
      arr.push(s);
    }
    const wrap = $('results');
    wrap.innerHTML = '';
    arr.forEach(p => {
      const strength = p.length >= 16 ? '极强' : p.length >= 12 ? '强' : p.length >= 8 ? '中' : '弱';
      const color = p.length >= 16 ? '#4ade80' : p.length >= 12 ? '#a3e635' : p.length >= 8 ? '#fbbf24' : '#f87171';
      const div = document.createElement('div');
      div.className = 'flex items-center gap-3 p-3 rounded-lg cursor-pointer transition-all';
      div.style.cssText = 'background: var(--bg); border: 1px solid var(--border);';
      div.innerHTML = `<code class="flex-1 text-sm" style="font-family: var(--font-mono); color: var(--text);">${p}</code><span class="text-xs px-2 py-0.5 rounded-full" style="background: ${color}22; color: ${color}; font-family: var(--font-mono);">${strength}</span>`;
      div.onclick = () => window.toolCopy(p);
      wrap.appendChild(div);
    });
  }

  $('btn-gen').onclick = gen;
  $('btn-copy').onclick = () => {
    const texts = Array.from($('results').querySelectorAll('code')).map(c=>c.textContent).join('\n');
    if (texts) window.toolCopy(texts);
  };
  gen();
})();
</script>
