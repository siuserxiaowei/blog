---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, 3);
const totalPosts = allPosts.length;
const todayLabel = new Date().toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
}).toUpperCase();

const sections = [
  {
    title: '工具箱',
    eyebrow: 'Browser-first utilities',
    href: '/tools',
    desc: '把高频开发小需求都收进一个更快的工具目录里，直接打开就能用。',
    stat: '60+ tools'
  },
  {
    title: '项目展示',
    eyebrow: 'Products in progress',
    href: '/projects',
    desc: '集中展示我在做的 AI、自动化和个人产品，保持公开迭代。',
    stat: '4 active bets'
  },
  {
    title: '比赛雷达',
    eyebrow: 'Opportunity scanner',
    href: '/competitions',
    desc: '收集创业、黑客松和创新比赛的信息，降低搜集成本。',
    stat: 'Always updating'
  },
];
---

<BaseLayout>
  <Header />

  <main class="flex-1">
    <section id="home" class="home-hero mx-auto px-6 pt-32 pb-18 md:pt-40 md:pb-24" style="max-width: var(--container-max); scroll-margin-top: 7rem;">
      <div class="home-grid">
        <div class="scroll-reveal">
          <div class="hero-meta-row">
            <span class="hero-chip">Independent Dispatch</span>
            <span class="hero-date">{todayLabel}</span>
          </div>

          <h1 class="hero-title">
            做产品，写判断，<br />
            <span class="text-shimmer">把过程公开出来。</span>
          </h1>

          <p class="hero-copy">
            这里是我的个人网站，也是一个持续发布中的工作台。
            我关注 AI、自动化、产品工程和学习系统，把思考写成文章，把问题做成工具。
          </p>

          <div class="hero-actions">
            <a href="#blog" class="hero-btn hero-btn-primary btn-glow">看最新文章</a>
            <a href="/tools" class="hero-btn hero-btn-ghost">进入工具箱</a>
          </div>

          <div class="hero-stats">
            <div>
              <span class="k">Articles</span>
              <strong>{totalPosts}</strong>
            </div>
            <div>
              <span class="k">Focus</span>
              <strong>AI + Product</strong>
            </div>
            <div>
              <span class="k">Mode</span>
              <strong>Ship Weekly</strong>
            </div>
          </div>
        </div>

        <aside class="scroll-reveal hero-panel surface-card gradient-border">
          <div class="hero-panel-head">
            <p>Currently shipping</p>
            <span>live</span>
          </div>

          <div class="hero-panel-block">
            <h2>当前重点</h2>
            <ul>
              <li>把个人网站做成更像产品，而不是单纯博客。</li>
              <li>持续扩展浏览器内可用的开发工具箱。</li>
              <li>围绕 AI 语音与自动化做更明确的产品判断。</li>
            </ul>
          </div>

          <div class="hero-panel-block">
            <h3>Recent dispatches</h3>
            <div class="hero-dispatches">
              {posts.map((post) => (
                <a href={`/blog/${post.id}`} class="hero-dispatch">
                  <span>{post.data.title}</span>
                  <em>{post.data.date.toLocaleDateString('zh-CN', { month: 'numeric', day: 'numeric' })}</em>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section id="about" class="mx-auto px-6 py-20 md:py-24" style="max-width: var(--container-max); scroll-margin-top: 7rem;">
      <div class="section-head scroll-reveal">
        <p class="section-kicker">About</p>
        <h2>我希望这个网站看起来像我做事的方式。</h2>
      </div>

      <div class="about-grid">
        <div class="scroll-reveal about-copy">
          <p>
            我不太想把这里做成标准模板式个人主页。相比“展示简历”，我更在意把正在发生的东西放上来：
            现在在研究什么、正在做什么产品、哪些判断成立、哪些尝试应该放弃。
          </p>
          <p>
            所以这个站会同时是三种东西：一个写作空间、一个工具目录、一个正在成形的产品工作台。
            它应该清晰、克制、有一点编辑感，也要足够像一个真正会持续更新的系统。
          </p>
        </div>

        <div class="about-principles">
          <div class="scroll-reveal glass-card spotlight principle-card">
            <span>01</span>
            <h3>先有判断，再有实现</h3>
            <p>先想清楚为什么做，再决定怎么做。</p>
          </div>
          <div class="scroll-reveal glass-card spotlight principle-card">
            <span>02</span>
            <h3>公开迭代</h3>
            <p>把过程写出来，网站本身也成为作品的一部分。</p>
          </div>
          <div class="scroll-reveal glass-card spotlight principle-card">
            <span>03</span>
            <h3>用工具减掉重复劳动</h3>
            <p>把高频小需求积累成真正能复用的系统。</p>
          </div>
          <div class="scroll-reveal glass-card spotlight principle-card">
            <span>04</span>
            <h3>长期主义但不拖延</h3>
            <p>方向看长期，执行看每一周有没有新东西上线。</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto px-6 py-10 md:py-12" style="max-width: var(--container-max);">
      <div class="section-head scroll-reveal">
        <p class="section-kicker">Entry Points</p>
        <h2>把内容、工具和项目分得更清楚。</h2>
      </div>

      <div class="entry-grid">
        {sections.map((section, index) => (
          <a href={section.href} class="scroll-reveal surface-card card-hover gradient-border entry-card">
            <span class="entry-index">{String(index + 1).padStart(2, '0')}</span>
            <p class="entry-kicker">{section.eyebrow}</p>
            <h3>{section.title}</h3>
            <p class="entry-copy">{section.desc}</p>
            <div class="entry-footer">
              <span>{section.stat}</span>
              <span>进入 ↗</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section id="blog" class="mx-auto px-6 py-20 md:py-24" style="max-width: var(--container-max); scroll-margin-top: 7rem;">
      <div class="section-row scroll-reveal">
        <div class="section-head">
          <p class="section-kicker">Writing</p>
          <h2>最近写下来的东西。</h2>
        </div>
        <a href="/blog" class="section-link">全部文章 ↗</a>
      </div>

      <div class="blog-list">
        {posts.map((post) => (
          <div class="scroll-reveal">
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date.toISOString()}
              tags={post.data.tags}
              slug={post.id}
              image={post.data.image}
            />
          </div>
        ))}
      </div>
    </section>

    <section id="contact" class="mx-auto px-6 py-18 md:py-22" style="max-width: var(--container-max); scroll-margin-top: 7rem;">
      <div class="contact-grid">
        <div class="scroll-reveal">
          <Newsletter />
        </div>

        <div class="scroll-reveal surface-card gradient-border contact-card">
          <p class="section-kicker">Contact</p>
          <h2>保持联系，或者直接来聊合作。</h2>
          <p class="contact-copy">
            如果你喜欢我在做的方向，或者你也在做 AI、自动化、内容产品这类东西，欢迎直接联系我。
          </p>

          <div class="contact-links">
            <a href="https://github.com/siuserxiaowei" target="_blank" rel="noopener">
              <span>GitHub</span>
              <em>@siuserxiaowei</em>
            </a>
            <a href="mailto:hi@siuserxiaowei.com">
              <span>Email</span>
              <em>hi@siuserxiaowei.com</em>
            </a>
            <a href="/rss.xml">
              <span>RSS</span>
              <em>订阅更新</em>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(340px, 0.85fr);
    gap: 2rem;
    align-items: end;
  }

  .hero-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .hero-chip,
  .hero-date,
  .section-kicker,
  .entry-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .hero-chip,
  .section-kicker {
    color: var(--color-accent);
  }

  .hero-date {
    color: var(--text-secondary);
  }

  .hero-title {
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.9;
    margin-bottom: 1.3rem;
  }

  .hero-copy {
    max-width: 42rem;
    color: var(--text-secondary);
    font-size: clamp(1rem, 1.55vw, 1.22rem);
    line-height: 1.85;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.6rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    border-radius: 999px;
    padding: 0 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .hero-btn-primary {
    background: linear-gradient(135deg, var(--color-accent), color-mix(in srgb, var(--color-accent) 70%, white 30%));
    color: #111;
  }

  .hero-btn-ghost {
    border: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    background: color-mix(in srgb, var(--surface) 78%, transparent);
    color: var(--text);
  }

  .hero-btn:hover {
    transform: translateY(-1px);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1.8rem;
  }

  .hero-stats > div,
  .principle-card,
  .entry-card,
  .contact-card {
    border-radius: 24px;
    border: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
    background: color-mix(in srgb, var(--surface) 78%, transparent);
  }

  .hero-stats > div {
    padding: 1rem;
  }

  .hero-stats .k {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-stats strong {
    font-size: 1.02rem;
  }

  .hero-panel {
    padding: 1.35rem;
    border-radius: 28px;
  }

  .hero-panel-head,
  .entry-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-panel-head span {
    border-radius: 999px;
    padding: 0.28rem 0.55rem;
    color: var(--text);
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .hero-panel-block + .hero-panel-block {
    margin-top: 1.25rem;
    padding-top: 1.1rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
  }

  .hero-panel-block h2,
  .hero-panel-block h3 {
    margin-bottom: 0.7rem;
    font-size: 1.8rem;
  }

  .hero-panel-block ul {
    margin: 0;
    padding-left: 1.05rem;
    color: var(--text-secondary);
  }

  .hero-panel-block li + li {
    margin-top: 0.55rem;
  }

  .hero-dispatches {
    display: grid;
    gap: 0.55rem;
  }

  .hero-dispatch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0.95rem;
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
  }

  .hero-dispatch span {
    color: var(--text);
    line-height: 1.4;
  }

  .hero-dispatch em {
    color: var(--text-secondary);
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .section-head h2,
  .contact-card h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 0.98;
    margin-top: 0.35rem;
  }

  .section-row {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-link {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .about-grid,
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 1.35rem;
    margin-top: 1.5rem;
  }

  .about-copy {
    display: grid;
    gap: 1rem;
    color: var(--text-secondary);
    font-size: 1.02rem;
    line-height: 1.9;
  }

  .about-principles {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .principle-card,
  .entry-card,
  .contact-card {
    padding: 1.15rem;
  }

  .principle-card span,
  .entry-index {
    display: inline-block;
    margin-bottom: 0.8rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .principle-card h3,
  .entry-card h3 {
    margin-bottom: 0.55rem;
    font-size: 1.6rem;
  }

  .principle-card p,
  .entry-copy,
  .contact-copy {
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .entry-card {
    display: block;
  }

  .entry-footer {
    margin-top: 1.2rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
  }

  .blog-list {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-links {
    display: grid;
    gap: 0.7rem;
    margin-top: 1.3rem;
  }

  .contact-links a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
  }

  .contact-links span {
    color: var(--text);
  }

  .contact-links em {
    color: var(--text-secondary);
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  @media (max-width: 1024px) {
    .home-grid,
    .about-grid,
    .contact-grid,
    .entry-grid {
      grid-template-columns: 1fr;
    }

    .about-principles {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .hero-title {
      font-size: 3.2rem;
    }

    .hero-stats,
    .about-principles {
      grid-template-columns: 1fr;
    }

    .section-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-dispatch {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

<script is:inline>
  (() => {
    const revealElements = document.querySelectorAll('.scroll-reveal');
    if (!revealElements.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });

    revealElements.forEach((element) => observer.observe(element));

    document.querySelectorAll('.spotlight').forEach((element) => {
      element.addEventListener('mousemove', (event) => {
        const rect = element.getBoundingClientRect();
        element.style.setProperty('--spot-x', `${event.clientX - rect.left - 140}px`);
        element.style.setProperty('--spot-y', `${event.clientY - rect.top - 140}px`);
      });
    });
  })();
</script>
