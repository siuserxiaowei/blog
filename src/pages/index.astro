---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, 3);
const totalPosts = allPosts.length;

const lanes = [
  {
    label: 'Write',
    title: '把判断写成公开日志',
    desc: '文章不是装饰，而是把真实的产品判断、实验过程和学习路径记录下来。',
    meta: `${totalPosts} 篇已发布`,
    href: '/blog'
  },
  {
    label: 'Build',
    title: '把重复问题做成工具',
    desc: '工具页承担的是效率任务。高频动作直接固定成浏览器内可用的小产品。',
    meta: '60+ 工具在线',
    href: '/tools'
  },
  {
    label: 'Ship',
    title: '让项目和比赛形成外部约束',
    desc: '项目展示和比赛雷达不是补充页面，而是推动更新频率和判断密度的外部机制。',
    meta: '持续公开迭代',
    href: '/projects'
  }
];
---

<BaseLayout>
  <Header />

  <main class="flex-1">

    <!-- ===== Hero ===== -->
    <section id="home" class="container hero-section">
      <div class="hero-inner">
        <p class="animate-fade-in stagger-1 section-kicker">Independent Workbench · 2026</p>

        <h1 class="animate-fade-in stagger-2 hero-title display-serif">
          这里不是个人<em>简历</em>，<br />
          而是一个持续<em>运行</em>的工作台。
        </h1>

        <p class="animate-fade-in stagger-3 hero-lede">
          我把 AI、自动化、产品工程和学习系统相关的工作公开发布出来。<br class="hide-mobile" />
          一部分写成文章，一部分做成工具，一部分继续推进成项目。
        </p>

        <div class="animate-fade-in stagger-4 hero-actions">
          <a href="#blog" class="btn-primary">看最新文章 →</a>
          <a href="/tools" class="btn-ghost">进入工具箱</a>
        </div>
      </div>

      <div class="divider-accent hero-divider"></div>
    </section>

    <!-- ===== Operating model ===== -->
    <section id="about" class="container model-section">
      <div class="model-head">
        <p class="section-kicker">Operating Model</p>
        <h2 class="display-serif model-heading">
          三件事撑起这个站：<em>写</em>、<em>做</em>、<em>交付</em>。
        </h2>
      </div>

      <div class="lanes">
        {lanes.map((lane, i) => (
          <a href={lane.href} class="lane scroll-reveal">
            <div class="lane-head">
              <span class="lane-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="lane-label">{lane.label}</span>
            </div>
            <h3 class="lane-title display-serif">{lane.title}</h3>
            <p class="lane-desc">{lane.desc}</p>
            <div class="lane-foot">
              <span>{lane.meta}</span>
              <span class="lane-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ===== Writing ===== -->
    <section id="blog" class="container blog-section">
      <div class="blog-head">
        <p class="section-kicker">Writing</p>
        <h2 class="display-serif model-heading">最近写下来的判断和实验。</h2>
        <a href="/blog" class="blog-head-link">全部文章 →</a>
      </div>

      <div class="blog-list">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString()}
            tags={post.data.tags}
            slug={post.id}
            image={post.data.image}
          />
        ))}
      </div>
    </section>

    <!-- ===== Contact ===== -->
    <section id="contact" class="container contact-section">
      <div class="contact-inner">
        <div>
          <p class="section-kicker">Contact</p>
          <h2 class="display-serif model-heading contact-h2">
            做类似方向的，<em>直接找我</em>。
          </h2>
          <p class="contact-copy">
            AI、自动化、内容产品、学习工具这些方向都可以聊。这里希望结识一起做东西的人，<br class="hide-mobile" />
            而不只是交换名片。
          </p>
        </div>

        <ul class="contact-links">
          <li>
            <a href="https://github.com/siuserxiaowei" target="_blank" rel="noopener">
              <span>GitHub</span>
              <em>@siuserxiaowei</em>
            </a>
          </li>
          <li>
            <a href="mailto:hi@siuserxiaowei.com">
              <span>Email</span>
              <em>hi@siuserxiaowei.com</em>
            </a>
          </li>
          <li>
            <a href="/rss.xml">
              <span>RSS</span>
              <em>订阅更新</em>
            </a>
          </li>
        </ul>
      </div>

      <div class="newsletter-slot">
        <Newsletter />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .hide-mobile { display: inline; }
  @media (max-width: 780px) { .hide-mobile { display: none; } }

  /* ===== Buttons ===== */
  .btn-primary,
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    height: 2.75rem;
    padding: 0 1.2rem;
    border-radius: var(--radius-sm);
    font-size: 0.92rem;
    font-weight: 500;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-accent-ink);
    border: 1px solid var(--color-accent);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--color-accent-ink);
  }

  .btn-ghost {
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--text);
  }

  .btn-ghost:hover {
    border-color: var(--text);
    color: var(--text);
  }

  /* ===== Hero ===== */
  .hero-section {
    padding-top: 7rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 54rem;
  }

  .hero-title {
    margin-top: 1.5rem;
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
  }

  .hero-title em {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-lede {
    max-width: 42rem;
    margin-top: 1.75rem;
    color: var(--text-secondary);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.85;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .hero-divider {
    margin-top: 4.5rem;
  }

  @media (max-width: 780px) {
    .hero-section { padding-top: 5rem; padding-bottom: 3rem; }
    .hero-title { font-size: clamp(2.2rem, 9vw, 3.2rem); }
  }

  /* ===== Sections ===== */
  .model-section,
  .blog-section,
  .contact-section {
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  .model-head,
  .blog-head {
    max-width: 48rem;
    margin-bottom: 3rem;
  }

  .model-heading {
    margin-top: 0.8rem;
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
  }

  .model-heading em {
    color: var(--color-accent);
    font-style: italic;
  }

  /* ===== Lanes (Operating Model) ===== */
  .lanes {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--border);
  }

  .lane {
    display: grid;
    grid-template-columns: minmax(8rem, 10rem) minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: start;
    padding: 2.2rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    transition: background 0.15s ease;
  }

  .lane:hover {
    background: color-mix(in srgb, var(--surface) 60%, transparent);
    color: var(--text);
  }

  .lane-head {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .lane-index {
    font-family: var(--font-heading);
    font-size: 2.6rem;
    line-height: 1;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }

  .lane-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .lane-title {
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    line-height: 1.15;
    margin-bottom: 0.6rem;
  }

  .lane:hover .lane-title {
    color: var(--color-accent);
  }

  .lane-desc {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 0.98rem;
  }

  .lane-foot {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: flex-end;
    text-align: right;
    min-width: 8rem;
  }

  .lane-foot > span:first-child {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .lane-arrow {
    color: var(--color-accent);
    font-size: 1.15rem;
    transition: transform 0.2s ease;
  }

  .lane:hover .lane-arrow { transform: translateX(4px); }

  @media (max-width: 780px) {
    .lane {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      padding: 1.7rem 0;
    }
    .lane-index { font-size: 2rem; }
    .lane-foot { align-items: flex-start; text-align: left; }
  }

  /* ===== Blog ===== */
  .blog-head {
    position: relative;
  }

  .blog-head-link {
    position: absolute;
    right: 0;
    bottom: 0.3rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .blog-list {
    border-top: 1px solid var(--border);
  }

  @media (max-width: 680px) {
    .blog-head-link {
      position: static;
      margin-top: 1rem;
      display: inline-block;
    }
  }

  /* ===== Contact ===== */
  .contact-section {
    padding-bottom: 5rem;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: 3rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .contact-h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    margin-bottom: 1.3rem;
  }

  .contact-copy {
    max-width: 40rem;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  .contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--border);
  }

  .contact-links li {
    border-bottom: 1px solid var(--border);
  }

  .contact-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0.25rem;
    color: var(--text);
    transition: color 0.15s ease, padding 0.15s ease;
  }

  .contact-links a:hover {
    color: var(--color-accent);
    padding-left: 0.75rem;
  }

  .contact-links a span {
    font-family: var(--font-heading);
    font-size: 1.1rem;
  }

  .contact-links a em {
    font-style: normal;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
  }

  .newsletter-slot {
    margin-top: 1rem;
  }

  @media (max-width: 860px) {
    .contact-inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script is:inline>
  (() => {
    const revealElements = document.querySelectorAll('.scroll-reveal');
    if (!revealElements.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });

    revealElements.forEach((element) => observer.observe(element));
  })();
</script>
