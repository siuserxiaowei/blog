---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, 4);
const totalPosts = allPosts.length;
const totalTags = new Set(allPosts.flatMap((post) => post.data.tags || [])).size;

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' });
}

const quickEntries = [
  {
    label: 'Tools',
    title: '工具箱',
    desc: '格式化、编码转换、时间戳、图片处理等高频小工具。',
    href: '/tools',
    meta: '60+ utilities',
    shortcut: '01',
    keywords: ['工具', 'tool', 'utilities', 'json', 'timestamp', 'image']
  },
  {
    label: 'Writing',
    title: '文章库',
    desc: '产品判断、AI 实验、公开构建过程和学习笔记。',
    href: '/blog',
    meta: `${totalPosts} posts`,
    shortcut: '02',
    keywords: ['文章', 'blog', 'writing', 'ai', '产品', '学习']
  },
  {
    label: 'Projects',
    title: '项目台账',
    desc: '公开推进中的产品、站点和自动化项目。',
    href: '/projects',
    meta: '4 tracked',
    shortcut: '03',
    keywords: ['项目', 'project', 'voice agent', 'cms', 'monitor']
  },
  {
    label: 'Radar',
    title: '比赛雷达',
    desc: '把值得投入的比赛、赛道和截止日期集中管理。',
    href: '/competitions',
    meta: 'priority matrix',
    shortcut: '04',
    keywords: ['比赛', 'competition', 'hackathon', 'radar']
  },
  {
    label: 'RSS',
    title: 'RSS 订阅',
    desc: '用阅读器跟踪新文章，不依赖平台推荐流。',
    href: '/rss.xml',
    meta: 'feed',
    shortcut: '05',
    keywords: ['rss', '订阅', 'feed']
  },
  {
    label: 'Contact',
    title: '联系我',
    desc: 'AI、自动化、内容产品、学习工具方向都可以聊。',
    href: '#contact',
    meta: 'email / github',
    shortcut: '06',
    keywords: ['联系', 'contact', 'github', 'email']
  }
];

const featuredProjects = [
  {
    title: 'AI 语音机器人',
    desc: '把多轮对话、话术流程和企业外呼场景做成可落地的语音交互系统。',
    href: '/projects',
    status: 'Active',
    signal: 'Voice Agent',
    tags: ['AI', 'LLM', 'SaaS']
  },
  {
    title: '个人网站工作台',
    desc: 'Astro 内容站、工具箱、比赛雷达和项目台账组合成一个公开工作台。',
    href: '/projects',
    status: 'Active',
    signal: 'This site',
    tags: ['Astro', 'Content', 'Tools']
  },
  {
    title: 'Admin CMS',
    desc: '通过 GitHub API 管理 Markdown 内容，给静态站补上轻量后台。',
    href: '/projects',
    status: 'Active',
    signal: 'Content Ops',
    tags: ['SPA', 'GitHub API', 'Markdown']
  }
];

const metrics = [
  { label: 'Published', value: totalPosts, unit: 'posts' },
  { label: 'Topics', value: totalTags, unit: 'tags' },
  { label: 'Toolbox', value: '60+', unit: 'tools' }
];
---

<BaseLayout>
  <Header />

  <main class="flex-1">
    <section id="home" class="container command-section">
      <div class="command-head animate-fade-in stagger-1">
        <div>
          <p class="section-kicker">Workbench Index</p>
          <h1>
            <span>先找到入口，</span>
            <span>再继续深入。</span>
          </h1>
        </div>
        <p class="command-copy">
          这里把文章、工具、项目和比赛雷达整理成可检索的工作台。你可以直接搜索关键词，也可以从快捷入口开始。
        </p>
      </div>

      <div class="command-grid">
        <div class="search-column animate-fade-in stagger-2">
          <form id="home-search-form" class="search-panel" action="/blog" method="get">
            <label for="home-search-input">搜索工作台</label>
            <div class="search-row">
              <input
                id="home-search-input"
                name="q"
                type="search"
                autocomplete="off"
                placeholder="试试：AI、工具、项目、比赛..."
                aria-describedby="home-search-help"
              />
              <button id="home-search-submit" type="submit">搜索</button>
            </div>
            <p id="home-search-help">
              输入时会先筛选本页入口，按回车进入文章库继续检索。
            </p>
          </form>

          <div class="metrics-strip" aria-label="站点概览">
            {metrics.map((metric) => (
              <div class="metric-cell">
                <span>{metric.label}</span>
                <strong>{metric.value}</strong>
                <em>{metric.unit}</em>
              </div>
            ))}
          </div>

          <div class="quick-grid" id="home-search-results">
            {quickEntries.map((entry) => (
              <a
                href={entry.href}
                class="quick-card home-searchable"
                data-home-search={`${entry.title} ${entry.desc} ${entry.label} ${entry.meta} ${entry.keywords.join(' ')}`}
              >
                <div class="quick-card-top">
                  <span>{entry.shortcut}</span>
                  <em>{entry.label}</em>
                </div>
                <h2>{entry.title}</h2>
                <p>{entry.desc}</p>
                <div class="quick-card-foot">
                  <span>{entry.meta}</span>
                  <span aria-hidden="true">→</span>
                </div>
              </a>
            ))}
          </div>

          <p id="home-search-empty" class="search-empty hidden">没有匹配入口。可以按回车去文章库继续搜。</p>
        </div>

        <aside class="update-panel animate-fade-in stagger-3" aria-label="最近更新">
          <div class="panel-head">
            <p class="section-kicker">Recent Updates</p>
            <span id="home-search-count">{quickEntries.length + posts.length + featuredProjects.length} items</span>
          </div>

          <div class="update-list">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="update-item home-searchable"
                data-home-search={`${post.data.title} ${post.data.description} ${(post.data.tags || []).join(' ')}`}
              >
                <time>{formatDate(post.data.date)}</time>
                <div>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.tags?.slice(0, 3).join(' / ') || 'Writing'}</p>
                </div>
              </a>
            ))}
          </div>

          <a href="/blog" class="panel-link">查看全部文章 <span aria-hidden="true">→</span></a>
        </aside>
      </div>
    </section>

    <section class="container featured-section">
      <div class="section-head">
        <div>
          <p class="section-kicker">Pinned Projects</p>
          <h2>重点项目卡</h2>
        </div>
        <a href="/projects">项目台账 <span aria-hidden="true">→</span></a>
      </div>

      <div class="project-grid">
        {featuredProjects.map((project) => (
          <a
            href={project.href}
            class="project-card home-searchable scroll-reveal"
            data-home-search={`${project.title} ${project.desc} ${project.signal} ${project.tags.join(' ')}`}
          >
            <div class="project-card-top">
              <span>{project.status}</span>
              <em>{project.signal}</em>
            </div>
            <h3>{project.title}</h3>
            <p>{project.desc}</p>
            <div class="project-tags">
              {project.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section id="blog" class="container writing-section">
      <div class="section-head">
        <div>
          <p class="section-kicker">Latest Writing</p>
          <h2>最近写下来的判断和实验</h2>
        </div>
        <a href="/blog">文章库 <span aria-hidden="true">→</span></a>
      </div>

      <div class="blog-list">
        {posts.slice(0, 3).map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString()}
            tags={post.data.tags}
            slug={post.id}
            image={post.data.image}
          />
        ))}
      </div>
    </section>

    <section id="contact" class="container contact-section">
      <div class="contact-grid">
        <div class="contact-copy-block">
          <p class="section-kicker">Contact</p>
          <h2>需要一起做点东西，可以直接找我。</h2>
          <p>
            AI、自动化、内容产品、学习工具这些方向都可以聊。这个站点会优先展示正在推进的东西，而不是只放一份静态介绍。
          </p>
        </div>

        <ul class="contact-links">
          <li>
            <a href="https://github.com/siuserxiaowei" target="_blank" rel="noopener">
              <span>GitHub</span>
              <em>@siuserxiaowei</em>
            </a>
          </li>
          <li>
            <a href="mailto:hi@siuserxiaowei.com">
              <span>Email</span>
              <em>hi@siuserxiaowei.com</em>
            </a>
          </li>
          <li>
            <a href="/rss.xml">
              <span>RSS</span>
              <em>订阅更新</em>
            </a>
          </li>
        </ul>
      </div>

      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .hidden {
    display: none !important;
  }

  .command-section {
    overflow-x: clip;
    padding-top: 6.5rem;
    padding-bottom: 3.5rem;
  }

  .command-head {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.62fr);
    gap: 2rem;
    align-items: end;
    margin-bottom: 1.2rem;
  }

  .command-head h1 {
    max-width: 34rem;
    margin-top: 0.55rem;
    font-size: clamp(2rem, 4.6vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.012em;
    overflow-wrap: anywhere;
  }

  .command-head h1 span {
    display: block;
  }

  .command-copy {
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 32rem;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .command-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(300px, 0.75fr);
    gap: 1rem;
    align-items: start;
  }

  .search-column {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .search-panel,
  .update-panel,
  .quick-card,
  .project-card {
    min-width: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .search-panel {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
  }

  .search-panel label {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .search-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.6rem;
  }

  .search-row input,
  .search-row button {
    height: 3rem;
    border-radius: var(--radius-sm);
    font: inherit;
  }

  .search-row input {
    min-width: 0;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    padding: 0 0.95rem;
    outline: none;
  }

  .search-row input:focus {
    border-color: color-mix(in srgb, var(--color-accent) 62%, var(--border));
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .search-row button {
    border: 1px solid var(--color-accent);
    background: var(--color-accent);
    color: var(--color-accent-ink);
    padding: 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .search-panel p,
  .search-empty {
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.65;
  }

  .metrics-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .metric-cell {
    min-height: 5.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 72%, var(--bg));
    padding: 0.8rem;
  }

  .metric-cell span,
  .metric-cell em,
  .panel-head span,
  .quick-card-top,
  .project-card-top {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .metric-cell span,
  .metric-cell em,
  .panel-head span {
    color: var(--text-muted);
  }

  .metric-cell strong {
    display: block;
    margin-top: 0.5rem;
    color: var(--text);
    font-family: var(--font-heading);
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1;
  }

  .metric-cell em {
    display: block;
    margin-top: 0.35rem;
    font-style: normal;
  }

  .quick-grid,
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    min-width: 0;
  }

  .quick-card,
  .project-card {
    display: flex;
    min-height: 13.2rem;
    flex-direction: column;
    padding: 1rem;
    color: var(--text);
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }

  .quick-card:hover,
  .project-card:hover,
  .update-item:hover {
    border-color: var(--border-strong);
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 72%, var(--surface-strong));
  }

  .quick-card-top,
  .project-card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-muted);
  }

  .quick-card-top span,
  .project-card-top span {
    color: var(--color-accent);
  }

  .quick-card-top em,
  .project-card-top em {
    font-style: normal;
  }

  .quick-card h2,
  .project-card h3 {
    margin-top: 1.15rem;
    font-size: 1.25rem;
    line-height: 1.18;
  }

  .quick-card p,
  .project-card p {
    margin-top: 0.7rem;
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .quick-card-foot {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .quick-card-foot span:last-child {
    color: var(--color-accent);
  }

  .update-panel {
    position: sticky;
    top: 5.5rem;
    padding: 1rem;
  }

  .panel-head,
  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .update-list {
    display: grid;
    margin-top: 0.95rem;
    border-top: 1px solid var(--border);
  }

  .update-item {
    display: grid;
    grid-template-columns: 3.4rem minmax(0, 1fr);
    gap: 0.85rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .update-item time {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .update-item h2 {
    overflow: hidden;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.45;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .update-item p {
    margin-top: 0.15rem;
    overflow: hidden;
    color: var(--text-muted);
    font-size: 0.78rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .panel-link,
  .section-head a {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .panel-link {
    display: inline-flex;
    gap: 0.35rem;
    margin-top: 1rem;
  }

  .featured-section,
  .writing-section,
  .contact-section {
    padding-top: 3.5rem;
    padding-bottom: 1rem;
  }

  .section-head {
    margin-bottom: 1rem;
    min-width: 0;
  }

  .section-head h2 {
    margin-top: 0.35rem;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .project-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .project-card {
    min-height: 15rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .project-tags span {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    padding: 0.18rem 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .blog-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    min-width: 0;
  }

  .contact-section {
    padding-bottom: 5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .contact-copy-block,
  .contact-links {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .contact-copy-block {
    padding: 1rem;
  }

  .contact-copy-block h2 {
    max-width: 34rem;
    margin-top: 0.45rem;
    font-size: clamp(1.45rem, 3vw, 2.15rem);
  }

  .contact-copy-block p:last-child {
    max-width: 42rem;
    margin-top: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  .contact-links li + li {
    border-top: 1px solid var(--border);
  }

  .contact-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.2rem;
    padding: 0.8rem 1rem;
    color: var(--text);
  }

  .contact-links a:hover {
    background: color-mix(in srgb, var(--surface) 72%, var(--surface-strong));
    color: var(--text);
  }

  .contact-links span {
    font-weight: 600;
  }

  .contact-links em {
    overflow: hidden;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-style: normal;
    letter-spacing: 0.08em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .home-searchable.is-filtered {
    display: none;
  }

  @media (max-width: 1040px) {
    .command-head,
    .command-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .update-panel {
      position: static;
    }

    .quick-grid,
    .project-grid,
    .blog-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .command-section {
      padding-top: 5rem;
      padding-bottom: 2.5rem;
    }

    .command-head {
      gap: 1rem;
    }

    .command-head h1 {
      font-size: clamp(2rem, 11vw, 2.65rem);
      line-height: 1.08;
    }

    .search-row,
    .metrics-strip,
    .quick-grid,
    .project-grid,
    .blog-list {
      grid-template-columns: 1fr;
    }

    .search-row input,
    .search-row button {
      width: 100%;
    }

    .quick-card,
    .project-card {
      min-height: 0;
    }

    .section-head,
    .panel-head {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.45rem;
    }
  }
</style>

<script is:inline>
  (() => {
    const input = document.getElementById('home-search-input');
    const cards = Array.from(document.querySelectorAll('[data-home-search]'));
    const count = document.getElementById('home-search-count');
    const empty = document.getElementById('home-search-empty');

    const normalize = (value) => (value || '').toLowerCase().trim();

    const filterHome = () => {
      const query = normalize(input?.value);
      let visible = 0;

      cards.forEach((card) => {
        const haystack = normalize(card.getAttribute('data-home-search'));
        const match = !query || haystack.includes(query);
        card.classList.toggle('is-filtered', !match);
        if (match) visible += 1;
      });

      if (count) count.textContent = `${visible} items`;
      if (empty) empty.classList.toggle('hidden', visible > 0);
    };

    input?.addEventListener('input', filterHome);
    filterHome();

    const revealElements = document.querySelectorAll('.scroll-reveal');
    if (!revealElements.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });

    revealElements.forEach((element) => observer.observe(element));
  })();
</script>
