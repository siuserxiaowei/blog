---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, 3);
const totalPosts = allPosts.length;
const todayLabel = new Date().toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
}).toUpperCase();

const operatingSystem = [
  {
    index: '01',
    label: 'Write',
    title: '把判断写成公开日志',
    desc: '文章不是装饰，而是把真实的产品判断、实验过程和学习路径记录下来。',
    note: 'Blog / RSS / newsletter',
    proof: `${totalPosts} 篇已发布`
  },
  {
    index: '02',
    label: 'Build',
    title: '把重复问题做成工具',
    desc: '工具页承担的是效率任务。高频动作直接固定成浏览器内可用的小产品。',
    note: 'Browser-first toolbox',
    proof: '60+ tools live'
  },
  {
    index: '03',
    label: 'Ship',
    title: '让项目和比赛形成外部约束',
    desc: '项目展示和比赛雷达不是补充页面，而是推动更新频率和判断密度的外部机制。',
    note: 'Projects / competitions',
    proof: '持续公开迭代'
  }
];

const signalStrip = [
  { k: 'Published', v: `${totalPosts} dispatches` },
  { k: 'Toolbox', v: '60+ browser tools' },
  { k: 'Cadence', v: 'Ship weekly' },
  { k: 'Focus', v: 'AI / automation / learning systems' }
];

const entryPoints = [
  {
    title: '工具箱',
    eyebrow: 'Browser-first utilities',
    href: '/tools',
    desc: '把 JSON、编码、哈希、时间、颜色、文本处理这些高频动作收进一个真正能用的目录。',
    stat: '60+ live tools',
    tags: ['快开即用', '浏览器内运行', '无上传']
  },
  {
    title: '项目展示',
    eyebrow: 'Products in progress',
    href: '/projects',
    desc: '集中展示我正在做的 AI、自动化和个人产品，保留持续迭代的上下文。',
    stat: '公开推进中',
    tags: ['AI 产品', '自动化', '公开构建']
  },
  {
    title: '比赛雷达',
    eyebrow: 'Opportunity scanner',
    href: '/competitions',
    desc: '把创业比赛、黑客松和创新项目搜集成可以快速扫描的机会页面。',
    stat: '持续更新',
    tags: ['信息整理', '机会发现', '降低搜索成本']
  }
];

const publishingLanes = [
  '产品判断和拆解',
  'AI 工具与自动化实验',
  '公开构建中的项目记录'
];
---

<BaseLayout>
  <Header />

  <main class="flex-1">
    <section
      id="home"
      class="mx-auto px-6 pt-32 pb-16 md:pt-40 md:pb-22"
      style="max-width: var(--container-max); scroll-margin-top: 7rem;"
    >
      <div class="hero-shell">
        <div class="scroll-reveal hero-copy">
          <div class="hero-meta-row">
            <span class="pill-note">Independent Workbench</span>
            <span class="hero-date">{todayLabel}</span>
          </div>

          <h1 class="hero-title">
            这里不是个人简历，<br />
            <span class="text-shimmer">是一个持续运行的工作台。</span>
          </h1>

          <p class="hero-copy-text">
            我把 AI、自动化、产品工程和学习系统相关的工作公开发布出来。
            一部分写成文章，一部分做成工具，一部分继续推进成项目。
          </p>

          <div class="hero-actions">
            <a href="#blog" class="hero-btn hero-btn-primary btn-glow">看最新文章</a>
            <a href="/tools" class="hero-btn hero-btn-ghost">进入工具箱</a>
          </div>
        </div>

        <aside class="scroll-reveal hero-board surface-card gradient-border">
          <div class="hero-board-head">
            <p class="section-kicker">Site Model</p>
            <span>updated weekly</span>
          </div>

          <div class="hero-board-list">
            {operatingSystem.map((item) => (
              <article class="hero-board-row">
                <div class="hero-board-index">{item.index}</div>
                <div>
                  <p class="hero-board-label">{item.label}</p>
                  <h2>{item.title}</h2>
                  <p>{item.desc}</p>
                  <div class="hero-board-meta">
                    <span>{item.note}</span>
                    <strong>{item.proof}</strong>
                  </div>
                </div>
              </article>
            ))}
          </div>

          <div class="section-rule"></div>

          <div class="hero-dispatches">
            <div class="hero-dispatches-head">
              <p class="section-kicker">Recent Dispatches</p>
              <a href="/blog">全部文章 ↗</a>
            </div>

            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="hero-dispatch">
                <span>{post.data.title}</span>
                <em>{post.data.date.toLocaleDateString('zh-CN', { month: 'numeric', day: 'numeric' })}</em>
              </a>
            ))}
          </div>
        </aside>
      </div>

      <div class="hero-strip">
        {signalStrip.map((item) => (
          <div class="metric-tile scroll-reveal hero-metric">
            <span>{item.k}</span>
            <strong>{item.v}</strong>
          </div>
        ))}
      </div>
    </section>

    <section
      id="about"
      class="mx-auto px-6 py-20 md:py-22"
      style="max-width: var(--container-max); scroll-margin-top: 7rem;"
    >
      <div class="section-row scroll-reveal">
        <div class="section-head">
          <p class="section-kicker">Operating System</p>
          <h2>这个网站围绕三件事组织，而不是围绕“自我介绍”。</h2>
        </div>
        <p class="section-side-copy">
          视觉和结构都只服务一个目标: 让人快速明白我在做什么、最近在推进什么、以及下一步该从哪里进入。
        </p>
      </div>

      <div class="operating-grid">
        {operatingSystem.map((item) => (
          <article class="scroll-reveal surface-card card-hover operating-card">
            <div class="operating-card-head">
              <span>{item.index}</span>
              <p>{item.label}</p>
            </div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class="operating-card-foot">
              <span>{item.note}</span>
              <strong>{item.proof}</strong>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="mx-auto px-6 py-8 md:py-10" style="max-width: var(--container-max);">
      <div class="section-row scroll-reveal">
        <div class="section-head">
          <p class="section-kicker">Entry Points</p>
          <h2>先从最有用的三个入口开始。</h2>
        </div>
      </div>

      <div class="entry-grid">
        {entryPoints.map((entry) => (
          <a href={entry.href} class="scroll-reveal surface-card card-hover gradient-border entry-card">
            <p class="entry-eyebrow">{entry.eyebrow}</p>
            <h3>{entry.title}</h3>
            <p class="entry-copy">{entry.desc}</p>

            <div class="entry-tags">
              {entry.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>

            <div class="entry-footer">
              <span>{entry.stat}</span>
              <span>进入 ↗</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section
      id="blog"
      class="mx-auto px-6 py-20 md:py-24"
      style="max-width: var(--container-max); scroll-margin-top: 7rem;"
    >
      <div class="section-row scroll-reveal">
        <div class="section-head">
          <p class="section-kicker">Writing</p>
          <h2>最近写下来的判断和实验。</h2>
        </div>
        <p class="section-side-copy">
          优先记录真实进展，不写空泛总结。文章会围绕下面三类主题持续更新。
        </p>
      </div>

      <div class="blog-shell">
        <aside class="scroll-reveal surface-card blog-brief">
          <p class="section-kicker">Reading Guide</p>
          <h3>内容主线</h3>
          <div class="blog-lanes">
            {publishingLanes.map((lane) => (
              <div class="blog-lane">
                <span></span>
                <p>{lane}</p>
              </div>
            ))}
          </div>
          <a href="/blog" class="blog-brief-link">全部文章 ↗</a>
        </aside>

        <div class="blog-list">
          {posts.map((post) => (
            <div class="scroll-reveal">
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date.toISOString()}
                tags={post.data.tags}
                slug={post.id}
                image={post.data.image}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section
      id="contact"
      class="mx-auto px-6 py-18 md:py-22"
      style="max-width: var(--container-max); scroll-margin-top: 7rem;"
    >
      <div class="contact-grid">
        <div class="scroll-reveal">
          <Newsletter />
        </div>

        <div class="scroll-reveal surface-card gradient-border contact-card">
          <p class="section-kicker">Contact</p>
          <h2>如果你也在做类似方向，欢迎直接联系我。</h2>
          <p class="contact-copy">
            AI、自动化、内容产品、学习工具这些方向都可以聊。这里更希望结识一起做东西的人，而不只是交换名片。
          </p>

          <div class="contact-links">
            <a href="https://github.com/siuserxiaowei" target="_blank" rel="noopener">
              <span>GitHub</span>
              <em>@siuserxiaowei</em>
            </a>
            <a href="mailto:hi@siuserxiaowei.com">
              <span>Email</span>
              <em>hi@siuserxiaowei.com</em>
            </a>
            <a href="/rss.xml">
              <span>RSS</span>
              <em>订阅更新</em>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(360px, 0.96fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100%;
    padding-right: 0.5rem;
  }

  .hero-meta-row,
  .hero-board-head,
  .hero-dispatches-head,
  .entry-footer,
  .operating-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .hero-date {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-title {
    margin-top: 1.25rem;
    font-size: clamp(2.9rem, 6.2vw, 5.4rem);
    line-height: 0.96;
    letter-spacing: -0.035em;
  }

  .hero-copy-text {
    max-width: 42rem;
    margin-top: 1.25rem;
    color: var(--text-secondary);
    font-size: clamp(0.98rem, 1.25vw, 1.08rem);
    line-height: 1.9;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.7rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.15rem;
    border-radius: 999px;
    padding: 0 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .hero-btn-primary {
    background: linear-gradient(135deg, var(--color-accent), color-mix(in srgb, var(--color-accent) 76%, white 24%));
    color: #111;
  }

  .hero-btn-ghost {
    border: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    color: var(--text);
  }

  .hero-btn:hover {
    transform: translateY(-1px);
  }

  .hero-board {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 28px;
  }

  .hero-board-head span,
  .hero-board-label,
  .operating-card-head p,
  .entry-eyebrow,
  .entry-tags span,
  .hero-metric span,
  .blog-brief-link,
  .contact-links em {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .hero-board-list {
    display: grid;
    gap: 1rem;
  }

  .hero-board-row {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr);
    gap: 0.85rem;
  }

  .hero-board-index {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-board-row h2 {
    margin-top: 0.28rem;
    margin-bottom: 0.45rem;
    font-size: 1.28rem;
    line-height: 1.12;
  }

  .hero-board-row p:last-of-type {
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .hero-board-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
  }

  .hero-board-meta span {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-board-meta strong,
  .operating-card-foot strong,
  .hero-metric strong {
    color: var(--text);
    font-size: 0.98rem;
  }

  .hero-dispatches {
    display: grid;
    gap: 0.65rem;
  }

  .hero-dispatches-head a {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-dispatch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0.95rem;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
  }

  .hero-dispatch span {
    line-height: 1.45;
  }

  .hero-dispatch em {
    color: var(--text-secondary);
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .hero-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 0.95rem;
  }

  .hero-metric {
    padding: 1rem 1.05rem;
  }

  .hero-metric span {
    display: block;
    margin-bottom: 0.35rem;
  }

  .section-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: 1.2rem;
    align-items: end;
    margin-bottom: 1.4rem;
  }

  .section-head h2,
  .contact-card h2 {
    margin-top: 0.35rem;
    font-size: clamp(1.8rem, 3vw, 2.9rem);
    line-height: 1.02;
  }

  .section-side-copy {
    color: var(--text-secondary);
    line-height: 1.85;
  }

  .operating-grid,
  .entry-grid,
  .contact-grid {
    display: grid;
    gap: 1rem;
  }

  .operating-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .operating-card,
  .entry-card,
  .contact-card,
  .blog-brief {
    border-radius: 28px;
    padding: 1.25rem;
  }

  .operating-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.95rem;
  }

  .operating-card-head span {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .operating-card h3,
  .entry-card h3,
  .blog-brief h3 {
    font-size: 1.42rem;
    line-height: 1.14;
  }

  .operating-card h3 {
    margin-bottom: 0.65rem;
  }

  .operating-card p,
  .entry-copy,
  .blog-brief p,
  .contact-copy {
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .operating-card-foot {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
  }

  .operating-card-foot span {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .entry-grid,
  .contact-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .entry-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .entry-copy {
    flex: 1;
  }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .entry-tags span {
    padding: 0.28rem 0.58rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    background: color-mix(in srgb, var(--surface-2) 86%, transparent);
  }

  .entry-footer {
    margin-top: 0.2rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    color: var(--text-secondary);
  }

  .blog-shell {
    display: grid;
    grid-template-columns: minmax(280px, 0.42fr) minmax(0, 1fr);
    gap: 1rem;
  }

  .blog-brief {
    height: fit-content;
  }

  .blog-brief h3 {
    margin-top: 0.35rem;
    margin-bottom: 1rem;
  }

  .blog-lanes {
    display: grid;
    gap: 0.75rem;
  }

  .blog-lane {
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr);
    gap: 0.7rem;
    align-items: start;
  }

  .blog-lane span {
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.45rem;
    border-radius: 999px;
    background: var(--color-accent);
  }

  .blog-brief-link {
    display: inline-flex;
    margin-top: 1.25rem;
  }

  .blog-list {
    display: grid;
    gap: 1rem;
  }

  .contact-grid {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  }

  .contact-card {
    display: grid;
    gap: 1rem;
  }

  .contact-links {
    display: grid;
    gap: 0.7rem;
  }

  .contact-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0.95rem;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .contact-links a:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-accent) 28%, var(--border));
  }

  .contact-links span {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 1120px) {
    .hero-shell,
    .section-row,
    .blog-shell {
      grid-template-columns: 1fr;
    }

    .operating-grid,
    .entry-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .hero-title {
      font-size: clamp(2.45rem, 11vw, 3.8rem);
    }

    .hero-strip,
    .operating-grid,
    .entry-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .hero-board,
    .operating-card,
    .entry-card,
    .blog-brief,
    .contact-card {
      border-radius: 24px;
    }
  }
</style>

<script is:inline>
  (() => {
    const revealElements = document.querySelectorAll('.scroll-reveal');

    if (!revealElements.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });

    revealElements.forEach((element) => observer.observe(element));
  })();
</script>
