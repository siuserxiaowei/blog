---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { competitions, RADAR_UPDATED_AT, enrichCompetitions, getCompetitionCategories } from '../data/competitions.js';

const TODAY = new Date(RADAR_UPDATED_AT);
const enriched = enrichCompetitions(competitions, TODAY);
const expiredCount = enriched.filter(c => c.status.kind === 'expired').length;
const urgentCount = enriched.filter(c => c.status.kind === 'urgent').length;
const sCount = enriched.filter(c => c.tier === 'S').length;
const openCount = enriched.length - expiredCount;
const urgentItems = enriched.filter(c => c.status.kind === 'urgent').sort((a, b) => a.status.days - b.status.days);
const topRadar = enriched.slice().sort((a, b) => b.priority - a.priority || b.match - a.match).slice(0, 4);
const categories = getCompetitionCategories(enriched);
---

<BaseLayout title="AI 硬件赛事雷达 · siuser小伟" description="AI 硬件方案商的赛事与行业活动调研看板。">
  <Header />

  <main class="competition-radar-page flex-1">
    <section class="radar-hero">
      <div class="radar-shell">
        <div class="hero-grid">
          <div class="hero-copy animate-fade-in stagger-1">
            <div class="radar-meta-row">
              <p class="section-kicker">Competition Radar</p>
              <span>// {RADAR_UPDATED_AT}</span>
              <span>{enriched.length} signals tracked</span>
            </div>
            <h1>AI 硬件赛事雷达</h1>
            <p class="hero-brief">
              面向 AI 硬件方案商和早期硬件创业团队的赛事作战台。把政府政策、创投曝光、工程量产和渠道验证压到同一屏，优先判断：能不能拿订单、能不能上量、能不能拿背书。
            </p>
            <div class="radar-signal-row">
              <span><span class="dot-accent"></span>订单</span>
              <span><span class="dot-accent2"></span>政策</span>
              <span><span class="dot-warn"></span>资本</span>
              <span><span class="dot-danger"></span>硬截止</span>
            </div>
          </div>

          <div class="radar-scope animate-fade-in stagger-2" aria-hidden="true">
            <div class="scope-axis scope-axis-x"></div>
            <div class="scope-axis scope-axis-y"></div>
            <div class="scope-ring scope-ring-1"></div>
            <div class="scope-ring scope-ring-2"></div>
            <div class="scope-ring scope-ring-3"></div>
            <div class="scope-sweep"></div>
            <span class="scope-blip blip-1"></span>
            <span class="scope-blip blip-2"></span>
            <span class="scope-blip blip-3"></span>
            <span class="scope-blip blip-4"></span>
            <div class="scope-readout">
              <span>TOP PRIORITY</span>
              <strong>{topRadar[0]?.priority ?? 0}</strong>
            </div>
          </div>
        </div>

        <div class="radar-metrics animate-fade-in stagger-3">
          <div class="metric-tile">
            <span class="metric-label">TOTAL</span>
            <strong>{enriched.length}</strong>
            <span>赛事总数</span>
          </div>
          <div class="metric-tile metric-hot">
            <span class="metric-label">ACTIVE</span>
            <strong>{openCount}</strong>
            <span>仍可动作</span>
          </div>
          <div class="metric-tile metric-warn">
            <span class="metric-label">URGENT</span>
            <strong>{urgentCount}</strong>
            <span>14 天内截止</span>
          </div>
          <div class="metric-tile">
            <span class="metric-label">TIER S</span>
            <strong>{sCount}</strong>
            <span>S 级强推</span>
          </div>
          <div class="metric-tile metric-muted">
            <span class="metric-label">EXPIRED</span>
            <strong>{expiredCount}</strong>
            <span>已截止</span>
          </div>
        </div>
      </div>
    </section>

    <section class="radar-section">
      <div class="radar-shell">
        <div class="mission-console animate-fade-in stagger-4">
          <div class="mission-brief">
            <p class="section-kicker">// Priority Matrix</p>
            <h2>5 月第一优先级：BEYOND、广东 OPC、鸿蒙、海聚英才</h2>
            <p>
              5-8 到 5-15 是硬截止密集窗口：BEYOND HACK DAY、广东众创杯 OPC、Founder Park × 百度快闪、北京 5.10 AI 极客争霸赛、HarmonyOS 创新赛都在同一段时间。错过 4-30 三场后，短线先保能带现场资源和渠道验证的项目；中线锁定海聚英才、创客中国、奇绩创坛和智能终端场景赛。
            </p>
            <div class="mission-tags">
              <span class="pill-note"><span class="dot-danger"></span>5-8 BEYOND</span>
              <span class="pill-note"><span class="dot-danger"></span>5-10 广东 OPC</span>
              <span class="pill-note"><span class="dot-warn"></span>5-15 鸿蒙</span>
              <span class="pill-note"><span class="dot-accent2"></span>5-31 海聚英才</span>
            </div>
          </div>

          <div class="urgent-console">
            <div class="console-title-row">
              <p class="section-kicker">// 14 天紧急</p>
              <span>{urgentCount} alerts</span>
            </div>
            {urgentCount > 0 ? (
              <ul class="urgent-stack">
                {urgentItems.map(c => (
                  <li>
                    <button data-jump={c.id} class="urgent-chip">
                      <span class={`status-dot status-${c.status.kind}`}></span>
                      <span class="urgent-name">{c.name}</span>
                      <span class="urgent-meta">{c.tier} · {c.match.toFixed(1)}</span>
                      <span class="urgent-badge">{c.status.days}d</span>
                    </button>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="empty-state">14 天内暂无赛事截止。</p>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="radar-section radar-section-tight">
      <div class="radar-shell">
        <div class="control-console">
          <div class="console-title-row">
            <p class="section-kicker">// Control Console</p>
            <span><span class="console-led"></span>filters online</span>
          </div>
          <div class="filter-rows">
            <div class="radar-control-grid">
              <label class="radar-field">
                <span class="section-kicker filter-label">// 搜索</span>
                <input id="radar-search" class="radar-input" type="search" placeholder="搜赛事、赛道、打法" autocomplete="off" />
              </label>
              <label class="radar-field">
                <span class="section-kicker filter-label">// 状态</span>
                <select id="radar-status" class="radar-select">
                  <option value="全部">全部状态</option>
                  <option value="urgent">紧急</option>
                  <option value="ongoing">进行中</option>
                  <option value="upcoming">即将开始</option>
                  <option value="expired">已过期</option>
                </select>
              </label>
              <label class="radar-field">
                <span class="section-kicker filter-label">// 排序</span>
                <select id="radar-sort" class="radar-select">
                  <option value="match-desc">匹配度高优先</option>
                  <option value="urgent-first">紧急优先</option>
                  <option value="deadline-asc">截止近优先</option>
                  <option value="tier-desc">等级高优先</option>
                </select>
              </label>
            </div>
            <div class="filter-row">
              <span class="section-kicker filter-label">// 分类</span>
              <div class="filter-group">
                <button data-fcat="全部" class="filter-cat filter-chip is-on">全部</button>
                {categories.map(cat => (
                  <button data-fcat={cat} class="filter-cat filter-chip">{cat}</button>
                ))}
              </div>
            </div>
            <div class="filter-row">
              <span class="section-kicker filter-label">// 等级</span>
              <div class="filter-group compact">
                <button data-ftier="全部" class="filter-tier filter-chip is-on">全部</button>
                {['S','A','B'].map(t => (
                  <button data-ftier={t} class="filter-tier filter-chip">{t} 级</button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="radar-section radar-section-last">
      <div class="radar-shell">
        <div class="radar-workbench">
          <aside class="competition-index-panel">
            <div class="panel-bar">
              <span class="section-kicker">// Targets</span>
              <span id="list-count">{enriched.length} items</span>
            </div>
            <div class="competition-list-stack">
              {enriched.map(c => (
                <button
                  data-id={c.id}
                  data-name={c.name}
                  data-full-name={c.fullName}
                  data-cat={c.cat}
                  data-tier={c.tier}
                  data-status={c.status.kind}
                  data-match={c.match}
                  data-deadline={c.deadlineISO}
                  data-strategy={c.strategy}
                  data-url={c.url}
                  data-priority={c.priority}
                  data-bucket={c.bucket}
                  data-sources={(c.sources ?? []).map(source => `${source.title} ${source.date} ${source.url}`).join(' | ')}
                  data-search={`${c.name} ${c.fullName} ${c.cat} ${c.tier} ${c.status.label} ${c.bucket} ${c.desc} ${c.strategy} ${c.org} ${c.loc} ${c.winning.join(' ')} ${(c.sources ?? []).map(source => source.title).join(' ')}`}
                  class="cp-list-item"
                >
                  <div class="list-topline">
                    <span class="list-code">#{c.id}</span>
                    <span class={`tier-tag tier-${c.tier}`}>{c.tier}</span>
                  </div>
                  <h4>{c.name}</h4>
                  <div class="list-meta-line">
                    <span class={`status-dot status-${c.status.kind}`}></span>
                    <span>{c.status.label}</span>
                    <span class="meta-dot"></span>
                    <span>{c.cat}</span>
                  </div>
                  <p>{c.desc}</p>
                  <div class="list-footer">
                    <span>{c.bucket}</span>
                    <strong>{c.match.toFixed(1)}<small>/10</small></strong>
                  </div>
                </button>
              ))}
            </div>
          </aside>

          <section class="competition-detail-stage">
            {enriched.map((c, i) => (
              <div data-detail={c.id} class:list={["detail-panel", i !== 0 && "hidden"]}>
                <article class="radar-panel detail-card">
                  <div class="detail-header">
                    <div class="detail-title-zone">
                      <div class="detail-tags">
                        <span class={`tier-tag tier-${c.tier} tier-lg`}>{c.tier} 级</span>
                        <span class="pill-note"><span class={`status-dot status-${c.status.kind}`}></span>{c.status.label}</span>
                        <span class="pill-note">信用 {c.rel}</span>
                        <span class="pill-note">{c.bucket}</span>
                      </div>
                      <h2>{c.fullName}</h2>
                      <div class="detail-meta-grid">
                        <span><span>LOC</span>{c.loc}</span>
                        <span><span>DATE</span>{c.date}</span>
                        <span><span>ORG</span>{c.org}</span>
                      </div>
                    </div>

                    <div class="match-console">
                      <span>MATCH</span>
                      <strong>{c.match.toFixed(1)}</strong>
                      <small>{c.suit} · priority {c.priority}</small>
                    </div>
                  </div>

                  <div class="timeline-block">
                    <div class="block-heading">
                      <p class="section-kicker">// Timeline</p>
                      <span>deadline {c.deadlineISO}</span>
                    </div>
                    <div class="timeline-strip" style={`--timeline-count: ${c.timeline.length};`}>
                      {c.timeline.map(n => {
                        const past = new Date(n.date) < TODAY;
                        const dotClass = past ? 'past' : n.critical ? 'critical' : 'normal';
                        return (
                          <div class="timeline-node">
                            <div class={`timeline-dot ${dotClass}`}></div>
                            <p>{n.event}</p>
                            <small>{n.date}</small>
                          </div>
                        );
                      })}
                    </div>
                  </div>

                  <div class="intel-grid">
                    <section class="intel-block">
                      <p class="section-kicker">// 赛事定位</p>
                      <p>{c.desc}</p>
                    </section>
                    <section class="intel-block intel-action">
                      <p class="section-kicker">// 参赛打法</p>
                      <p>{c.strategy}</p>
                    </section>
                  </div>

                  <div class="chip-section-grid">
                    <section>
                      <p class="section-kicker">// 核心奖励 / 资源</p>
                      <div class="chip-cloud">
                        {c.rewards.map(r => (
                          <span class="reward-chip">{r}</span>
                        ))}
                      </div>
                    </section>
                    <section>
                      <p class="section-kicker">// 必胜卖点</p>
                      <div class="chip-cloud">
                        {c.winning.map(w => (
                          <span class="winning-chip">{w}</span>
                        ))}
                      </div>
                    </section>
                  </div>
                </article>

                <div class="pros-cons-grid">
                  <section class="radar-panel signal-list positive">
                    <p class="section-kicker">// + 优势</p>
                    <ul>
                      {c.pros.map(p => (
                        <li><span></span>{p}</li>
                      ))}
                    </ul>
                  </section>
                  <section class="radar-panel signal-list negative">
                    <p class="section-kicker">// ! 难点 / 风险</p>
                    <ul>
                      {c.cons.map(p => (
                        <li><span></span>{p}</li>
                      ))}
                    </ul>
                  </section>
                </div>

                <div class="radar-panel action-console">
                  <div class="audience-block">
                    <p class="section-kicker">// 适合谁</p>
                    <p>{c.audience}</p>
                    {c.sources?.length ? (
                      <div class="source-links">
                        <span class="section-kicker source-label">// 参考来源</span>
                        {c.sources.map(source => (
                          <a href={source.url} target="_blank" rel="noopener" class="source-link">
                            <span>{source.title}</span>
                            <small>{source.date}</small>
                          </a>
                        ))}
                      </div>
                    ) : null}
                  </div>
                  <div class="detail-actions">
                    <button type="button" data-copy-summary={c.id} class="summary-button">
                      复制参赛摘要
                    </button>
                    <a href={c.url} target="_blank" rel="noopener" class="cta-button">
                      访问官方报名页 <span aria-hidden="true">↗</span>
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </section>
        </div>

        <div class="radar-footnote">
          DATA UPDATED · {RADAR_UPDATED_AT} · {enriched.length} ENTRIES TRACKED · 带「参考上届」标签的届次尚未官方公告，请以主办方通知为准
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* ============ Filter rows ============ */
  .filter-rows {
    display: grid;
    gap: 1rem;
  }

  .radar-control-grid {
    display: grid;
    grid-template-columns: minmax(220px, 1.3fr) minmax(160px, 0.7fr) minmax(180px, 0.8fr);
    gap: 0.85rem;
    align-items: end;
  }

  .radar-field {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .radar-input,
  .radar-select {
    width: 100%;
    min-width: 0;
    min-height: 42px;
    border-radius: var(--radius-md);
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 62%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    padding: 0 0.85rem;
    font-size: 13px;
    line-height: 1.2;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .radar-input::placeholder {
    color: color-mix(in srgb, var(--text-secondary) 78%, transparent);
  }

  .radar-select {
    cursor: pointer;
  }

  .radar-input:focus,
  .radar-select:focus {
    border-color: color-mix(in srgb, var(--color-accent) 58%, var(--border));
    background: color-mix(in srgb, var(--surface) 76%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 14%, transparent);
  }

  .filter-row {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr);
    align-items: center;
    gap: 1.25rem;
  }

  .filter-label {
    white-space: nowrap;
  }

  .filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    min-width: 0;
  }

  @media (max-width: 720px) {
    .radar-control-grid {
      grid-template-columns: 1fr;
    }

    .filter-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  /* ============ 列表项 ============ */
  .cp-list-item {
    cursor: pointer;
    border-radius: var(--radius-lg);
    padding-block: 1.1rem !important;
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 90%, transparent), color-mix(in srgb, var(--surface-2) 82%, transparent));
    border: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: transform 0.24s cubic-bezier(.2,.7,.2,1), border-color 0.2s ease, box-shadow 0.24s ease, background 0.24s ease;
    overflow-wrap: anywhere;
  }
  .cp-list-item:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--border));
    box-shadow: 0 18px 36px -28px color-mix(in srgb, var(--color-accent) 32%, transparent);
  }
  .cp-list-item.is-active {
    border-color: color-mix(in srgb, var(--color-accent) 70%, transparent) !important;
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 8%, var(--surface)), color-mix(in srgb, var(--surface-2) 85%, transparent));
    box-shadow: 0 22px 48px -30px color-mix(in srgb, var(--color-accent) 55%, transparent);
    transform: translateY(-1px);
  }
  .cp-list-item.is-active h4 { color: var(--color-accent) !important; }
  .cp-list-item[data-status="expired"] { opacity: 0.55; }

  /* ============ 等级标签 ============ */
  .tier-tag {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 10.5px; font-weight: 700; letter-spacing: 0.08em;
    font-family: var(--font-mono);
  }
  .tier-tag.tier-lg {
    padding: 4px 11px;
    font-size: 11px;
  }
  .tier-S {
    color: #1a130b;
    background: var(--color-accent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 60%, transparent), 0 0 16px -4px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  /* Dark ink on accent fills */
  .tier-S,
  .urgent-badge,
  .filter-chip.is-on,
  .cta-button {
    color: var(--color-accent-ink);
  }
  .tier-A {
    color: var(--color-accent-2);
    background: color-mix(in srgb, var(--color-accent-2) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent-2) 42%, transparent);
  }
  .tier-B {
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
  }

  /* ============ 状态点 ============ */
  .status-dot {
    display: inline-block; width: 7px; height: 7px; border-radius: 999px;
    flex-shrink: 0;
  }
  .status-dot.status-urgent {
    background: var(--color-accent);
    animation: status-pulse 1.8s infinite;
  }
  .status-dot.status-ongoing { background: var(--color-accent-2); }
  .status-dot.status-upcoming { background: color-mix(in srgb, var(--text-secondary) 70%, transparent); }
  .status-dot.status-expired { background: color-mix(in srgb, var(--text-secondary) 40%, transparent); }
  @keyframes status-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 65%, transparent); }
    70% { box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-accent) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 0%, transparent); }
  }

  /* ============ 紧急清单 chip ============ */
  .urgent-chip {
    display: flex; align-items: center; gap: 10px; width: 100%;
    padding: 10px 12px;
    text-align: left;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .urgent-chip:hover {
    border-color: color-mix(in srgb, var(--color-accent) 55%, var(--border));
    background: color-mix(in srgb, var(--color-accent) 6%, var(--surface));
    transform: translateX(2px);
  }
  .urgent-badge {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 999px;
    color: #1a130b;
    background: var(--color-accent);
  }

  .dot-accent, .dot-accent2 {
    display: inline-block; width: 6px; height: 6px; border-radius: 999px; margin-right: 2px;
  }
  .dot-accent { background: var(--color-accent); }
  .dot-accent2 { background: var(--color-accent-2); }

  /* ============ 时间轴点 ============ */
  .timeline-dot {
    width: 11px; height: 11px; border-radius: 999px;
    background: color-mix(in srgb, var(--text-secondary) 50%, transparent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--border) 80%, transparent);
    position: relative; z-index: 1;
  }
  .timeline-dot.past { background: color-mix(in srgb, var(--text-secondary) 40%, transparent); }
  .timeline-dot.normal {
    background: var(--color-accent-2);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent-2) 25%, transparent);
  }
  .timeline-dot.critical {
    background: var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 28%, transparent);
    transform: scale(1.2);
  }

  /* ============ 筛选按钮 ============ */
  .filter-chip {
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
    max-width: 100%;
    overflow-wrap: anywhere;
  }
  .filter-chip:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--border));
  }
  .filter-chip.is-on {
    color: #1a130b;
    background: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 8px 20px -12px color-mix(in srgb, var(--color-accent) 70%, transparent);
  }

  /* ============ 奖励 / 卖点 chip ============ */
  .reward-chip {
    font-size: 12px; padding: 5px 10px;
    border-radius: var(--radius-md);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent);
    line-height: 1.5;
  }
  .winning-chip {
    font-size: 12px; padding: 5px 10px;
    border-radius: 999px;
    color: var(--color-accent-2);
    background: color-mix(in srgb, var(--color-accent-2) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent-2) 32%, transparent);
    line-height: 1.5;
  }

  /* ============ CTA ============ */
  .cta-button {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600; font-size: 14px;
    color: #1a130b;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
    box-shadow: 0 16px 28px -18px color-mix(in srgb, var(--color-accent) 52%, transparent);
    transition: transform 0.24s ease, box-shadow 0.24s ease;
    justify-content: center;
    min-width: 0;
    text-align: center;
  }
  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 36px -18px color-mix(in srgb, var(--color-accent) 62%, transparent);
  }

  .detail-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.65rem;
    min-width: min(100%, 320px);
  }

  .source-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-top: 0.95rem;
    min-width: 0;
  }

  .source-label {
    flex-basis: 100%;
    font-size: 10px;
  }

  .source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    max-width: 100%;
    padding: 0.38rem 0.65rem;
    border-radius: var(--radius-md);
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 62%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    font-size: 12px;
    line-height: 1.35;
    overflow-wrap: anywhere;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .source-link:hover {
    border-color: color-mix(in srgb, var(--color-accent) 44%, var(--border));
    background: color-mix(in srgb, var(--color-accent) 7%, var(--surface));
    transform: translateY(-1px);
  }

  .source-link small {
    flex-shrink: 0;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .summary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    padding: 12px 18px;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 14px;
    line-height: 1.2;
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 58%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .summary-button:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 48%, var(--border));
    background: color-mix(in srgb, var(--color-accent) 8%, var(--surface));
    transform: translateY(-1px);
  }

  .summary-button.is-copied {
    color: var(--color-accent-ink);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ============ line-clamp ============ */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ============ 响应式微调 ============ */
  @media (max-width: 768px) {
    .cp-list-item { padding: 14px; }
    .urgent-chip { padding: 10px; }
    .detail-actions {
      width: 100%;
      justify-content: stretch;
    }
    .detail-actions > * {
      width: 100%;
    }
    .source-link {
      width: 100%;
      justify-content: space-between;
    }
  }

  /* ============ 2026 radar density pass ============ */
  html:has(.competition-radar-page) {
    --bg: #06100d;
    --surface: #0c1713;
    --surface-strong: #12231d;
    --surface-card: #0f1c18;
    --surface-2: #13241f;
    --border: rgba(130, 174, 151, 0.22);
    --border-strong: rgba(89, 242, 174, 0.44);
    --text: #edfff7;
    --text-secondary: #a8beb4;
    --text-muted: #71877c;
    --color-accent: #49f2ae;
    --color-accent-2: #f2c766;
    --color-accent-dark: #1fa874;
    --color-accent-ink: #04120d;
  }

  body:has(.competition-radar-page) {
    background: #06100d;
  }

  .competition-radar-page {
    --radar-panel: rgba(11, 24, 20, 0.88);
    --radar-panel-strong: rgba(15, 34, 28, 0.94);
    --radar-line: rgba(111, 242, 181, 0.22);
    --radar-cyan: #79d9ff;
    --radar-red: #ff6d61;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    background:
      linear-gradient(rgba(73, 242, 174, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(73, 242, 174, 0.04) 1px, transparent 1px),
      linear-gradient(180deg, #07120f 0%, #091814 52%, #050907 100%);
    background-size: 42px 42px, 42px 42px, auto;
    color: var(--text);
  }

  .competition-radar-page::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(180deg, rgba(255,255,255,0.035) 0 1px, transparent 1px 7px);
    opacity: 0.18;
  }

  .radar-shell {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin: 0 auto;
    padding-inline: 1.5rem;
  }

  .radar-hero {
    padding: 4.5rem 0 1.5rem;
  }

  .radar-section {
    padding: 1.1rem 0;
  }

  .radar-section-tight {
    padding-top: 0.5rem;
  }

  .radar-section-last {
    padding-bottom: 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.58fr);
    gap: 2rem;
    align-items: center;
  }

  .radar-meta-row,
  .console-title-row,
  .panel-bar,
  .block-heading,
  .list-topline,
  .list-meta-line,
  .list-footer,
  .radar-signal-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .radar-meta-row span,
  .console-title-row span,
  .panel-bar span,
  .block-heading span,
  .list-code,
  .metric-label,
  .radar-footnote {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin: 0.7rem 0 0.85rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: clamp(2.45rem, 6vw, 5.1rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .hero-brief {
    max-width: 760px;
    color: var(--text-secondary);
    font-size: 0.98rem;
    line-height: 1.85;
  }

  .radar-signal-row {
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .radar-signal-row span,
  .pill-note {
    min-width: 0;
    border-color: var(--radar-line);
    background: rgba(8, 20, 16, 0.78);
    color: var(--text-secondary);
  }

  .radar-scope {
    position: relative;
    aspect-ratio: 1;
    max-width: 320px;
    justify-self: end;
    border: 1px solid var(--radar-line);
    border-radius: 999px;
    background:
      radial-gradient(circle, transparent 0 22%, rgba(73, 242, 174, 0.06) 22.5% 23%, transparent 23.5% 47%, rgba(73, 242, 174, 0.08) 47.5% 48%, transparent 48.5%),
      rgba(7, 18, 15, 0.82);
    box-shadow: inset 0 0 48px rgba(73, 242, 174, 0.09), 0 18px 60px -36px rgba(73, 242, 174, 0.5);
    overflow: hidden;
  }

  .scope-axis,
  .scope-ring,
  .scope-sweep,
  .scope-blip {
    position: absolute;
  }

  .scope-axis {
    background: rgba(73, 242, 174, 0.16);
  }
  .scope-axis-x { left: 8%; right: 8%; top: 50%; height: 1px; }
  .scope-axis-y { top: 8%; bottom: 8%; left: 50%; width: 1px; }
  .scope-ring { inset: 11%; border: 1px solid rgba(73, 242, 174, 0.18); border-radius: 999px; }
  .scope-ring-2 { inset: 27%; }
  .scope-ring-3 { inset: 43%; }
  .scope-sweep {
    inset: 0;
    background: conic-gradient(from 15deg, rgba(73, 242, 174, 0.26), transparent 42deg);
    animation: radar-spin 5s linear infinite;
  }
  .scope-blip {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 16px var(--color-accent);
  }
  .blip-1 { left: 63%; top: 28%; }
  .blip-2 { left: 35%; top: 62%; background: var(--color-accent-2); box-shadow: 0 0 16px var(--color-accent-2); }
  .blip-3 { left: 72%; top: 69%; background: var(--radar-cyan); box-shadow: 0 0 16px var(--radar-cyan); }
  .blip-4 { left: 24%; top: 36%; background: var(--radar-red); box-shadow: 0 0 16px var(--radar-red); }
  .scope-readout {
    position: absolute;
    left: 50%;
    bottom: 13%;
    transform: translateX(-50%);
    display: grid;
    place-items: center;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
  }
  .scope-readout strong {
    color: var(--color-accent);
    font-size: 1.75rem;
    line-height: 1;
  }

  @keyframes radar-spin {
    to { transform: rotate(1turn); }
  }

  .radar-metrics {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.7rem;
    margin-top: 2rem;
  }

  .metric-tile,
  .radar-panel,
  .mission-console,
  .control-console,
  .competition-index-panel {
    border: 1px solid var(--radar-line);
    border-radius: 8px;
    background: linear-gradient(180deg, var(--radar-panel-strong), var(--radar-panel));
    box-shadow: 0 24px 70px -54px rgba(73, 242, 174, 0.45);
  }

  .metric-tile {
    padding: 0.95rem;
  }
  .metric-tile strong {
    display: block;
    margin: 0.15rem 0;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 1.9rem;
    line-height: 1;
  }
  .metric-tile span:last-child {
    color: var(--text-secondary);
    font-size: 0.78rem;
  }
  .metric-hot strong { color: var(--color-accent); }
  .metric-warn strong { color: var(--color-accent-2); }
  .metric-muted { opacity: 0.62; }

  .mission-console {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.75fr);
    gap: 1.2rem;
    padding: 1.15rem;
  }

  .mission-brief h2 {
    margin: 0.55rem 0 0.7rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    line-height: 1.25;
    letter-spacing: 0;
  }
  .mission-brief p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.8;
  }
  .mission-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .console-title-row,
  .block-heading,
  .panel-bar {
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .urgent-stack {
    display: grid;
    gap: 0.45rem;
  }

  .urgent-chip {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto;
    gap: 0.5rem;
    align-items: center;
    width: 100%;
    padding: 0.56rem 0.65rem;
    border-radius: 6px;
    border: 1px solid rgba(242, 199, 102, 0.28);
    background: rgba(242, 199, 102, 0.08);
    color: var(--text);
    text-align: left;
  }
  .urgent-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.82rem;
  }
  .urgent-meta,
  .urgent-badge {
    color: var(--color-accent-2);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    white-space: nowrap;
  }
  .urgent-badge {
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    background: var(--color-accent-2);
    color: #130e04;
    font-weight: 700;
  }

  .control-console {
    position: sticky;
    top: 4.25rem;
    z-index: 10;
    padding: 1rem;
  }
  .console-led {
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    margin-right: 0.35rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent);
  }
  .filter-rows {
    gap: 0.65rem;
  }
  .radar-control-grid {
    grid-template-columns: minmax(220px, 1.25fr) minmax(150px, 0.6fr) minmax(170px, 0.7fr);
    gap: 0.65rem;
  }
  .radar-input,
  .radar-select {
    min-height: 38px;
    border-radius: 6px;
    border-color: var(--radar-line);
    background: rgba(4, 14, 11, 0.82);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .radar-input:focus,
  .radar-select:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(73, 242, 174, 0.12);
  }
  .filter-row {
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: 0.75rem;
  }
  .filter-group {
    gap: 0.38rem;
  }
  .filter-chip {
    padding: 0.32rem 0.62rem;
    border-radius: 6px;
    border-color: var(--radar-line);
    background: rgba(8, 20, 16, 0.7);
    color: var(--text-secondary);
    font-size: 0.7rem;
  }
  .filter-chip.is-on {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-ink);
  }

  .radar-workbench {
    display: grid;
    grid-template-columns: minmax(300px, 0.38fr) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }
  .competition-index-panel {
    position: sticky;
    top: 11.7rem;
    padding: 0.85rem;
    max-height: calc(100vh - 12.5rem);
    overflow: hidden;
  }
  .competition-list-stack {
    display: grid;
    gap: 0.5rem;
    max-height: calc(100vh - 16rem);
    overflow-y: auto;
    padding-right: 0.25rem;
  }
  .cp-list-item {
    width: 100%;
    padding: 0.72rem;
    border-radius: 7px;
    border: 1px solid rgba(130, 174, 151, 0.18);
    background: rgba(7, 18, 15, 0.68);
    text-align: left;
    color: var(--text);
  }
  .cp-list-item:hover,
  .cp-list-item.is-active {
    border-color: var(--color-accent);
    background: rgba(73, 242, 174, 0.09);
    transform: none;
  }
  .cp-list-item[data-status="expired"] {
    opacity: 0.5;
  }
  .cp-list-item h4 {
    margin: 0.35rem 0 0.28rem;
    overflow: hidden;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.25;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cp-list-item p {
    display: -webkit-box;
    overflow: hidden;
    margin: 0.42rem 0 0.55rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.55;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .list-meta-line,
  .list-footer {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }
  .list-footer {
    justify-content: space-between;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(130, 174, 151, 0.16);
  }
  .list-footer strong {
    color: var(--color-accent);
    font-family: var(--font-mono);
  }
  .list-footer small {
    color: var(--text-muted);
  }

  .detail-panel {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }
  .detail-card,
  .signal-list,
  .action-console {
    padding: 1rem;
  }
  .detail-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 150px;
    gap: 1rem;
    align-items: start;
  }
  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.65rem;
  }
  .detail-title-zone h2 {
    color: var(--text);
    font-family: var(--font-body);
    font-size: clamp(1.3rem, 2.6vw, 2rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.22;
  }
  .detail-meta-grid {
    display: grid;
    gap: 0.4rem;
    margin-top: 0.8rem;
    color: var(--text-secondary);
    font-size: 0.78rem;
  }
  .detail-meta-grid span span {
    display: inline-block;
    width: 3.2rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }
  .match-console {
    display: grid;
    place-items: center;
    padding: 0.9rem 0.6rem;
    border: 1px solid rgba(73, 242, 174, 0.28);
    border-radius: 8px;
    background: rgba(73, 242, 174, 0.08);
    font-family: var(--font-mono);
  }
  .match-console span,
  .match-console small {
    color: var(--text-muted);
    font-size: 0.64rem;
    text-transform: uppercase;
  }
  .match-console strong {
    color: var(--color-accent);
    font-size: 2.25rem;
    line-height: 1;
  }

  .timeline-block,
  .intel-grid,
  .chip-section-grid {
    margin-top: 1.2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(130, 174, 151, 0.16);
  }
  .timeline-strip {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--timeline-count), minmax(118px, 1fr));
    gap: 0.4rem;
    overflow-x: auto;
    padding: 0.2rem 0 0.35rem;
  }
  .timeline-node {
    min-width: 0;
    padding-top: 0.2rem;
  }
  .timeline-node p {
    margin: 0.45rem 0 0.1rem;
    color: var(--text-secondary);
    font-size: 0.72rem;
    line-height: 1.35;
  }
  .timeline-node small {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }
  .timeline-dot {
    width: 0.62rem;
    height: 0.62rem;
    border: 1px solid #06100d;
    border-radius: 999px;
    background: var(--text-muted);
  }
  .timeline-dot.normal { background: var(--radar-cyan); box-shadow: 0 0 12px var(--radar-cyan); }
  .timeline-dot.critical { background: var(--color-accent-2); box-shadow: 0 0 14px var(--color-accent-2); }
  .timeline-dot.past { opacity: 0.42; }

  .intel-grid,
  .chip-section-grid,
  .pros-cons-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .intel-block p:last-child,
  .audience-block p:last-child {
    color: var(--text-secondary);
    font-size: 0.86rem;
    line-height: 1.75;
  }
  .intel-action p:last-child {
    color: var(--text);
  }
  .chip-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.36rem;
    margin-top: 0.55rem;
  }
  .reward-chip,
  .winning-chip {
    border-radius: 6px;
    padding: 0.28rem 0.52rem;
    font-size: 0.72rem;
    line-height: 1.45;
  }
  .reward-chip {
    color: var(--color-accent-2);
    border-color: rgba(242, 199, 102, 0.28);
    background: rgba(242, 199, 102, 0.08);
  }
  .winning-chip {
    color: var(--color-accent);
    border-color: rgba(73, 242, 174, 0.28);
    background: rgba(73, 242, 174, 0.08);
  }
  .signal-list ul {
    display: grid;
    gap: 0.45rem;
    margin-top: 0.7rem;
  }
  .signal-list li {
    display: grid;
    grid-template-columns: 0.45rem minmax(0, 1fr);
    gap: 0.55rem;
    color: var(--text-secondary);
    font-size: 0.82rem;
    line-height: 1.55;
  }
  .signal-list li span {
    width: 0.38rem;
    height: 0.38rem;
    margin-top: 0.47rem;
    border-radius: 999px;
    background: var(--color-accent);
  }
  .signal-list.negative li span {
    background: var(--radar-red);
  }
  .action-console {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
  }
  .detail-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.55rem;
  }
  .summary-button,
  .cta-button {
    min-height: 2.4rem;
    border-radius: 6px;
    padding: 0.6rem 0.9rem;
    font-size: 0.82rem;
  }
  .summary-button {
    border: 1px solid var(--radar-line);
    background: rgba(8, 20, 16, 0.72);
    color: var(--text);
  }
  .cta-button {
    background: var(--color-accent);
    color: var(--color-accent-ink);
  }
  .source-links {
    gap: 0.4rem;
  }
  .source-link {
    border-radius: 6px;
    border-color: var(--radar-line);
    background: rgba(8, 20, 16, 0.7);
  }
  .radar-footnote {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(130, 174, 151, 0.18);
    text-align: center;
  }

  .tier-tag {
    border-radius: 6px;
  }
  .status-dot {
    width: 0.45rem;
    height: 0.45rem;
  }
  .status-dot.status-urgent { background: var(--color-accent-2); }
  .status-dot.status-ongoing { background: var(--color-accent); }
  .status-dot.status-upcoming { background: var(--radar-cyan); }
  .status-dot.status-expired { background: var(--text-muted); }
  .dot-warn,
  .dot-danger {
    display: inline-block;
    width: 0.38rem;
    height: 0.38rem;
    margin-right: 0.18rem;
    border-radius: 999px;
  }
  .dot-warn { background: var(--color-accent-2); }
  .dot-danger { background: var(--radar-red); }
  .meta-dot {
    width: 0.2rem;
    height: 0.2rem;
    border-radius: 999px;
    background: var(--text-muted);
  }
  .empty-state {
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 1040px) {
    .hero-grid,
    .mission-console,
    .radar-workbench,
    .action-console {
      grid-template-columns: 1fr;
    }
    .radar-scope {
      justify-self: start;
      max-width: 250px;
    }
    .radar-metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .control-console,
    .competition-index-panel {
      position: relative;
      top: auto;
      max-height: none;
    }
    .competition-list-stack {
      max-height: none;
      overflow: visible;
    }
  }

  @media (max-width: 760px) {
    .radar-shell {
      padding-inline: 1rem;
    }
    .radar-hero {
      padding-top: 3rem;
    }
    .radar-meta-row,
    .console-title-row,
    .panel-bar,
    .block-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.28rem;
    }
    .radar-control-grid,
    .filter-row,
    .detail-header,
    .intel-grid,
    .chip-section-grid,
    .pros-cons-grid {
      grid-template-columns: 1fr;
    }
    .filter-group {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 0.15rem;
    }
    .filter-chip {
      flex: 0 0 auto;
      white-space: nowrap;
    }
    .urgent-chip {
      grid-template-columns: auto minmax(0, 1fr) auto;
    }
    .urgent-meta {
      display: none;
    }
    .detail-actions,
    .detail-actions > * {
      width: 100%;
    }
    .radar-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  (function () {
    const abortKey = '__competitionRadarAbort';
    const tierRank = { S: 3, A: 2, B: 1 };
    const statusRank = { urgent: 0, ongoing: 1, upcoming: 2, expired: 3 };

    function getAddressId() {
      const params = new URLSearchParams(window.location.search);
      const queryId = params.get('competition') || params.get('event');
      const hashId = window.location.hash ? decodeURIComponent(window.location.hash.slice(1)) : '';
      return queryId || hashId || '';
    }

    function setAddressId(id, mode) {
      if (!id || !window.history) return;
      const url = new URL(window.location.href);
      url.hash = encodeURIComponent(id);
      window.history[mode === 'replace' ? 'replaceState' : 'pushState']({}, '', url);
    }

    function initCompetitionRadar() {
      window[abortKey]?.abort();
      const controller = new AbortController();
      window[abortKey] = controller;
      const { signal } = controller;

      const items = Array.from(document.querySelectorAll('[data-id]'));
      const panels = Array.from(document.querySelectorAll('[data-detail]'));
      const countEl = document.getElementById('list-count');
      const searchEl = document.getElementById('radar-search');
      const statusEl = document.getElementById('radar-status');
      const sortEl = document.getElementById('radar-sort');
      const listEl = items[0]?.parentElement;
      if (!items.length || !listEl) return;

      const state = {
        cat: '全部',
        tier: '全部',
        status: '全部',
        search: '',
        sort: sortEl?.value || 'match-desc',
        selectedId: items.some(item => item.dataset.id === getAddressId()) ? getAddressId() : items[0].dataset.id,
      };

      function visibleItems() {
        return items.filter(item => !item.classList.contains('hidden'));
      }

      function compareItems(a, b) {
        const matchA = Number(a.dataset.match || 0);
        const matchB = Number(b.dataset.match || 0);
        const deadlineA = Date.parse(a.dataset.deadline || '9999-12-31');
        const deadlineB = Date.parse(b.dataset.deadline || '9999-12-31');
        if (state.sort === 'urgent-first') {
          return (statusRank[a.dataset.status] ?? 9) - (statusRank[b.dataset.status] ?? 9) || deadlineA - deadlineB || matchB - matchA;
        }
        if (state.sort === 'deadline-asc') {
          return deadlineA - deadlineB || matchB - matchA;
        }
        if (state.sort === 'tier-desc') {
          return (tierRank[b.dataset.tier] ?? 0) - (tierRank[a.dataset.tier] ?? 0) || matchB - matchA;
        }
        return matchB - matchA || deadlineA - deadlineB;
      }

      function applySort() {
        items.slice().sort(compareItems).forEach(item => listEl.appendChild(item));
      }

      function applySelect(options = {}) {
        const hasPanel = panels.some(panel => panel.dataset.detail === state.selectedId);
        panels.forEach(panel => panel.classList.toggle('hidden', panel.dataset.detail !== state.selectedId || !hasPanel));
        items.forEach(item => item.classList.toggle('is-active', item.dataset.id === state.selectedId));
        if (hasPanel && options.address) setAddressId(state.selectedId, options.address);
        if (hasPanel && options.scroll) {
          document.querySelector('[data-detail="' + CSS.escape(state.selectedId) + '"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }

      function applyFilter(options = {}) {
        const query = state.search.trim().toLowerCase();
        let visible = 0;
        items.forEach(item => {
          const haystack = (item.dataset.search || '').toLowerCase();
          const ok =
            (state.cat === '全部' || item.dataset.cat === state.cat) &&
            (state.tier === '全部' || item.dataset.tier === state.tier) &&
            (state.status === '全部' || item.dataset.status === state.status) &&
            (!query || haystack.includes(query));
          item.classList.toggle('hidden', !ok);
          if (ok) visible++;
        });
        if (countEl) countEl.textContent = visible + ' items';
        applySort();

        const current = items.find(item => item.dataset.id === state.selectedId);
        if (!current || current.classList.contains('hidden')) {
          state.selectedId = visibleItems()[0]?.dataset.id || '';
          applySelect({ address: state.selectedId ? 'replace' : '' });
          return;
        }
        applySelect(options);
      }

      function setChipState(selector, dataName, value) {
        document.querySelectorAll(selector).forEach(button => {
          button.classList.toggle('is-on', button.dataset[dataName] === value);
        });
      }

      async function copySummary(id, button) {
        const item = items.find(entry => entry.dataset.id === id) || items.find(entry => entry.dataset.id === state.selectedId);
        if (!item) return;
        const summary = [
          '赛事：' + (item.dataset.fullName || item.dataset.name || ''),
          '截止时间：' + (item.dataset.deadline || ''),
          '参赛打法：' + (item.dataset.strategy || ''),
          '官方链接：' + (item.dataset.url || ''),
          item.dataset.sources ? '参考来源：' + item.dataset.sources : '',
        ].filter(Boolean).join('\n');

        try {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(summary);
          } else {
            const textarea = document.createElement('textarea');
            textarea.value = summary;
            textarea.setAttribute('readonly', '');
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            textarea.remove();
          }
          const original = button.textContent;
          button.textContent = '已复制';
          button.classList.add('is-copied');
          window.setTimeout(() => {
            if (signal.aborted) return;
            button.textContent = original || '复制参赛摘要';
            button.classList.remove('is-copied');
          }, 1400);
        } catch {
          button.textContent = '复制失败';
          window.setTimeout(() => {
            if (signal.aborted) return;
            button.textContent = '复制参赛摘要';
          }, 1400);
        }
      }

      items.forEach(item => {
        item.addEventListener('click', () => {
          state.selectedId = item.dataset.id;
          applySelect({ address: 'push', scroll: window.innerWidth < 1024 });
        }, { signal });
      });

      document.querySelectorAll('.filter-cat').forEach(button => {
        button.addEventListener('click', () => {
          state.cat = button.dataset.fcat || '全部';
          setChipState('.filter-cat', 'fcat', state.cat);
          applyFilter({ address: 'replace' });
        }, { signal });
      });

      document.querySelectorAll('.filter-tier').forEach(button => {
        button.addEventListener('click', () => {
          state.tier = button.dataset.ftier || '全部';
          setChipState('.filter-tier', 'ftier', state.tier);
          applyFilter({ address: 'replace' });
        }, { signal });
      });

      searchEl?.addEventListener('input', () => {
        state.search = searchEl.value;
        applyFilter({ address: 'replace' });
      }, { signal });

      statusEl?.addEventListener('change', () => {
        state.status = statusEl.value;
        applyFilter({ address: 'replace' });
      }, { signal });

      sortEl?.addEventListener('change', () => {
        state.sort = sortEl.value;
        applyFilter({ address: 'replace' });
      }, { signal });

      document.querySelectorAll('[data-jump]').forEach(button => {
        button.addEventListener('click', () => {
          state.selectedId = button.dataset.jump;
          applySelect({ address: 'push', scroll: true });
        }, { signal });
      });

      document.querySelectorAll('[data-copy-summary]').forEach(button => {
        button.addEventListener('click', () => copySummary(button.dataset.copySummary, button), { signal });
      });

      window.addEventListener('hashchange', () => {
        const id = getAddressId();
        if (!items.some(item => item.dataset.id === id)) return;
        state.selectedId = id;
        applyFilter();
      }, { signal });

      applyFilter({ address: getAddressId() ? 'replace' : '' });
      if (getAddressId()) {
        window.setTimeout(() => {
          if (signal.aborted) return;
          document.querySelector('[data-detail="' + CSS.escape(state.selectedId) + '"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
      }
    }

    document.addEventListener('astro:page-load', initCompetitionRadar);
    initCompetitionRadar();
  })();
</script>
