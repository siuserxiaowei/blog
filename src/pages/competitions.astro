                      <span class="px-3 py-1 rounded-full text-xs font-bold bg-slate-100 text-slate-600">{c.cat}</span>
                    </div>
                    <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight leading-tight">{c.fullName}</h2>
                    <div class="flex flex-wrap gap-y-2 gap-x-6 text-sm font-bold text-slate-500">
                      <span>📍 {c.loc}</span>
                      <span>📅 {c.date}</span>
                      <span>🏛 {c.org}</span>
                    </div>
                  </div>
                  <div class="flex flex-col items-center justify-center bg-slate-900 rounded-[2rem] p-6 min-w-[140px] shadow-2xl">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.25em] mb-1">匹配度</span>
                    <span class="text-5xl font-black text-white leading-none">{c.match.toFixed(1)}</span>
                    <span class="text-xs text-slate-500 mt-1">/ 10.0</span>
                    <div class="w-12 h-1 bg-blue-500 mt-3 rounded-full"></div>
                    <span class="text-xs text-blue-300 font-bold mt-2">{c.suit}</span>
                  </div>
                </div>

                <!-- 时间轴 -->
                <h4 class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-[0.18em] mb-6">
                  <span class="w-1 h-5 bg-blue-600 rounded-full"></span>关键时间节点
                </h4>
                <div class="relative pt-6 pb-4 mb-8">
                  <div class="absolute top-1/2 left-0 right-0 h-1 bg-slate-100 rounded-full -translate-y-1/2"></div>
                  <div class="relative flex justify-between gap-2">
                    {c.timeline.map(n=>{
                      const past = new Date(n.date) < new Date('2026-04-21');
                      return (
                        <div class="flex flex-col items-center flex-1 min-w-0">
                          <div class:list={[
                            "w-5 h-5 rounded-full border-4 border-white shadow",
                            past && "bg-slate-300",
                            !past && n.critical && "bg-rose-500 ring-4 ring-rose-100 scale-125",
                            !past && !n.critical && "bg-blue-500 ring-4 ring-blue-100",
                          ]}></div>
                          <p class:list={["text-[11px] font-black text-center mt-3 mb-0.5", n.critical ? "text-slate-900" : "text-slate-400"]}>{n.event}</p>
                          <small class="text-[10px] font-mono text-slate-500">{n.date}</small>
                        </div>
                      );
                    })}
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                  <div>
                    <h4 class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-[0.18em] mb-3">
                      <span class="w-1 h-5 bg-blue-600 rounded-full"></span>赛事定位
                    </h4>
                    <p class="text-sm text-slate-600 leading-relaxed bg-slate-50 p-4 rounded-2xl border border-slate-100 font-medium">{c.desc}</p>
                  </div>
                  <div>
                    <h4 class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-[0.18em] mb-3">
                      <span class="w-1 h-5 bg-blue-600 rounded-full"></span>参赛打法
                    </h4>
                    <p class="text-sm text-blue-900 leading-relaxed bg-blue-50 p-4 rounded-2xl border border-blue-100 font-bold">{c.strategy}</p>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div>
                    <h4 class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-[0.18em] mb-3">
                      <span class="w-1 h-5 bg-blue-600 rounded-full"></span>核心奖励 / 资源
                    </h4>
                    <div class="flex flex-wrap gap-2">
                      {c.rewards.map(r=>(
                        <span class="text-xs font-bold bg-rose-50 text-rose-700 border border-rose-100 px-3 py-1.5 rounded-lg">{r}</span>
                      ))}
                    </div>
                  </div>
                  <div>
                    <h4 class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-[0.18em] mb-3">
                      <span class="w-1 h-5 bg-blue-600 rounded-full"></span>必胜卖点
                    </h4>
                    <div class="flex flex-wrap gap-2">
                      {c.winning.map(w=>(
                        <span class="text-[11px] font-bold bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full">{w}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <!-- 优势 / 难点 -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white rounded-[2rem] p-6 shadow-xl shadow-slate-200/50">
                  <h4 class="text-xs font-black text-emerald-600 uppercase tracking-[0.2em] mb-4">✓ 优势</h4>
                  <ul class="space-y-2">
                    {c.pros.map(p=>(
                      <li class="flex gap-2 text-sm font-bold text-slate-700"><span class="text-emerald-500">●</span>{p}</li>
                    ))}
                  </ul>
                </div>
                <div class="bg-white rounded-[2rem] p-6 shadow-xl shadow-slate-200/50">
                  <h4 class="text-xs font-black text-amber-600 uppercase tracking-[0.2em] mb-4">⚠ 难点 / 风险</h4>
                  <ul class="space-y-2">
                    {c.cons.map(p=>(
                      <li class="flex gap-2 text-sm font-bold text-slate-700"><span class="text-amber-500">●</span>{p}</li>
                    ))}
                  </ul>
                </div>
              </div>

              <a href={c.url} target="_blank" rel="noopener" class="block text-center bg-blue-600 hover:bg-blue-700 text-white font-black text-base py-5 rounded-[2rem] shadow-2xl shadow-blue-200/50 transition-all hover:-translate-y-1">
                访问官方报名页 →
              </a>
            </div>
          ))}
        </section>
      </div>

      <div class="text-center text-xs text-slate-400 pt-12 mt-12 border-t border-slate-200">数据更新于 2026-04-21 · 17 个赛事全部重新网络核验 · 带「参考上届」标签的届次尚未官方公告，请以主办方通知为准</div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  body:has(.cp-page-marker) { background:#f8fafc !important; }
  /* 选中态高亮（动态加 class，需要静态存在让 Tailwind 抓到） */
  .cp-list-item.is-active { border-color:#2563eb !important; box-shadow:0 20px 40px -20px rgba(37,99,235,.35); transform:translateY(-2px); }
  .cp-list-item.is-active h4 { color:#2563eb !important; }
</style>

<div class="cp-page-marker hidden"></div>

<script is:inline>
  (function(){
    let selectedId = document.querySelector('[data-id]')?.dataset.id;
    let fCat = '全部', fTier = '全部';

    const items = Array.from(document.querySelectorAll('[data-id]'));
    const panels = Array.from(document.querySelectorAll('[data-detail]'));
    const countEl = document.getElementById('list-count');

    function applySelect(){
      items.forEach(it => it.classList.toggle('is-active', it.dataset.id === selectedId));
      panels.forEach(p => p.classList.toggle('hidden', p.dataset.detail !== selectedId));
    }

    function applyFilter(){
      let visible = 0;
      items.forEach(it => {
        const ok = (fCat === '全部' || it.dataset.cat === fCat) && (fTier === '全部' || it.dataset.tier === fTier);
        it.classList.toggle('hidden', !ok);
        if (ok) visible++;
      });
      countEl.textContent = visible + ' 个项目';
      // 如果当前选中的被筛掉，自动选第一个可见项
      const cur = items.find(it => it.dataset.id === selectedId);
      if (cur && cur.classList.contains('hidden')) {
        const first = items.find(it => !it.classList.contains('hidden'));
        if (first) { selectedId = first.dataset.id; applySelect(); }
      }
    }

    items.forEach(it => it.addEventListener('click', () => { selectedId = it.dataset.id; applySelect(); }));

    document.querySelectorAll('.filter-cat').forEach(btn => {
      btn.addEventListener('click', () => {
        fCat = btn.dataset.fcat;
        document.querySelectorAll('.filter-cat').forEach(b => {
          const active = b.dataset.fcat === fCat;
          b.classList.toggle('bg-blue-600', active);
          b.classList.toggle('text-white', active);
          b.classList.toggle('bg-slate-100', !active);
          b.classList.toggle('text-slate-600', !active);
        });
        applyFilter();
      });
    });

    document.querySelectorAll('.filter-tier').forEach(btn => {
      btn.addEventListener('click', () => {
        fTier = btn.dataset.ftier;
        document.querySelectorAll('.filter-tier').forEach(b => {
          const active = b.dataset.ftier === fTier;
          b.classList.toggle('bg-blue-600', active);
          b.classList.toggle('text-white', active);
          b.classList.toggle('bg-slate-100', !active);
          b.classList.toggle('text-slate-600', !active);
        });
        applyFilter();
      });
    });

    document.querySelectorAll('[data-jump]').forEach(b => {
      b.addEventListener('click', () => {
        selectedId = b.dataset.jump;
        applySelect();
        document.querySelector('[data-detail="'+selectedId+'"]')?.scrollIntoView({behavior:'smooth',block:'start'});
      });
    });

    applySelect();
  })();
</script>
