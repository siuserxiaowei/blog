                  <h4 class="text-xs font-black text-emerald-600 uppercase tracking-[0.2em] mb-4">✓ 优势</h4>
                  <ul class="space-y-2">
                    {c.pros.map(p=>(
                      <li class="flex gap-2 text-sm font-bold text-slate-700"><span class="text-emerald-500">●</span>{p}</li>
                    ))}
                  </ul>
                </div>
                <div class="bg-white rounded-[2rem] p-6 shadow-xl shadow-slate-200/50">
                  <h4 class="text-xs font-black text-amber-600 uppercase tracking-[0.2em] mb-4">⚠ 难点 / 风险</h4>
                  <ul class="space-y-2">
                    {c.cons.map(p=>(
                      <li class="flex gap-2 text-sm font-bold text-slate-700"><span class="text-amber-500">●</span>{p}</li>
                    ))}
                  </ul>
                </div>
              </div>

              <a href={c.url} target="_blank" rel="noopener" class="block text-center bg-blue-600 hover:bg-blue-700 text-white font-black text-base py-5 rounded-[2rem] shadow-2xl shadow-blue-200/50 transition-all hover:-translate-y-1">
                访问官方报名页 →
              </a>
            </div>
          ))}
        </section>
      </div>

      <div class="text-center text-xs text-slate-400 pt-12 mt-12 border-t border-slate-200">数据更新于 2026-04-14 · 报名时间以主办方公告为准 · 团队内部决策参考</div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  body:has(.cp-page-marker) { background:#f8fafc !important; }
  /* 选中态高亮（动态加 class，需要静态存在让 Tailwind 抓到） */
  .cp-list-item.is-active { border-color:#2563eb !important; box-shadow:0 20px 40px -20px rgba(37,99,235,.35); transform:translateY(-2px); }
  .cp-list-item.is-active h4 { color:#2563eb !important; }
</style>

<div class="cp-page-marker hidden"></div>

<script is:inline>
  (function(){
    let selectedId = document.querySelector('[data-id]')?.dataset.id;
    let fCat = '全部', fTier = '全部';

    const items = Array.from(document.querySelectorAll('[data-id]'));
    const panels = Array.from(document.querySelectorAll('[data-detail]'));
    const countEl = document.getElementById('list-count');

    function applySelect(){
      items.forEach(it => it.classList.toggle('is-active', it.dataset.id === selectedId));
      panels.forEach(p => p.classList.toggle('hidden', p.dataset.detail !== selectedId));
    }

    function applyFilter(){
      let visible = 0;
      items.forEach(it => {
        const ok = (fCat === '全部' || it.dataset.cat === fCat) && (fTier === '全部' || it.dataset.tier === fTier);
        it.classList.toggle('hidden', !ok);
        if (ok) visible++;
      });
      countEl.textContent = visible + ' 个项目';
      // 如果当前选中的被筛掉，自动选第一个可见项
      const cur = items.find(it => it.dataset.id === selectedId);
      if (cur && cur.classList.contains('hidden')) {
        const first = items.find(it => !it.classList.contains('hidden'));
        if (first) { selectedId = first.dataset.id; applySelect(); }
      }
    }

    items.forEach(it => it.addEventListener('click', () => { selectedId = it.dataset.id; applySelect(); }));

    document.querySelectorAll('.filter-cat').forEach(btn => {
      btn.addEventListener('click', () => {
        fCat = btn.dataset.fcat;
        document.querySelectorAll('.filter-cat').forEach(b => {
          const active = b.dataset.fcat === fCat;
          b.classList.toggle('bg-blue-600', active);
          b.classList.toggle('text-white', active);
          b.classList.toggle('bg-slate-100', !active);
          b.classList.toggle('text-slate-600', !active);
        });
        applyFilter();
      });
    });

    document.querySelectorAll('.filter-tier').forEach(btn => {
      btn.addEventListener('click', () => {
        fTier = btn.dataset.ftier;
        document.querySelectorAll('.filter-tier').forEach(b => {
          const active = b.dataset.ftier === fTier;
          b.classList.toggle('bg-blue-600', active);
          b.classList.toggle('text-white', active);
          b.classList.toggle('bg-slate-100', !active);
          b.classList.toggle('text-slate-600', !active);
        });
        applyFilter();
      });
    });

    document.querySelectorAll('[data-jump]').forEach(b => {
      b.addEventListener('click', () => {
        selectedId = b.dataset.jump;
        applySelect();
        document.querySelector('[data-detail="'+selectedId+'"]')?.scrollIntoView({behavior:'smooth',block:'start'});
      });
    });

    applySelect();
  })();
</script>
