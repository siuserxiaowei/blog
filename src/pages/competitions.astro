---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { competitions, RADAR_UPDATED_AT, enrichCompetitions, getCompetitionCategories } from '../data/competitions.js';

const TODAY = new Date(RADAR_UPDATED_AT);
const enriched = enrichCompetitions(competitions, TODAY);
const expiredCount = enriched.filter(c => c.status.kind === 'expired').length;
const urgentCount = enriched.filter(c => c.status.kind === 'urgent').length;
const sCount = enriched.filter(c => c.tier === 'S').length;
const categories = getCompetitionCategories(enriched);
---

<BaseLayout title="AI 硬件赛事雷达 · siuser小伟" description="AI 硬件方案商的赛事与行业活动调研看板。">
  <Header />

  <main class="flex-1">

    <!-- Hero -->
    <section class="mx-auto px-6 pt-16 pb-10 md:pt-24" style="max-width: var(--container-max);">
      <div class="animate-fade-in stagger-1 flex items-center gap-3 mb-3">
        <p class="section-kicker">Competition Radar</p>
        <span class="text-[10px] tracking-wider" style="font-family: var(--font-mono); color: var(--text-secondary); opacity: 0.5;">// {RADAR_UPDATED_AT} · {enriched.length} items tracked</span>
      </div>
      <h1 class="animate-fade-in stagger-2 text-3xl md:text-5xl mb-4" style="font-family: var(--font-heading); color: var(--text);">
        AI 硬件 <span class="text-shimmer">赛事雷达</span>
      </h1>
      <p class="animate-fade-in stagger-3 text-base max-w-2xl leading-relaxed" style="color: var(--text-secondary);">
        面向 AI 硬件方案商和早期硬件创业团队的赛事与行业活动数据库。只看三件事：能不能拿订单、能不能上量、能不能拿政府 / 资本背书。
      </p>
      <div class="animate-fade-in stagger-3 divider-accent mt-6 mb-10"></div>

      <!-- 四指标 -->
      <div class="animate-fade-in stagger-4 grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        <div class="metric-tile p-5">
          <div class="text-[11px] uppercase tracking-[0.18em] mb-2" style="color: var(--text-secondary); font-family: var(--font-mono);">TOTAL</div>
          <div class="text-3xl font-semibold" style="color: var(--text); font-family: var(--font-heading);">{enriched.length}</div>
          <div class="mt-1 text-xs" style="color: var(--text-secondary);">赛事总数</div>
        </div>
        <div class="metric-tile p-5">
          <div class="text-[11px] uppercase tracking-[0.18em] mb-2" style="color: var(--text-secondary); font-family: var(--font-mono);">TIER·S</div>
          <div class="text-3xl font-semibold" style="color: var(--color-accent); font-family: var(--font-heading);">{sCount}</div>
          <div class="mt-1 text-xs" style="color: var(--text-secondary);">S 级强推</div>
        </div>
        <div class="metric-tile p-5 relative overflow-hidden">
          <div class="text-[11px] uppercase tracking-[0.18em] mb-2" style="color: var(--text-secondary); font-family: var(--font-mono);">URGENT</div>
          <div class="text-3xl font-semibold" style="color: var(--color-accent-2); font-family: var(--font-heading);">{urgentCount}</div>
          <div class="mt-1 text-xs" style="color: var(--text-secondary);">14 天内截止</div>
        </div>
        <div class="metric-tile p-5">
          <div class="text-[11px] uppercase tracking-[0.18em] mb-2" style="color: var(--text-secondary); font-family: var(--font-mono);">EXPIRED</div>
          <div class="text-3xl font-semibold line-through" style="color: var(--text-secondary); opacity: 0.55; font-family: var(--font-heading);">{expiredCount}</div>
          <div class="mt-1 text-xs" style="color: var(--text-secondary);">已过期</div>
        </div>
      </div>
    </section>

    <!-- 核心结论 -->
    <section class="mx-auto px-6 pb-10" style="max-width: var(--container-max);">
      <div class="animate-fade-in glass-card gradient-border p-7 md:p-10 grid grid-cols-1 md:grid-cols-[1.6fr_1fr] gap-8" style="border-radius: var(--radius-xl);">
        <div>
          <p class="section-kicker mb-4">// Priority Matrix</p>
          <h2 class="text-2xl md:text-4xl mb-5 leading-tight" style="font-family: var(--font-heading); color: var(--text); letter-spacing: -0.005em;">
            BEYOND HACK <span style="color: var(--text-secondary); font-weight: 400;">›</span> 鸿蒙 <span style="color: var(--text-secondary); font-weight: 400;">›</span> 创客中国 <span style="color: var(--text-secondary); font-weight: 400;">›</span> WAVES 决赛
          </h2>
          <p class="text-sm md:text-base leading-relaxed mb-6" style="color: var(--text-secondary);">
            <strong style="color: var(--color-accent);">4-30 三场刚刚截止</strong>：「星火」硬件创新大赛、WAIC OPC 先锋赛、36氪 <strong style="color: var(--color-accent);">WAVES 有智青年</strong>挑战赛（决赛 6 月）— 错过报名的盯 6 月 WAVES 决赛和下一轮。一周倒计时：<strong style="color: var(--color-accent);">BEYOND HACK（5-8）</strong>澳门极限开发 + 嘉立创百万奖池，<strong style="color: var(--color-accent);">HarmonyOS 极客赛道（5-15）</strong>奖池 68 万。中长线：创客中国第 11 届 7-10 截止，政策兑现最稳。
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="pill-note"><span class="dot-accent"></span>资本 · BEYOND HACK · 5-8</span>
            <span class="pill-note"><span class="dot-accent"></span>生态 · 鸿蒙 · 5-15</span>
            <span class="pill-note"><span class="dot-accent"></span>政策 · 创客中国 · 7-10</span>
            <span class="pill-note"><span class="dot-accent"></span>决赛 · WAVES · 6 月</span>
          </div>
        </div>

        <div class="border-t md:border-t-0 md:border-l pt-6 md:pt-0 md:pl-8" style="border-color: color-mix(in srgb, var(--border) 55%, transparent);">
          <p class="section-kicker mb-4">// 14 天紧急</p>
          {urgentCount > 0 ? (
            <ul class="space-y-2.5">
              {enriched.filter(c => c.status.kind === 'urgent').sort((a,b)=>a.status.days-b.status.days).map(c => (
                <li>
                  <button data-jump={c.id} class="urgent-chip group">
                    <span class="flex-1 text-sm font-medium truncate" style="color: var(--text);">{c.name}</span>
                    <span class="urgent-badge">{c.status.days}d</span>
                  </button>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm" style="color: var(--text-secondary);">14 天内暂无赛事截止。</p>
          )}
        </div>
      </div>
    </section>

    <!-- 筛选条 -->
    <section class="mx-auto px-6 pb-8" style="max-width: var(--container-max);">
      <div class="filter-rows">
        <div class="filter-row">
          <span class="section-kicker filter-label">// 分类</span>
          <div class="filter-group">
            <button data-fcat="全部" class="filter-cat filter-chip is-on">全部</button>
            {categories.map(cat => (
              <button data-fcat={cat} class="filter-cat filter-chip">{cat}</button>
            ))}
          </div>
        </div>
        <div class="filter-row">
          <span class="section-kicker filter-label">// 等级</span>
          <div class="filter-group">
            <button data-ftier="全部" class="filter-tier filter-chip is-on">全部</button>
            {['S','A','B'].map(t => (
              <button data-ftier={t} class="filter-tier filter-chip">{t} 级</button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 列表 + 详情 -->
    <section class="mx-auto px-6 pb-20" style="max-width: var(--container-max);">
      <div class="grid grid-cols-1 lg:grid-cols-[360px_1fr] gap-8 lg:gap-12">
        <!-- 左侧列表 -->
        <aside>
          <div class="flex items-center justify-between px-1 mb-3">
            <span class="section-kicker">// 列表</span>
            <span id="list-count" class="text-xs" style="color: var(--text-secondary); font-family: var(--font-mono);">{enriched.length} items</span>
          </div>
          <div class="space-y-5 lg:max-h-[1440px] lg:overflow-y-auto lg:pr-2">
            {enriched.map(c => (
              <button
                data-id={c.id}
                data-cat={c.cat}
                data-tier={c.tier}
                data-status={c.status.kind}
                data-match={c.match}
                class="cp-list-item w-full text-left p-4"
              >
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h4 class="text-base font-semibold leading-tight truncate" style="color: var(--text); font-family: var(--font-heading);">{c.name}</h4>
                  <span class={`tier-tag tier-${c.tier}`}>{c.tier}</span>
                </div>
                <div class="flex items-center gap-2 mb-2">
                  <span class={`status-dot status-${c.status.kind}`}></span>
                  <span class="text-[11px]" style="color: var(--text-secondary); font-family: var(--font-mono);">{c.status.label}</span>
                  <span class="text-[11px]" style="color: var(--text-secondary); opacity: 0.5;">·</span>
                  <span class="text-[11px]" style="color: var(--text-secondary);">{c.cat}</span>
                </div>
                <p class="text-xs leading-relaxed line-clamp-2 mb-3" style="color: var(--text-secondary);">{c.desc}</p>
                <div class="flex items-center justify-between pt-2 text-[11px]" style="border-top: 1px solid color-mix(in srgb, var(--border) 50%, transparent);">
                  <span style="color: var(--text-secondary); font-family: var(--font-mono); letter-spacing: 0.08em;">MATCH</span>
                  <span style="font-family: var(--font-heading); color: var(--color-accent); font-weight: 600; font-size: 14px;">{c.match.toFixed(1)}<span style="color: var(--text-secondary); font-size: 10px; font-weight: 400;"> / 10</span></span>
                </div>
              </button>
            ))}
          </div>
        </aside>

        <!-- 右侧详情 -->
        <section class="space-y-8">
          {enriched.map((c, i) => (
            <div data-detail={c.id} class:list={["detail-panel space-y-7", i !== 0 && "hidden"]}>

              <!-- 主卡 -->
              <div class="glass-card gradient-border p-7 md:p-11" style="border-radius: var(--radius-xl);">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-8">
                  <div class="flex-1 min-w-0 space-y-3">
                    <div class="flex flex-wrap items-center gap-2.5">
                      <span class={`tier-tag tier-${c.tier} tier-lg`}>{c.tier} 级</span>
                      <span class="pill-note"><span class={`status-dot status-${c.status.kind}`}></span>{c.status.label}</span>
                      <span class="pill-note">信用 {c.rel}</span>
                      <span class="pill-note">{c.cat}</span>
                    </div>
                    <h2 class="text-2xl md:text-3xl leading-tight" style="font-family: var(--font-heading); color: var(--text); letter-spacing: -0.022em;">{c.fullName}</h2>
                    <div class="flex flex-wrap gap-x-6 gap-y-1.5 text-sm" style="color: var(--text-secondary);">
                      <span class="flex items-center gap-1.5"><span class="opacity-50">◎</span>{c.loc}</span>
                      <span class="flex items-center gap-1.5"><span class="opacity-50">◷</span>{c.date}</span>
                      <span class="flex items-center gap-1.5"><span class="opacity-50">◆</span>{c.org}</span>
                    </div>
                  </div>

                  <div class="metric-tile px-5 py-4 flex flex-col items-center justify-center min-w-[120px]">
                    <span class="text-[10px] uppercase tracking-[0.2em]" style="color: var(--text-secondary); font-family: var(--font-mono);">Match</span>
                    <span class="text-5xl font-semibold leading-none mt-1" style="color: var(--color-accent); font-family: var(--font-heading);">{c.match.toFixed(1)}</span>
                    <span class="text-[10px] mt-1" style="color: var(--text-secondary);">/ 10</span>
                    <span class="text-[11px] mt-2 px-2 py-0.5 rounded-full" style="color: var(--color-accent-2); background: color-mix(in srgb, var(--color-accent-2) 12%, transparent);">{c.suit}</span>
                  </div>
                </div>

                <!-- 时间轴 -->
                <div class="mb-10">
                  <p class="section-kicker mb-5">// 关键时间节点</p>
                  <div class="relative pt-2">
                    <div class="absolute top-4 left-1.5 right-1.5 h-px" style="background: linear-gradient(90deg, color-mix(in srgb, var(--color-accent) 30%, transparent), color-mix(in srgb, var(--border) 80%, transparent) 55%, transparent);"></div>
                    <div class="relative grid gap-2" style={`grid-template-columns: repeat(${c.timeline.length}, minmax(0, 1fr));`}>
                      {c.timeline.map(n => {
                        const past = new Date(n.date) < TODAY;
                        const dotClass = past ? 'past' : n.critical ? 'critical' : 'normal';
                        return (
                          <div class="flex flex-col items-center text-center min-w-0 px-1">
                            <div class={`timeline-dot ${dotClass}`}></div>
                            <p class="mt-3 mb-1 text-[11px] font-medium leading-tight" style={`color: ${n.critical && !past ? 'var(--text)' : 'var(--text-secondary)'}; max-width: 100%;`}>{n.event}</p>
                            <small class="text-[10px]" style="color: var(--text-secondary); opacity: 0.6; font-family: var(--font-mono);">{n.date}</small>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                </div>

                <!-- 定位 / 打法 -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                  <div>
                    <p class="section-kicker mb-3">// 赛事定位</p>
                    <p class="text-sm leading-relaxed p-4 rounded-[14px]" style="color: var(--text-secondary); background: color-mix(in srgb, var(--surface) 55%, transparent); border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);">{c.desc}</p>
                  </div>
                  <div>
                    <p class="section-kicker mb-3">// 参赛打法</p>
                    <p class="text-sm leading-relaxed p-4 rounded-[14px]" style="color: var(--text); background: color-mix(in srgb, var(--color-accent) 7%, transparent); border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent);">{c.strategy}</p>
                  </div>
                </div>

                <!-- 奖励 / 卖点 -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-7">
                  <div>
                    <p class="section-kicker mb-3">// 核心奖励 / 资源</p>
                    <div class="flex flex-wrap gap-1.5">
                      {c.rewards.map(r => (
                        <span class="reward-chip">{r}</span>
                      ))}
                    </div>
                  </div>
                  <div>
                    <p class="section-kicker mb-3">// 必胜卖点</p>
                    <div class="flex flex-wrap gap-1.5">
                      {c.winning.map(w => (
                        <span class="winning-chip">{w}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <!-- 优势 / 难点 -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="glass-card p-6" style="border-radius: var(--radius-lg);">
                  <p class="section-kicker mb-3" style="color: var(--color-accent-2);">// + 优势</p>
                  <ul class="space-y-2">
                    {c.pros.map(p => (
                      <li class="flex gap-2.5 text-sm leading-relaxed" style="color: var(--text-secondary);"><span style="color: var(--color-accent-2); margin-top: 2px;">●</span><span>{p}</span></li>
                    ))}
                  </ul>
                </div>
                <div class="glass-card p-6" style="border-radius: var(--radius-lg);">
                  <p class="section-kicker mb-3" style="color: var(--color-accent);">// ! 难点 / 风险</p>
                  <ul class="space-y-2">
                    {c.cons.map(p => (
                      <li class="flex gap-2.5 text-sm leading-relaxed" style="color: var(--text-secondary);"><span style="color: var(--color-accent); margin-top: 2px;">●</span><span>{p}</span></li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- 受众 + CTA -->
              <div class="glass-card p-5 md:p-6 flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-6" style="border-radius: var(--radius-lg);">
                <div class="flex-1 min-w-0">
                  <p class="section-kicker mb-2">// 适合谁</p>
                  <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">{c.audience}</p>
                </div>
                <a href={c.url} target="_blank" rel="noopener" class="cta-button shrink-0">
                  访问官方报名页 <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          ))}
        </section>
      </div>

      <div class="text-center text-[11px] pt-12 mt-12 border-t" style="color: var(--text-secondary); border-color: color-mix(in srgb, var(--border) 50%, transparent); font-family: var(--font-mono); letter-spacing: 0.05em;">
        DATA UPDATED · {RADAR_UPDATED_AT} · {enriched.length} ENTRIES TRACKED · 带「参考上届」标签的届次尚未官方公告，请以主办方通知为准
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* ============ Filter rows ============ */
  .filter-rows {
    display: grid;
    gap: 1rem;
  }

  .filter-row {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr);
    align-items: center;
    gap: 1.25rem;
  }

  .filter-label {
    white-space: nowrap;
  }

  .filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  @media (max-width: 720px) {
    .filter-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  /* ============ 列表项 ============ */
  .cp-list-item {
    cursor: pointer;
    border-radius: var(--radius-lg);
    padding-block: 1.1rem !important;
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 90%, transparent), color-mix(in srgb, var(--surface-2) 82%, transparent));
    border: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: transform 0.24s cubic-bezier(.2,.7,.2,1), border-color 0.2s ease, box-shadow 0.24s ease, background 0.24s ease;
  }
  .cp-list-item:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--border));
    box-shadow: 0 18px 36px -28px color-mix(in srgb, var(--color-accent) 32%, transparent);
  }
  .cp-list-item.is-active {
    border-color: color-mix(in srgb, var(--color-accent) 70%, transparent) !important;
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 8%, var(--surface)), color-mix(in srgb, var(--surface-2) 85%, transparent));
    box-shadow: 0 22px 48px -30px color-mix(in srgb, var(--color-accent) 55%, transparent);
    transform: translateY(-1px);
  }
  .cp-list-item.is-active h4 { color: var(--color-accent) !important; }
  .cp-list-item[data-status="expired"] { opacity: 0.55; }

  /* ============ 等级标签 ============ */
  .tier-tag {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 10.5px; font-weight: 700; letter-spacing: 0.08em;
    font-family: var(--font-mono);
  }
  .tier-tag.tier-lg {
    padding: 4px 11px;
    font-size: 11px;
  }
  .tier-S {
    color: #1a130b;
    background: var(--color-accent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 60%, transparent), 0 0 16px -4px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  /* Dark ink on accent fills */
  .tier-S,
  .urgent-badge,
  .filter-chip.is-on,
  .cta-button {
    color: var(--color-accent-ink);
  }
  .tier-A {
    color: var(--color-accent-2);
    background: color-mix(in srgb, var(--color-accent-2) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent-2) 42%, transparent);
  }
  .tier-B {
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
  }

  /* ============ 状态点 ============ */
  .status-dot {
    display: inline-block; width: 7px; height: 7px; border-radius: 999px;
    flex-shrink: 0;
  }
  .status-dot.status-urgent {
    background: var(--color-accent);
    animation: status-pulse 1.8s infinite;
  }
  .status-dot.status-ongoing { background: var(--color-accent-2); }
  .status-dot.status-upcoming { background: color-mix(in srgb, var(--text-secondary) 70%, transparent); }
  .status-dot.status-expired { background: color-mix(in srgb, var(--text-secondary) 40%, transparent); }
  @keyframes status-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 65%, transparent); }
    70% { box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-accent) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 0%, transparent); }
  }

  /* ============ 紧急清单 chip ============ */
  .urgent-chip {
    display: flex; align-items: center; gap: 10px; width: 100%;
    padding: 10px 12px;
    text-align: left;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .urgent-chip:hover {
    border-color: color-mix(in srgb, var(--color-accent) 55%, var(--border));
    background: color-mix(in srgb, var(--color-accent) 6%, var(--surface));
    transform: translateX(2px);
  }
  .urgent-badge {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 999px;
    color: #1a130b;
    background: var(--color-accent);
  }

  .dot-accent, .dot-accent2 {
    display: inline-block; width: 6px; height: 6px; border-radius: 999px; margin-right: 2px;
  }
  .dot-accent { background: var(--color-accent); }
  .dot-accent2 { background: var(--color-accent-2); }

  /* ============ 时间轴点 ============ */
  .timeline-dot {
    width: 11px; height: 11px; border-radius: 999px;
    background: color-mix(in srgb, var(--text-secondary) 50%, transparent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--border) 80%, transparent);
    position: relative; z-index: 1;
  }
  .timeline-dot.past { background: color-mix(in srgb, var(--text-secondary) 40%, transparent); }
  .timeline-dot.normal {
    background: var(--color-accent-2);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent-2) 25%, transparent);
  }
  .timeline-dot.critical {
    background: var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 28%, transparent);
    transform: scale(1.2);
  }

  /* ============ 筛选按钮 ============ */
  .filter-chip {
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
  }
  .filter-chip:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--border));
  }
  .filter-chip.is-on {
    color: #1a130b;
    background: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 8px 20px -12px color-mix(in srgb, var(--color-accent) 70%, transparent);
  }

  /* ============ 奖励 / 卖点 chip ============ */
  .reward-chip {
    font-size: 12px; padding: 5px 10px;
    border-radius: var(--radius-md);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent);
    line-height: 1.5;
  }
  .winning-chip {
    font-size: 12px; padding: 5px 10px;
    border-radius: 999px;
    color: var(--color-accent-2);
    background: color-mix(in srgb, var(--color-accent-2) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent-2) 32%, transparent);
    line-height: 1.5;
  }

  /* ============ CTA ============ */
  .cta-button {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600; font-size: 14px;
    color: #1a130b;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
    box-shadow: 0 16px 28px -18px color-mix(in srgb, var(--color-accent) 52%, transparent);
    transition: transform 0.24s ease, box-shadow 0.24s ease;
  }
  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 36px -18px color-mix(in srgb, var(--color-accent) 62%, transparent);
  }

  /* ============ line-clamp ============ */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ============ 响应式微调 ============ */
  @media (max-width: 768px) {
    .cp-list-item { padding: 14px; }
    .urgent-chip { padding: 10px; }
  }
</style>

<script is:inline>
  (function () {
    const items = Array.from(document.querySelectorAll('[data-id]'));
    const panels = Array.from(document.querySelectorAll('[data-detail]'));
    const countEl = document.getElementById('list-count');
    let selectedId = items[0]?.dataset.id;
    let fCat = '全部', fTier = '全部';

    function applySelect() {
      items.forEach(it => it.classList.toggle('is-active', it.dataset.id === selectedId));
      panels.forEach(p => p.classList.toggle('hidden', p.dataset.detail !== selectedId));
    }

    function applyFilter() {
      let visible = 0;
      items.forEach(it => {
        const ok = (fCat === '全部' || it.dataset.cat === fCat) && (fTier === '全部' || it.dataset.tier === fTier);
        it.classList.toggle('hidden', !ok);
        if (ok) visible++;
      });
      if (countEl) countEl.textContent = visible + ' items';
      const cur = items.find(it => it.dataset.id === selectedId);
      if (cur && cur.classList.contains('hidden')) {
        const first = items.find(it => !it.classList.contains('hidden'));
        if (first) { selectedId = first.dataset.id; applySelect(); }
      }
    }

    items.forEach(it => it.addEventListener('click', () => {
      selectedId = it.dataset.id;
      applySelect();
      if (window.innerWidth < 1024) {
        const panel = document.querySelector('[data-detail="' + selectedId + '"]');
        panel?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }));

    document.querySelectorAll('.filter-cat').forEach(btn => {
      btn.addEventListener('click', () => {
        fCat = btn.dataset.fcat;
        document.querySelectorAll('.filter-cat').forEach(b => {
          b.classList.toggle('is-on', b.dataset.fcat === fCat);
        });
        applyFilter();
      });
    });

    document.querySelectorAll('.filter-tier').forEach(btn => {
      btn.addEventListener('click', () => {
        fTier = btn.dataset.ftier;
        document.querySelectorAll('.filter-tier').forEach(b => {
          b.classList.toggle('is-on', b.dataset.ftier === fTier);
        });
        applyFilter();
      });
    });

    document.querySelectorAll('[data-jump]').forEach(b => {
      b.addEventListener('click', () => {
        selectedId = b.dataset.jump;
        applySelect();
        document.querySelector('[data-detail="' + selectedId + '"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    applySelect();
  })();
</script>
