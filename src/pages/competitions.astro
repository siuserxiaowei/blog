  .cp-pc-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px; }
  @media (max-width:720px){ .cp-pc-grid { grid-template-columns:1fr; } }
  .cp-pc { background:#fff; border-radius:24px; padding:22px; box-shadow:0 12px 24px -16px rgba(0,0,0,.08); }
  .cp-pc h4 { font-size:11px; font-weight:900; letter-spacing:.18em; text-transform:uppercase; margin:0 0 14px; }
  .cp-pc.pros h4 { color:#059669; }
  .cp-pc.cons h4 { color:#d97706; }
  .cp-pc ul { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; }
  .cp-pc li { font-size:13px; font-weight:700; color:#334155; display:flex; gap:10px; }
  .cp-pc.pros li::before { content:'●'; color:#10b981; }
  .cp-pc.cons li::before { content:'●'; color:#f59e0b; }

  .cp-cta { display:block; text-align:center; background:var(--cp-blue); color:#fff; font-weight:900; font-size:16px; padding:22px; border-radius:24px; text-decoration:none; box-shadow:0 20px 40px -15px rgba(37,99,235,.4); transition:.2s; }
  .cp-cta:hover { background:var(--cp-blue-dark); transform:translateY(-2px); }

  .cp-foot { text-align:center; font-size:12px; color:#94a3b8; padding:48px 0 0; margin-top:48px; border-top:1px solid #e2e8f0; }
</style>

<script is:inline define:vars={{ dataJSON }}>
  const data = JSON.parse(dataJSON);
  const cats = ['全部', ...new Set(data.map(d => d.cat))];
  let fCat='全部', fTier='全部', selectedId=data[0].id;

  const tierBadge = (t)=>`<span class="cp-badge cp-bd-${t}">${t} 级</span>`;
  const statusBadge = (s)=>`<span class="cp-badge cp-st-${s.kind}">${s.label}</span>`;

  const urgentEl = document.getElementById('urgent-list');
  data.filter(d=>d.status.kind==='urgent').sort((a,b)=>a.status.days-b.status.days).forEach(d=>{
    const li = document.createElement('li');
    li.innerHTML = `<button data-jump="${d.id}">${d.name}</button><span>${d.status.days}d</span>`;
    urgentEl.appendChild(li);
  });
  urgentEl.querySelectorAll('button').forEach(b=>{
    b.onclick = ()=>{ selectedId = b.dataset.jump; render(); document.getElementById('comp-detail').scrollIntoView({behavior:'smooth',block:'start'}); };
  });

  function renderFilters(){
    const bar = document.getElementById('filter-bar'); bar.innerHTML = '';
    cats.forEach(c=>{
      const b = document.createElement('button');
      b.className = 'cp-chip'+(fCat===c?' active':'');
      b.textContent = c;
      b.onclick = ()=>{ fCat=c; render(); };
      bar.appendChild(b);
    });
    const sep = document.createElement('span'); sep.className='sep'; sep.textContent='|'; bar.appendChild(sep);
    ['全部','S','A','B'].forEach(t=>{
      const b = document.createElement('button');
      b.className = 'cp-chip'+(fTier===t?' active':'');
      b.textContent = t==='全部'?'全部等级':(t+' 级');
      b.onclick = ()=>{ fTier=t; render(); };
      bar.appendChild(b);
    });
  }

  function renderList(){
    const order = { urgent:0, ongoing:1, upcoming:2, expired:3 };
    const list = data.filter(d=>(fCat==='全部'||d.cat===fCat)&&(fTier==='全部'||d.tier===fTier))
      .sort((a,b)=>{ const so=order[a.status.kind]-order[b.status.kind]; return so!==0?so:b.match-a.match; });
    document.getElementById('list-count').textContent = `${list.length} 个项目`;
    const el = document.getElementById('comp-list'); el.innerHTML = '';
    list.forEach(d=>{
      const div = document.createElement('button');
      div.className = `cp-item ${selectedId===d.id?'active':''} ${d.status.kind==='expired'?'expired':''}`;
      div.innerHTML = `
        <div class="cp-item-row1">
          <div class="cp-item-name">${d.name}</div>
          ${tierBadge(d.tier)}
        </div>
        <div class="cp-item-row2">${statusBadge(d.status)}<span class="cp-badge cp-bd-cat">${d.cat}</span></div>
        <p class="cp-item-desc">${d.desc}</p>
        <div class="cp-item-bot">
          <span class="lbl">匹配度</span>
          <span class="val">${d.match.toFixed(1)} <small>/ 10</small></span>
        </div>
      `;
      div.onclick = ()=>{ selectedId=d.id; render(); };
      el.appendChild(div);
    });
  }

  function renderDetail(){
    const d = data.find(x=>x.id===selectedId) || data[0];
    const today = new Date('2026-04-14');
    const el = document.getElementById('comp-detail');
    el.innerHTML = `
      <div class="cp-card">
        <div class="cp-card-row">
          <div style="flex:1;min-width:280px;">
            <div class="cp-meta-row">
              ${tierBadge(d.tier)}
              ${statusBadge(d.status)}
              <span class="cp-badge cp-bd-rel">主办方信用 ${d.rel}</span>
              <span class="cp-badge cp-bd-cat">${d.cat}</span>
            </div>
            <h2 class="cp-fname">${d.fullName}</h2>
            <div class="cp-meta-info">
              <span>📍 ${d.loc}</span>
              <span>📅 ${d.date}</span>
              <span>🏛 ${d.org}</span>
            </div>
          </div>
          <div class="cp-score-box">
            <span class="lbl">匹配度</span>
            <span class="val">${d.match.toFixed(1)}</span>
            <span class="max">/ 10.0</span>
            <div class="bar"></div>
            <span class="suit">${d.suit}</span>
          </div>
        </div>

        <h4 class="cp-section-h">关键时间节点</h4>
        <div class="cp-timeline">
          <div class="cp-timeline-line"></div>
          <div class="cp-timeline-nodes">
            ${d.timeline.map(n=>{
              const past = new Date(n.date) < today;
              const cls = past ? '' : (n.critical ? 'critical' : 'upcoming');
              return `<div class="cp-tnode">
                <div class="cp-tdot ${cls}"></div>
                <p class="${n.critical?'crit':''}">${n.event}</p>
                <small>${n.date}</small>
              </div>`;
            }).join('')}
          </div>
        </div>

        <div class="cp-grid2">
          <div>
            <h4 class="cp-section-h">赛事定位</h4>
            <div class="cp-block"><p>${d.desc}</p></div>
          </div>
          <div>
            <h4 class="cp-section-h">参赛打法</h4>
            <div class="cp-block blue"><p>${d.strategy}</p></div>
          </div>
        </div>

        <div class="cp-grid2">
          <div>
            <h4 class="cp-section-h">核心奖励 / 资源</h4>
            <div class="cp-rewards">${d.rewards.map(r=>`<span class="cp-rwd">${r}</span>`).join('')}</div>
          </div>
          <div>
            <h4 class="cp-section-h">必胜卖点</h4>
            <div class="cp-wpoints">${d.winning.map(w=>`<span class="cp-wpoint">${w}</span>`).join('')}</div>
          </div>
        </div>
      </div>

      <div class="cp-pc-grid">
        <div class="cp-pc pros">
          <h4>✓ 优势</h4>
          <ul>${d.pros.map(p=>`<li>${p}</li>`).join('')}</ul>
        </div>
        <div class="cp-pc cons">
          <h4>⚠ 难点 / 风险</h4>
          <ul>${d.cons.map(p=>`<li>${p}</li>`).join('')}</ul>
        </div>
      </div>

      <a class="cp-cta" href="${d.url}" target="_blank" rel="noopener">访问官方报名页 →</a>
    `;
  }

  function render(){ renderFilters(); renderList(); renderDetail(); }
  render();
</script>
</BaseLayout>
