---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  showProgress?: boolean;
  ogImage?: string;
  ogType?: string;
}

const {
  title = 'siuser小伟 - 思考、创造、记录',
  description = '一个关于技术、思考与创造的个人空间',
  showProgress = false,
  ogImage = '',
  ogType = 'website'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:site_name" content="siuser小伟" />
  <meta property="og:locale" content="zh_CN" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="siuser小伟" href="/rss.xml" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "siuser小伟",
    "url": "https://siuserxiaowei.com",
    "description": "关于技术、思考与创造的个人博客",
    "author": {
      "@type": "Person",
      "name": "siuser小伟",
      "url": "https://siuserxiaowei.com"
    }
  })} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Latin fonts: Inter (body), Playfair Display (heading), JetBrains Mono (code/meta) -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <!-- CJK fonts: load async to prevent render blocking -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600&family=Noto+Serif+SC:wght@400;600;700&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Umami Analytics (privacy-friendly, no cookies) -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="xxx"></script>

  <!-- View Transitions -->
  <ClientRouter />

  <!-- Theme script (prevent flash) -->
  <script is:inline>
    const theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
  </script>

  <!-- Loading screen styles (inline to avoid FOUC) -->
  <style>
    /* ===== Loading Screen ===== */
    .loading-screen {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: var(--bg);
      transition: opacity 0.5s ease;
    }
    .loading-screen.loaded {
      opacity: 0;
      pointer-events: none;
    }

    /* Animated lines box */
    .loading-box {
      position: relative;
      width: 80px;
      height: 80px;
      margin-bottom: 2rem;
    }
    .loading-line {
      position: absolute;
      background: var(--color-accent);
    }
    /* Top line: slides right */
    .loading-line-1 {
      top: 0; left: 0;
      width: 0; height: 2px;
      animation: line-h 1.2s ease-in-out infinite;
    }
    /* Right line: slides down */
    .loading-line-2 {
      top: 0; right: 0;
      width: 2px; height: 0;
      animation: line-v 1.2s ease-in-out 0.3s infinite;
    }
    /* Bottom line: slides left */
    .loading-line-3 {
      bottom: 0; right: 0;
      width: 0; height: 2px;
      animation: line-h-rev 1.2s ease-in-out 0.6s infinite;
    }
    /* Left line: slides up */
    .loading-line-4 {
      bottom: 0; left: 0;
      width: 2px; height: 0;
      animation: line-v-rev 1.2s ease-in-out 0.9s infinite;
    }
    @keyframes line-h {
      0% { width: 0; left: 0; }
      50% { width: 100%; left: 0; }
      100% { width: 0; left: 100%; }
    }
    @keyframes line-v {
      0% { height: 0; top: 0; }
      50% { height: 100%; top: 0; }
      100% { height: 0; top: 100%; }
    }
    @keyframes line-h-rev {
      0% { width: 0; right: 0; }
      50% { width: 100%; right: 0; }
      100% { width: 0; right: 100%; }
    }
    @keyframes line-v-rev {
      0% { height: 0; bottom: 0; }
      50% { height: 100%; bottom: 0; }
      100% { height: 0; bottom: 100%; }
    }

    /* Center letter */
    .loading-letter {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-accent);
      animation: letter-pulse 1.2s ease-in-out infinite;
    }
    @keyframes letter-pulse {
      0%, 100% { opacity: 0.4; transform: scale(0.95); }
      50% { opacity: 1; transform: scale(1); }
    }

    /* Loading text with letter animation */
    .loading-text {
      font-family: var(--font-heading);
      font-size: 0.85rem;
      letter-spacing: 0.3em;
      color: var(--text-secondary);
      overflow: hidden;
    }
    .loading-text span {
      display: inline-block;
      opacity: 0;
      transform: translateY(8px);
      animation: letter-rise 0.4s ease forwards;
    }
  </style>
</head>
<body class="grain min-h-screen flex flex-col antialiased">

  <!-- ===== Loading Screen ===== -->
  <div class="loading-screen" id="loading-screen">
    <div class="loading-box">
      <div class="loading-line loading-line-1"></div>
      <div class="loading-line loading-line-2"></div>
      <div class="loading-line loading-line-3"></div>
      <div class="loading-line loading-line-4"></div>
      <div class="loading-letter">X</div>
    </div>
    <div class="loading-text" id="loading-text"></div>
  </div>

  <!-- ===== Reading Progress Bar ===== -->
  {showProgress && (
    <div id="progress-bar" class="fixed top-0 left-0 h-[2px] z-[99998] transition-[width] duration-75" style="width: 0%; background: var(--color-accent);"></div>
  )}

  <!-- ===== Particle Canvas ===== -->
  <canvas id="particles-canvas" class="fixed inset-0 pointer-events-none z-0"></canvas>

  <!-- ===== Page Content ===== -->
  <div class="relative z-10 page-content">
    <slot />
  </div>

  <!-- ===== Floating Dock (inspired by qianzhu.me) ===== -->
  <div class="floating-dock" id="floating-dock" style="opacity: 0; transition: opacity 0.4s ease;">
    <!-- Theme toggle -->
    <button class="dock-btn" onclick="toggleTheme()" aria-label="切换主题" id="dock-theme-btn">
      <svg class="w-5 h-5 dock-dark-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <svg class="w-5 h-5 dock-light-icon" style="display:none;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
      <span class="dock-tooltip">切换主题</span>
    </button>
    <!-- Tools -->
    <a href="/tools/wx2x" class="dock-btn" aria-label="工具箱">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
      </svg>
      <span class="dock-tooltip">工具箱</span>
    </a>
    <!-- Back to top -->
    <button class="dock-btn" id="dock-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="回到顶部" style="opacity:0; pointer-events:none; transition: opacity 0.3s ease;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
      <span class="dock-tooltip">回到顶部</span>
    </button>
  </div>

  <!-- ====== Scripts ====== -->

  <!-- Theme toggle -->
  <script is:inline>
    function toggleTheme() {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    }
    window.toggleTheme = toggleTheme;
  </script>

  <!-- Loading screen: letter-by-letter text + auto dismiss -->
  <script is:inline>
    (function() {
      const text = 'SIUSER BLOG';
      const el = document.getElementById('loading-text');
      if (el) {
        text.split('').forEach((ch, i) => {
          const span = document.createElement('span');
          span.textContent = ch === ' ' ? '\u00A0' : ch;
          span.style.animationDelay = (0.3 + i * 0.06) + 's';
          el.appendChild(span);
        });
      }

      let dismissed = false;
      function dismiss() {
        if (dismissed) return;
        dismissed = true;
        const ls = document.getElementById('loading-screen');
        if (ls) {
          ls.classList.add('loaded');
          setTimeout(() => { ls.style.display = 'none'; }, 600);
        }
      }

      // Dismiss after load + small delay, or force after 3s
      window.addEventListener('load', () => setTimeout(dismiss, 800));
      setTimeout(dismiss, 3000);
    })();
  </script>

  <!-- Floating Particles (performance-optimized) -->
  <script is:inline>
    (function() {
      const canvas = document.getElementById('particles-canvas');
      if (!canvas) return;

      // Skip on low-end devices (mobile with low memory or no pointer)
      const isMobile = window.matchMedia('(pointer: coarse)').matches;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduceMotion) { canvas.style.display = 'none'; return; }

      const ctx = canvas.getContext('2d');
      let particles = [];
      let w, h;
      let mouseX = -1000, mouseY = -1000;
      let animId = null;
      let isVisible = true;

      function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      if (!isMobile) {
        document.addEventListener('mousemove', e => { mouseX = e.clientX; mouseY = e.clientY; });
        document.addEventListener('mouseleave', () => { mouseX = -1000; mouseY = -1000; });
      }

      // Pause when tab is hidden
      document.addEventListener('visibilitychange', () => {
        isVisible = !document.hidden;
        if (isVisible && !animId) animate();
      });

      class Particle {
        constructor() { this.reset(); }
        reset() {
          this.x = Math.random() * w;
          this.y = Math.random() * h;
          this.size = Math.random() * 1.5 + 0.5;
          this.speedX = (Math.random() - 0.5) * 0.3;
          this.speedY = (Math.random() - 0.5) * 0.3;
          this.opacity = Math.random() * 0.3 + 0.1;
          this.fadeSpeed = Math.random() * 0.005 + 0.002;
          this.fadeDir = 1;
        }
        update() {
          if (!isMobile) {
            const dx = mouseX - this.x;
            const dy = mouseY - this.y;
            const distSq = dx * dx + dy * dy;
            if (distSq < 22500 && distSq > 0) { // 150^2
              const inv = 0.003;
              this.x += dx * inv;
              this.y += dy * inv;
            }
          }
          this.x += this.speedX;
          this.y += this.speedY;
          this.opacity += this.fadeSpeed * this.fadeDir;
          if (this.opacity >= 0.4) this.fadeDir = -1;
          if (this.opacity <= 0.05) this.fadeDir = 1;
          if (this.x < -10 || this.x > w + 10 || this.y < -10 || this.y > h + 10) this.reset();
        }
        draw() {
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(201, 169, 110, ${this.opacity})`;
          ctx.fill();
        }
      }

      // Fewer particles on mobile, more on desktop
      const maxCount = isMobile ? 15 : 40;
      const count = Math.min(maxCount, Math.floor(w * h / (isMobile ? 50000 : 25000)));
      for (let i = 0; i < count; i++) particles.push(new Particle());

      // Only draw lines on desktop (O(n^2) is expensive)
      function drawLines() {
        if (isMobile) return;
        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const distSq = dx * dx + dy * dy;
            if (distSq < 14400) { // 120^2
              const alpha = (1 - Math.sqrt(distSq) / 120) * 0.08;
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = `rgba(201, 169, 110, ${alpha})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }
      }

      function animate() {
        if (!isVisible) { animId = null; return; }
        ctx.clearRect(0, 0, w, h);
        particles.forEach(p => { p.update(); p.draw(); });
        drawLines();
        animId = requestAnimationFrame(animate);
      }
      animate();
    })();
  </script>

  <!-- Floating dock visibility + theme icons -->
  <script is:inline>
    (function() {
      const dock = document.getElementById('floating-dock');
      const topBtn = document.getElementById('dock-top-btn');
      if (!dock) return;

      // Show dock after scroll
      window.addEventListener('scroll', () => {
        dock.style.opacity = window.scrollY > 200 ? '1' : '0';
        if (topBtn) {
          const show = window.scrollY > 400;
          topBtn.style.opacity = show ? '1' : '0';
          topBtn.style.pointerEvents = show ? 'auto' : 'none';
        }
      });

      // Dock theme icons
      function updateDockIcons() {
        const theme = document.documentElement.getAttribute('data-theme');
        document.querySelectorAll('.dock-dark-icon').forEach(el => el.style.display = theme === 'dark' ? 'block' : 'none');
        document.querySelectorAll('.dock-light-icon').forEach(el => el.style.display = theme === 'light' ? 'block' : 'none');
      }
      updateDockIcons();
      const obs = new MutationObserver(updateDockIcons);
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    })();
  </script>

  <!-- Reading Progress -->
  <script is:inline>
    (function() {
      const bar = document.getElementById('progress-bar');
      if (!bar) return;
      window.addEventListener('scroll', () => {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + '%';
      });
    })();
  </script>

  <!-- Tab visibility easter egg (like iamyukino) -->
  <script is:inline>
    (function() {
      const originalTitle = document.title;
      document.addEventListener('visibilitychange', () => {
        document.title = document.hidden ? '(つ≧▽≦)つ 快回来~' : originalTitle;
      });
    })();
  </script>

  <!-- Re-init on View Transition page swap -->
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      // Re-apply theme
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);

      // Re-init scroll reveal
      const revealEls = document.querySelectorAll('.scroll-reveal:not(.revealed)');
      if (revealEls.length > 0) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        revealEls.forEach(el => obs.observe(el));
      }

      // Re-init floating dock visibility
      const dock = document.getElementById('floating-dock');
      if (dock) dock.style.opacity = window.scrollY > 200 ? '1' : '0';

      // Scroll to top on navigation
      window.scrollTo(0, 0);
    });
  </script>

</body>
</html>
