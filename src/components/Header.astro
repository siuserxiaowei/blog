---
import LangToggle from './LangToggle.astro';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const homeLinks = [
  { href: '#home', label: '首页' },
  { href: '#blog', label: '文章' },
  { href: '/tools', label: '工具箱' },
  { href: '/competitions', label: '比赛雷达' },
  { href: '/about', label: '关于' },
];

const pageLinks = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/tools', label: '工具箱' },
  { href: '/projects', label: '项目' },
  { href: '/competitions', label: '比赛雷达' },
  { href: '/about', label: '关于' },
];

const links = isHome ? homeLinks : pageLinks;
---

<header id="site-header" class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="siuser小伟 首页">
      <span class="brand-mark">SW</span>
      <span class="brand-copy">
        <span class="brand-name">siuser小伟</span>
        <span class="brand-sub">workbench / arsenal</span>
      </span>
    </a>

    <form id="site-search-form" class="header-search" role="search">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" />
      </svg>
      <input id="site-search" type="search" name="q" placeholder="搜索工具 / 文章 / 赛事" autocomplete="off" />
      <span class="search-keys" aria-hidden="true"><kbd>⌘</kbd><kbd>K</kbd></span>
    </form>

    <nav class="nav-links" aria-label="主导航">
      {links.map((link) => {
        const active = !isHome && (currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)));
        const isSection = link.href.startsWith('#');
        return (
          <a
            href={link.href}
            class:list={['nav-link', active && 'is-active']}
            data-nav-link={isSection ? link.href.slice(1) : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="header-actions">
      <LangToggle />
      <button id="theme-toggle" class="icon-btn theme-btn" type="button" aria-label="切换主题" title="切换主题">
        <span class="theme-glyph theme-sun">☀</span>
        <span class="theme-glyph theme-moon">◐</span>
      </button>
      <a class="icon-btn" href="https://github.com/siuserxiaowei" target="_blank" rel="noopener" aria-label="GitHub" title="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M12 .8a11.2 11.2 0 0 0-3.5 21.8c.6.1.8-.2.8-.6v-2.1c-3.3.7-4-1.4-4-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 .1.7 2.8 3.3 2 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C16.2 5 17.2 5.3 17.2 5.3c.6 1.6.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2V22c0 .4.2.7.8.6A11.2 11.2 0 0 0 12 .8Z" />
        </svg>
      </a>
      <a href="/admin/" class="admin-btn">Admin</a>
    </div>

    <button id="mobile-menu-btn" class="mobile-btn" type="button" aria-label="菜单" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu">
    <form id="mobile-search-form" class="mobile-search" role="search">
      <input id="mobile-site-search" type="search" name="q" placeholder="搜索工具 / 文章 / 赛事" autocomplete="off" />
    </form>
    <div class="mobile-links">
      {links.map((link) => <a href={link.href} class="mobile-link" data-mobile-link>{link.label}</a>)}
    </div>
    <div class="mobile-actions">
      <button id="mobile-theme-toggle" class="icon-btn" type="button" aria-label="切换主题">◐</button>
      <a href="https://github.com/siuserxiaowei" target="_blank" rel="noopener" class="admin-btn">GitHub</a>
      <a href="/admin/" class="admin-btn">Admin</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--border);
    background: var(--header-bg);
    backdrop-filter: saturate(150%) blur(14px);
    -webkit-backdrop-filter: saturate(150%) blur(14px);
  }

  .header-inner {
    max-width: var(--container-wide);
    min-height: 3.75rem;
    margin: 0 auto;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: auto minmax(14rem, 24rem) 1fr auto;
    align-items: center;
    gap: 0.75rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    color: var(--text);
  }

  .brand-mark {
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--color-accent) 42%, var(--border));
    border-radius: var(--radius-md);
    background: var(--surface-inset);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .brand-name {
    font-size: 0.98rem;
    font-weight: 700;
  }

  .brand-sub {
    margin-top: 0.18rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .header-search,
  .mobile-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 2.3rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface-inset);
    padding: 0 0.55rem;
    color: var(--text-muted);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
  }

  .header-search:focus-within,
  .mobile-search:focus-within {
    border-color: color-mix(in srgb, var(--color-accent) 64%, var(--border));
    box-shadow: var(--focus-ring);
  }

  .header-search svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }

  .header-search input,
  .mobile-search input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--text);
    font-size: 0.86rem;
  }

  .header-search input::placeholder,
  .mobile-search input::placeholder {
    color: var(--text-faint);
  }

  .search-keys {
    display: inline-flex;
    gap: 0.22rem;
  }

  .nav-links {
    display: flex;
    justify-content: flex-end;
    gap: 0.15rem;
    min-width: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0 0.62rem;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 0.86rem;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.is-active {
    background: var(--surface);
    color: var(--text);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .icon-btn,
  .admin-btn {
    height: 2.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
  }

  .icon-btn {
    width: 2.3rem;
    position: relative;
  }

  .icon-btn svg {
    width: 1.02rem;
    height: 1.02rem;
  }

  .admin-btn {
    padding: 0 0.75rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 600;
  }

  .icon-btn:hover,
  .admin-btn:hover {
    border-color: var(--border-strong);
    background: var(--surface-hover);
    color: var(--text);
  }

  .theme-glyph {
    position: absolute;
    line-height: 1;
    transition: opacity 0.18s ease;
  }

  .theme-sun { opacity: 0; }
  :root[data-theme="light"] .theme-sun { opacity: 1; }
  :root[data-theme="light"] .theme-moon { opacity: 0; }

  .mobile-btn {
    display: none;
    width: 2.3rem;
    height: 2.3rem;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .mobile-btn span {
    display: block;
    width: 1rem;
    height: 1px;
    background: var(--text);
    transition: transform 0.18s ease;
  }

  .mobile-btn span + span {
    margin-top: 0.34rem;
  }

  .mobile-menu {
    display: none;
    max-height: 0;
    overflow: hidden;
    border-top: 1px solid transparent;
    padding: 0 1rem;
    transition: max-height 0.2s ease, border-color 0.2s ease, padding-bottom 0.2s ease;
  }

  .mobile-menu.is-open {
    border-top-color: var(--border);
    padding-bottom: 1rem;
  }

  .mobile-search {
    margin-top: 1rem;
  }

  .mobile-links {
    display: grid;
    gap: 0.2rem;
    padding: 0.75rem 0;
  }

  .mobile-link {
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
  }

  .mobile-actions {
    display: flex;
    gap: 0.5rem;
  }

  .mobile-actions .admin-btn {
    flex: 1;
  }

  @media (max-width: 1120px) {
    .header-inner {
      grid-template-columns: auto minmax(12rem, 1fr) auto;
    }

    .nav-links {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .header-inner {
      min-height: 3.45rem;
      grid-template-columns: auto 1fr auto;
    }

    .brand-sub,
    .header-search,
    .header-actions {
      display: none;
    }

    .mobile-btn {
      display: grid;
    }

    .mobile-menu {
      display: block;
    }
  }
</style>

<script is:inline>
  (() => {
    const pageSearchSelector = '#tool-search, #search-input, #radar-search, #resource-search';

    const focusSearch = () => {
      const input = document.querySelector(pageSearchSelector) || document.getElementById('site-search') || document.getElementById('mobile-site-search');
      input?.focus();
      input?.select?.();
    };

    const runSearch = (query) => {
      const pageInput = document.querySelector(pageSearchSelector);
      if (pageInput && query) {
        pageInput.value = query;
        pageInput.dispatchEvent(new Event('input', { bubbles: true }));
        focusSearch();
        return;
      }
      window.location.href = `/tools${query ? `?q=${encodeURIComponent(query)}` : ''}#tool-search`;
    };

    const bindHeader = () => {
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const themeBtn = document.getElementById('theme-toggle');
      const mobileThemeBtn = document.getElementById('mobile-theme-toggle');

      document.querySelectorAll('#site-search-form, #mobile-search-form').forEach((form) => {
        if (form.dataset.bound) return;
        form.dataset.bound = 'true';
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          const input = form.querySelector('input');
          runSearch((input?.value || '').trim());
        });
      });

      if (themeBtn && !themeBtn.dataset.bound) {
        themeBtn.dataset.bound = 'true';
        themeBtn.addEventListener('click', () => window.toggleTheme?.());
      }

      if (mobileThemeBtn && !mobileThemeBtn.dataset.bound) {
        mobileThemeBtn.dataset.bound = 'true';
        mobileThemeBtn.addEventListener('click', () => window.toggleTheme?.());
      }

      if (mobileBtn && mobileMenu && !mobileBtn.dataset.bound) {
        mobileBtn.dataset.bound = 'true';
        mobileBtn.addEventListener('click', () => {
          const expanded = mobileBtn.getAttribute('aria-expanded') === 'true';
          mobileBtn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          mobileMenu.classList.toggle('is-open', !expanded);
          mobileMenu.style.maxHeight = expanded ? '0' : `${mobileMenu.scrollHeight + 12}px`;
        });
      }

      document.querySelectorAll('[data-mobile-link]').forEach((link) => {
        if (link.dataset.bound) return;
        link.dataset.bound = 'true';
        link.addEventListener('click', () => {
          mobileBtn?.setAttribute('aria-expanded', 'false');
          mobileMenu?.classList.remove('is-open');
          if (mobileMenu) mobileMenu.style.maxHeight = '0';
        });
      });

      const query = new URLSearchParams(window.location.search).get('q');
      const toolsSearch = document.getElementById('tool-search');
      if (query && toolsSearch && !toolsSearch.value) {
        toolsSearch.value = query;
        toolsSearch.dispatchEvent(new Event('input', { bubbles: true }));
      }
    };

    if (!window.__siteSearchKeysBound) {
      window.__siteSearchKeysBound = true;
      window.addEventListener('keydown', (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
          event.preventDefault();
          focusSearch();
        }
      });
    }

    bindHeader();
    document.addEventListener('astro:page-load', bindHeader);
  })();
</script>
