---
import LangToggle from './LangToggle.astro';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const homeLinks = [
  { href: '#home', label: '首页' },
  { href: '#about', label: '关于' },
  { href: '#blog', label: '文章' },
  { href: '/competitions', label: '比赛雷达' },
  { href: '/tools', label: '工具箱' },
  { href: '#contact', label: '联系' },
];

const pageLinks = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/projects', label: '项目' },
  { href: '/competitions', label: '比赛雷达' },
  { href: '/tools', label: '工具箱' },
  { href: '/about', label: '关于' },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto px-5 pt-4 md:px-6" style="max-width: calc(var(--container-max) + 2rem);">
    <nav id="site-nav" class="header-shell flex items-center justify-between gap-4 rounded-[24px] px-4 py-3 md:px-5">
      <a href="/" class="flex items-center gap-3">
        <span class="brand-mark">SW</span>
        <span class="leading-none">
          <span class="block brand-title">siuser小伟</span>
          <span class="brand-subtitle">open workbench · updated in public</span>
        </span>
      </a>

      <div class="header-links-shell hidden lg:flex items-center gap-1 rounded-full px-2 py-1">
        {(isHome ? homeLinks : pageLinks).map((link) => {
          const active = !isHome && (currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)));
          const isSection = link.href.startsWith('#');

          return (
            <a
              href={link.href}
              class:list={[
                'header-link',
                active && 'is-active'
              ]}
              data-nav-link={isSection ? link.href.slice(1) : undefined}
            >
              {link.label}
            </a>
          );
        })}
      </div>

      <div class="hidden md:flex items-center gap-2">
        <LangToggle />
        <button id="theme-toggle" class="header-action-btn" type="button" aria-label="切换主题" title="切换主题">
          <span class="theme-icon theme-light">☼</span>
          <span class="theme-icon theme-dark">◐</span>
        </button>
        <a href="/admin/" class="header-cta" aria-label="写文章">
          Publish
        </a>
      </div>

      <button id="mobile-menu-btn" class="mobile-menu-btn md:hidden" type="button" aria-label="菜单" aria-expanded="false">
        <span></span>
        <span></span>
      </button>
    </nav>

    <div id="mobile-menu" class="mobile-menu md:hidden">
      <div class="mobile-menu-inner">
        {(isHome ? homeLinks : pageLinks).map((link) => (
          <a href={link.href} class="mobile-link" data-mobile-link>{link.label}</a>
        ))}
        <div class="mobile-actions">
          <button id="mobile-theme-toggle" class="header-action-btn" type="button" aria-label="切换主题">
            主题
          </button>
          <a href="/admin/" class="header-cta">Publish</a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .header-shell {
    border: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 84%, transparent), color-mix(in srgb, var(--surface-2) 92%, transparent));
    box-shadow: 0 18px 42px -32px rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition: padding 0.24s ease, background-color 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
  }

  .header-links-shell {
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background: color-mix(in srgb, var(--surface-2) 60%, transparent);
  }

  .brand-mark {
    width: 2.45rem;
    height: 2.45rem;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: color-mix(in srgb, var(--surface-2) 88%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, var(--border));
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .brand-title {
    color: var(--text);
    font-family: var(--font-heading);
    font-size: 1.22rem;
    letter-spacing: -0.025em;
  }

  .brand-subtitle {
    display: block;
    margin-top: 0.15rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .header-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.95rem;
    padding: 0.66rem 0.82rem;
    border-radius: 999px;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .header-link:hover,
  .header-link.is-active {
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 90%, transparent);
  }

  .header-action-btn,
  .header-cta {
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    background: color-mix(in srgb, var(--surface) 84%, transparent);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .header-action-btn {
    width: 2.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 4.8rem;
    padding: 0 1rem;
    color: #111;
    border-color: transparent;
    background: linear-gradient(135deg, var(--color-accent), color-mix(in srgb, var(--color-accent) 76%, white 24%));
  }

  .header-action-btn:hover,
  .header-cta:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--color-accent) 44%, var(--border));
    transform: translateY(-1px);
  }

  .header-cta:hover {
    color: #111;
    border-color: transparent;
  }

  .theme-icon {
    position: absolute;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .theme-light {
    opacity: 1;
    transform: scale(1);
  }

  .theme-dark {
    opacity: 0;
    transform: scale(0.8);
  }

  #theme-toggle {
    position: relative;
  }

  .mobile-menu-btn {
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    background: color-mix(in srgb, var(--surface) 84%, transparent);
    display: grid;
    place-items: center;
    padding: 0;
  }

  .mobile-menu-btn span {
    display: block;
    width: 1rem;
    height: 1px;
    background: var(--text);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mobile-menu-btn span + span {
    margin-top: 0.3rem;
  }

  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.28s ease;
  }

  .mobile-menu-inner {
    margin-top: 0.75rem;
    border-radius: 24px;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 92%, transparent), color-mix(in srgb, var(--surface-2) 92%, transparent));
    box-shadow: var(--shadow-card);
  }

  .mobile-link {
    display: block;
    padding: 0.8rem 0.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 52%, transparent);
  }

  .mobile-link:last-of-type {
    border-bottom: none;
  }

  .mobile-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .mobile-actions .header-action-btn,
  .mobile-actions .header-cta {
    flex: 1;
  }

  @media (max-width: 767px) {
    .brand-subtitle {
      display: none;
    }

    .brand-title {
      font-size: 1.08rem;
    }
  }
</style>

<script is:inline>
  (() => {
    const header = document.getElementById('site-nav');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const themeBtn = document.getElementById('theme-toggle');
    const mobileThemeBtn = document.getElementById('mobile-theme-toggle');
    const lightIcon = themeBtn?.querySelector('.theme-light');
    const darkIcon = themeBtn?.querySelector('.theme-dark');
    const sectionLinks = Array.from(document.querySelectorAll('[data-nav-link]'));

    const updateThemeButton = (theme) => {
      if (!lightIcon || !darkIcon) return;
      lightIcon.style.opacity = theme === 'dark' ? '1' : '0';
      lightIcon.style.transform = theme === 'dark' ? 'scale(1)' : 'scale(0.8)';
      darkIcon.style.opacity = theme === 'light' ? '1' : '0';
      darkIcon.style.transform = theme === 'light' ? 'scale(1)' : 'scale(0.8)';
    };

    const syncHeader = () => {
      if (!header) return;
      const compact = window.scrollY > 24;
      header.style.paddingTop = compact ? '0.65rem' : '';
      header.style.paddingBottom = compact ? '0.65rem' : '';
      header.style.background = compact
        ? 'color-mix(in srgb, var(--surface) 84%, transparent)'
        : 'color-mix(in srgb, var(--surface) 76%, transparent)';
      header.style.borderColor = compact
        ? 'color-mix(in srgb, var(--color-accent) 24%, var(--border))'
        : 'color-mix(in srgb, var(--border) 82%, transparent)';
    };

    const closeMenu = () => {
      if (!mobileMenu || !mobileBtn) return;
      mobileMenu.style.maxHeight = '0';
      mobileBtn.setAttribute('aria-expanded', 'false');
      mobileBtn.classList.remove('is-open');
      const lines = mobileBtn.querySelectorAll('span');
      if (lines.length === 2) {
        lines[0].style.transform = 'none';
        lines[1].style.transform = 'none';
        lines[1].style.opacity = '1';
      }
    };

    themeBtn?.addEventListener('click', () => window.toggleTheme?.());
    mobileThemeBtn?.addEventListener('click', () => window.toggleTheme?.());

    window.addEventListener('themechange', (event) => updateThemeButton(event.detail));
    updateThemeButton(document.documentElement.getAttribute('data-theme') || 'dark');

    window.addEventListener('scroll', syncHeader, { passive: true });
    syncHeader();

    mobileBtn?.addEventListener('click', () => {
      if (!mobileMenu || !mobileBtn) return;
      const expanded = mobileBtn.getAttribute('aria-expanded') === 'true';
      mobileBtn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      mobileMenu.style.maxHeight = expanded ? '0' : `${mobileMenu.scrollHeight + 24}px`;
      const lines = mobileBtn.querySelectorAll('span');
      if (lines.length === 2) {
        lines[0].style.transform = expanded ? 'none' : 'translateY(4px) rotate(45deg)';
        lines[1].style.transform = expanded ? 'none' : 'translateY(-4px) rotate(-45deg)';
        lines[1].style.opacity = expanded ? '1' : '1';
      }
    });

    document.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (event) => {
        const targetId = anchor.getAttribute('href');
        if (!targetId || targetId === '#') return;
        const target = document.querySelector(targetId);
        if (!target) return;
        event.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        closeMenu();
      });
    });

    if (sectionLinks.length > 0) {
      const sections = Array.from(document.querySelectorAll('section[id]'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          sectionLinks.forEach((link) => {
            link.classList.toggle('is-active', link.getAttribute('data-nav-link') === entry.target.id);
          });
        });
      }, { rootMargin: '-35% 0px -50% 0px', threshold: 0 });

      sections.forEach((section) => observer.observe(section));
    }

    document.addEventListener('astro:page-load', closeMenu);
  })();
</script>
