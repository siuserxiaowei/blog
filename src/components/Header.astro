---
import LangToggle from './LangToggle.astro';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const homeLinks = [
  { href: '#home', label: '首页' },
  { href: '#blog', label: '文章' },
  { href: '/competitions', label: '比赛雷达' },
  { href: '/tools', label: '工具箱' },
  { href: '/about', label: '关于' },
  { href: '#contact', label: '联系' },
];

const pageLinks = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/projects', label: '项目' },
  { href: '/competitions', label: '比赛雷达' },
  { href: '/tools', label: '工具箱' },
  { href: '/about', label: '关于' },
];
---

<header id="site-header" class="site-header">
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="brand-mark">SW</span>
      <span class="brand-text">
        <span class="brand-name">siuser小伟</span>
        <span class="brand-sub">open workbench · updated in public</span>
      </span>
    </a>

    <nav class="nav-links hidden lg:flex">
      {(isHome ? homeLinks : pageLinks).map((link) => {
        const active = !isHome && (currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)));
        const isSection = link.href.startsWith('#');
        return (
          <a
            href={link.href}
            class:list={['nav-link', active && 'is-active']}
            data-nav-link={isSection ? link.href.slice(1) : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="header-actions hidden md:flex">
      <form id="site-search-form" class="site-search" role="search" aria-label="站内搜索">
        <input id="site-search-input" type="search" name="q" placeholder="搜索站内..." autocomplete="off" />
        <kbd>⌘K</kbd>
      </form>
      <LangToggle />
      <button id="theme-toggle" class="icon-btn" type="button" aria-label="切换主题" title="切换主题">
        <span class="theme-icon theme-light">☼</span>
        <span class="theme-icon theme-dark">◐</span>
      </button>
      <a href="/admin/" class="cta-btn" aria-label="写文章">Publish</a>
    </div>

    <button id="mobile-menu-btn" class="mobile-btn md:hidden" type="button" aria-label="菜单" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu md:hidden">
    <div class="mobile-inner">
      <form id="mobile-site-search-form" class="mobile-site-search" role="search" aria-label="站内搜索">
        <input id="mobile-site-search-input" type="search" name="q" placeholder="搜索工具、文章、比赛..." autocomplete="off" />
      </form>
      {(isHome ? homeLinks : pageLinks).map((link) => (
        <a href={link.href} class="mobile-link" data-mobile-link>{link.label}</a>
      ))}
      <div class="mobile-actions">
        <button id="mobile-theme-toggle" class="icon-btn" type="button" aria-label="切换主题">主题</button>
        <a href="/admin/" class="cta-btn">Publish</a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    border-bottom: 1px solid var(--border);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
    color: var(--text);
  }

  .brand-mark {
    width: 2.1rem;
    height: 2.1rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    line-height: 1.1;
  }

  .brand-name {
    color: var(--text);
    font-family: var(--font-heading);
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .brand-sub {
    margin-top: 0.2rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--text);
    background: var(--surface);
  }

  .header-actions {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }

  .site-search {
    display: none;
    align-items: center;
    gap: 0.5rem;
    height: 2.25rem;
    min-width: 12rem;
    padding: 0 0.55rem 0 0.8rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 72%, transparent);
  }

  .site-search input,
  .mobile-site-search input {
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
  }

  .site-search input {
    width: 8.5rem;
    font-size: 0.84rem;
  }

  .site-search input::placeholder,
  .mobile-site-search input::placeholder {
    color: var(--text-muted);
  }

  .site-search kbd {
    flex: 0 0 auto;
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1.2;
  }

  .site-search:focus-within {
    border-color: var(--border-strong);
  }

  .icon-btn {
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-secondary);
    transition: color 0.15s ease, border-color 0.15s ease;
    position: relative;
    cursor: pointer;
  }

  .icon-btn:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    height: 2.25rem;
    padding: 0 0.9rem;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: var(--color-accent-ink);
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.15s ease;
  }

  .cta-btn:hover {
    background: var(--color-accent-hover);
    color: var(--color-accent-ink);
  }

  .theme-icon {
    position: absolute;
    transition: opacity 0.2s ease;
  }

  .theme-dark { opacity: 0; }
  :root[data-theme="light"] .theme-light { opacity: 0; }
  :root[data-theme="light"] .theme-dark { opacity: 1; }

  .mobile-btn {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    display: grid;
    place-items: center;
  }

  .mobile-btn span {
    display: block;
    width: 0.95rem;
    height: 1px;
    background: var(--text);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mobile-btn span + span { margin-top: 0.35rem; }

  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    border-top: 1px solid transparent;
  }

  .mobile-menu[aria-expanded="true"],
  .mobile-menu[style*="max-height"]:not([style*="max-height: 0"]) {
    border-top-color: var(--border);
  }

  .mobile-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1rem 1.5rem 1.25rem;
  }

  .mobile-site-search {
    display: flex;
    align-items: center;
    min-height: 2.6rem;
    margin-bottom: 0.75rem;
    padding: 0 0.8rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 72%, transparent);
  }

  .mobile-site-search input {
    width: 100%;
    font-size: 0.92rem;
  }

  .mobile-link {
    display: block;
    padding: 0.8rem 0;
    color: var(--text);
    font-size: 0.95rem;
    border-bottom: 1px solid var(--border);
  }

  .mobile-link:last-of-type { border-bottom: none; }

  .mobile-actions {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.8rem;
  }

  .mobile-actions .icon-btn,
  .mobile-actions .cta-btn {
    flex: 1;
  }

  @media (max-width: 767px) {
    .header-inner {
      gap: 1rem;
    }

    .brand-sub { display: none; }
    .brand-name { font-size: 1.05rem; }
  }

  @media (min-width: 768px) {
    .header-actions {
      display: flex;
    }

    .mobile-btn,
    .mobile-menu {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }

    .site-search {
      display: flex;
    }
  }
</style>

<script is:inline>
  (() => {
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const themeBtn = document.getElementById('theme-toggle');
    const mobileThemeBtn = document.getElementById('mobile-theme-toggle');
    const sectionLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
    const siteSearchForm = document.getElementById('site-search-form');
    const mobileSearchForm = document.getElementById('mobile-site-search-form');
    const siteSearchInput = document.getElementById('site-search-input');
    const mobileSearchInput = document.getElementById('mobile-site-search-input');

    const routeSearch = (rawQuery) => {
      const query = (rawQuery || '').trim();
      if (!query) return;
      const lower = query.toLowerCase();
      const encoded = encodeURIComponent(query);
      const toolIntent = /工具|tool|json|yaml|csv|base64|jwt|aes|hash|token|密码|二维码|时间戳|timestamp|正则|regex|颜色|图片|curl|ai工具|chatgpt|claude|gemini|manus|grok/.test(lower);
      const competitionIntent = /比赛|赛事|竞赛|hackathon|beyond|opc|创业|报名|截止|雷达/.test(lower);

      if (competitionIntent) {
        window.location.href = `/competitions?q=${encoded}`;
      } else if (toolIntent) {
        window.location.href = `/tools?q=${encoded}`;
      } else {
        window.location.href = `/blog?q=${encoded}`;
      }
    };

    const closeMenu = () => {
      if (!mobileMenu || !mobileBtn) return;
      mobileMenu.style.maxHeight = '0';
      mobileBtn.setAttribute('aria-expanded', 'false');
      const lines = mobileBtn.querySelectorAll('span');
      if (lines.length === 2) {
        lines[0].style.transform = 'none';
        lines[1].style.transform = 'none';
      }
    };

    themeBtn?.addEventListener('click', () => window.toggleTheme?.());
    mobileThemeBtn?.addEventListener('click', () => window.toggleTheme?.());

    siteSearchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      routeSearch(siteSearchInput?.value);
    });

    mobileSearchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      routeSearch(mobileSearchInput?.value);
      closeMenu();
    });

    mobileBtn?.addEventListener('click', () => {
      if (!mobileMenu || !mobileBtn) return;
      const expanded = mobileBtn.getAttribute('aria-expanded') === 'true';
      mobileBtn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      mobileMenu.style.maxHeight = expanded ? '0' : `${mobileMenu.scrollHeight + 24}px`;
      const lines = mobileBtn.querySelectorAll('span');
      if (lines.length === 2) {
        lines[0].style.transform = expanded ? 'none' : 'translateY(3px) rotate(45deg)';
        lines[1].style.transform = expanded ? 'none' : 'translateY(-3px) rotate(-45deg)';
      }
    });

    document.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (event) => {
        const targetId = anchor.getAttribute('href');
        if (!targetId || targetId === '#') return;
        const target = document.querySelector(targetId);
        if (!target) return;
        event.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        closeMenu();
      });
    });

    if (sectionLinks.length > 0) {
      const sections = Array.from(document.querySelectorAll('section[id]'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          sectionLinks.forEach((link) => {
            link.classList.toggle('is-active', link.getAttribute('data-nav-link') === entry.target.id);
          });
        });
      }, { rootMargin: '-35% 0px -50% 0px', threshold: 0 });

      sections.forEach((section) => observer.observe(section));
    }

    window.addEventListener('keydown', (event) => {
      if (!(event.metaKey || event.ctrlKey) || event.key.toLowerCase() !== 'k') return;
      const localSearch = document.querySelector('#tool-search, #search-input, #radar-search, #resource-search');
      event.preventDefault();
      (localSearch || siteSearchInput || mobileSearchInput)?.focus();
    });

    document.addEventListener('astro:page-load', closeMenu);
  })();
</script>
