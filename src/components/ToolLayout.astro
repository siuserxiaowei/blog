---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description: string;
  category?: string;
  icon?: string;
}

const { title, description, category = '工具', icon = '⚙️' } = Astro.props;
---

<BaseLayout title={`${title} · 工具箱 · siuser小伟`} description={description}>
  <Header />

  <main class="min-h-screen pt-24 pb-20" style="background: var(--bg);">
    <div class="mx-auto px-6" style="max-width: var(--container-max);">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs mb-6" style="font-family: var(--font-mono); color: var(--text-secondary);">
        <a href="/" class="hover:text-[var(--color-accent)] transition-colors">HOME</a>
        <span style="opacity: 0.4;">/</span>
        <a href="/tools" class="hover:text-[var(--color-accent)] transition-colors">TOOLS</a>
        <span style="opacity: 0.4;">/</span>
        <span style="color: var(--color-accent);">{title.toUpperCase()}</span>
      </nav>

      <!-- Header -->
      <div class="mb-10 pb-6 border-b" style="border-color: var(--border);">
        <div class="flex items-start gap-4">
          <div class="text-4xl mt-1">{icon}</div>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-[10px] tracking-[0.2em] uppercase px-2 py-0.5 rounded-full" style="font-family: var(--font-mono); color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 12%, transparent); border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);">{category}</span>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold mb-2" style="font-family: var(--font-heading); color: var(--text);">{title}</h1>
            <p class="text-sm md:text-base" style="color: var(--text-secondary);">{description}</p>
          </div>
        </div>
      </div>

      <!-- Tool Content -->
      <div class="tool-shell">
        <slot />
      </div>

      <!-- Back to tools -->
      <div class="mt-12 text-center">
        <a href="/tools" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm transition-all hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]" style="border: 1px solid var(--border); color: var(--text-secondary);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          回到工具箱
        </a>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Tool shell shared styles */
  .tool-shell .tool-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }
  .tool-shell .tool-card:hover { border-color: color-mix(in srgb, var(--color-accent) 40%, var(--border)); }

  .tool-shell label.tool-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    font-family: var(--font-mono);
  }

  .tool-shell .tool-input,
  .tool-shell .tool-textarea,
  .tool-shell .tool-select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }
  .tool-shell .tool-textarea {
    min-height: 200px;
    resize: vertical;
    line-height: 1.6;
  }
  .tool-shell .tool-input:focus,
  .tool-shell .tool-textarea:focus,
  .tool-shell .tool-select:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .tool-shell .tool-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.1rem;
    border-radius: 10px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--text);
    font-family: var(--font-body);
  }
  .tool-shell .tool-btn:hover { border-color: var(--color-accent); color: var(--color-accent); transform: translateY(-1px); }
  .tool-shell .tool-btn:active { transform: translateY(0); }

  .tool-shell .tool-btn-primary {
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
    color: var(--color-bg-dark);
    border-color: transparent;
    font-weight: 600;
  }
  .tool-shell .tool-btn-primary:hover {
    color: var(--color-bg-dark);
    box-shadow: 0 8px 20px -8px color-mix(in srgb, var(--color-accent) 60%, transparent);
  }

  .tool-shell .tool-btn-ghost {
    background: transparent;
    border-color: color-mix(in srgb, var(--text-secondary) 30%, transparent);
  }

  .tool-shell .tool-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tool-shell .tool-grid-2 {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .tool-shell .tool-grid-2 { grid-template-columns: 1fr 1fr; }
  }

  .tool-shell .tool-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }
  .tool-shell .tool-status .ok { color: #4ade80; }
  .tool-shell .tool-status .err { color: #f87171; }
  .tool-shell .tool-status .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--text-secondary); opacity: 0.5;
  }
  .tool-shell .tool-status.is-ok .dot { background: #4ade80; opacity: 1; box-shadow: 0 0 8px #4ade80; }
  .tool-shell .tool-status.is-err .dot { background: #f87171; opacity: 1; box-shadow: 0 0 8px #f87171; }

  .tool-shell pre.tool-output {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.55;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
    min-height: 200px;
  }

  .tool-shell .tool-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .tool-shell .tool-meta-item {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.7rem 0.9rem;
  }
  .tool-shell .tool-meta-item .k {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 0.2rem;
  }
  .tool-shell .tool-meta-item .v {
    font-size: 0.95rem;
    color: var(--text);
    font-family: var(--font-mono);
    word-break: break-all;
  }

  /* Toast */
  .tool-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    padding: 0.7rem 1.4rem;
    background: var(--surface);
    border: 1px solid var(--color-accent);
    border-radius: 10px;
    font-size: 0.85rem;
    color: var(--text);
    box-shadow: 0 12px 40px -10px color-mix(in srgb, var(--color-accent) 40%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    z-index: 99999;
    font-family: var(--font-mono);
  }
  .tool-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<!-- shared toast helper -->
<div id="tool-toast" class="tool-toast"></div>
<script is:inline>
  window.toolToast = function(msg, type) {
    const t = document.getElementById('tool-toast');
    if (!t) return;
    t.textContent = msg;
    t.style.borderColor = type === 'err' ? '#f87171' : 'var(--color-accent)';
    t.classList.add('show');
    clearTimeout(window._toolToastTimer);
    window._toolToastTimer = setTimeout(() => t.classList.remove('show'), 1800);
  };
  window.toolCopy = async function(text) {
    try {
      await navigator.clipboard.writeText(text);
      window.toolToast('已复制到剪贴板');
    } catch (e) {
      window.toolToast('复制失败', 'err');
    }
  };
</script>
