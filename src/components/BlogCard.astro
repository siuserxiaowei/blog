---
interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  slug: string;
  image?: string;
}

const { title, description, date, tags = [], slug, image } = Astro.props;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<a href={`/blog/${slug}`} class="blog-card">
  {image && (
    <div class="blog-card-media">
      <img src={image} alt={title} loading="lazy" />
    </div>
  )}

  <article class="blog-card-body">
    <div class="blog-card-meta">
      <time>{formatDate(date)}</time>
      {tags.length > 0 && <span>{tags[0]}</span>}
    </div>

    <h3>{title}</h3>
    <p>{description}</p>

    <div class="blog-card-foot">
      <span>{tags.slice(0, 3).join(' / ') || 'Writing'}</span>
      <em aria-hidden="true">→</em>
    </div>
  </article>
</a>

<style>
  .blog-card {
    display: flex;
    min-height: 14.5rem;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text);
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .blog-card:hover {
    border-color: var(--border-strong);
    background: color-mix(in srgb, var(--surface) 74%, var(--surface-strong));
    color: var(--text);
  }

  .blog-card-media {
    aspect-ratio: 2.2 / 1;
    border-bottom: 1px solid var(--border);
    background: var(--surface-strong);
  }

  .blog-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .blog-card:hover .blog-card-media img {
    transform: scale(1.025);
  }

  .blog-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1rem;
  }

  .blog-card-meta,
  .blog-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .blog-card-meta span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .blog-card h3 {
    margin-top: 0.9rem;
    color: var(--text);
    font-family: var(--font-heading);
    font-size: clamp(1.18rem, 2vw, 1.45rem);
    line-height: 1.18;
  }

  .blog-card p {
    margin-top: 0.65rem;
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .blog-card-foot {
    margin-top: auto;
    padding-top: 1rem;
  }

  .blog-card-foot span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .blog-card-foot em {
    flex-shrink: 0;
    color: var(--color-accent);
    font-style: normal;
    transition: transform 0.15s ease;
  }

  .blog-card:hover .blog-card-foot em {
    transform: translateX(3px);
  }
</style>
