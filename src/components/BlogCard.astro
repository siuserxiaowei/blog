---
interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  slug: string;
  image?: string;
}

const { title, description, date, tags = [], slug, image } = Astro.props;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<a href={`/blog/${slug}`} class="group block">
  <article class="blog-card surface-card card-hover gradient-border rounded-[24px]">
    {image && (
      <div class="blog-card-media">
        <img src={image} alt={title} loading="lazy" />
      </div>
    )}

    <div class="blog-card-body">
      <div class="blog-card-meta">
        <span class="blog-card-kind">Dispatch</span>
        <time>{formatDate(date)}</time>
      </div>

      <div class="blog-card-content">
        <h3>{title}</h3>
        <p>{description}</p>
      </div>

      <div class="blog-card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span>{tag}</span>
        ))}
      </div>

      <div class="blog-card-footer">
        <span>Read dispatch</span>
        <span class="blog-card-arrow">↗</span>
      </div>
    </div>
  </article>
</a>

<style>
  .blog-card {
    overflow: hidden;
  }

  .blog-card-media {
    aspect-ratio: 2.35 / 1;
    overflow: hidden;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
  }

  .blog-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(.2, .7, .2, 1), filter 0.4s ease;
    filter: saturate(0.92) contrast(1.02);
  }

  .group:hover .blog-card-media img {
    transform: scale(1.04);
    filter: saturate(1.02) contrast(1.05);
  }

  .blog-card-body {
    display: grid;
    gap: 1rem;
    padding: 1.45rem;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.73rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .blog-card-kind {
    color: var(--color-accent);
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .blog-card-tags span {
    border-radius: 999px;
    padding: 0.28rem 0.58rem;
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    background: color-mix(in srgb, var(--surface-2) 88%, transparent);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-card-content h3 {
    margin-bottom: 0.6rem;
    font-size: clamp(1.55rem, 2.2vw, 2rem);
    line-height: 1.05;
  }

  .blog-card-content p {
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.05rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .blog-card-arrow {
    color: var(--color-accent);
    transition: transform 0.2s ease;
  }

  .group:hover .blog-card-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 680px) {
    .blog-card-body {
      padding: 1.15rem;
    }

    .blog-card-content h3 {
      font-size: 1.5rem;
    }
  }
</style>
