---
interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  slug: string;
  image?: string;
}

const { title, description, date, tags = [], slug, image } = Astro.props;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<a href={`/blog/${slug}`} class="group block">
  <article class="lift-card shine-hover border-sweep glass-card gold-shadow relative rounded-xl overflow-hidden">
    <!-- Hero Image -->
    {image && (
      <div class="aspect-[2.4/1] overflow-hidden">
        <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      </div>
    )}
    <!-- Main content -->
    <div class="p-6 md:p-8">
      <!-- Date & Tags -->
      <div class="flex items-center gap-3 mb-4">
        <time class="text-xs tracking-wider uppercase" style="color: var(--text-secondary); font-family: var(--font-mono);">
          {formatDate(date)}
        </time>
        {tags.length > 0 && (
          <span class="text-xs" style="color: var(--border);">|</span>
        )}
        {tags.map(tag => (
          <span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--surface-2); color: var(--color-accent);">
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h3 class="text-xl md:text-2xl mb-3 transition-colors duration-200 group-hover:text-[var(--color-accent)]" style="font-family: var(--font-heading); color: var(--text);">
        {title}
      </h3>

      <!-- Description -->
      <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
        {description}
      </p>

      <!-- Read more -->
      <span class="inline-flex items-center gap-1.5 text-xs tracking-wider uppercase transition-colors duration-200" style="color: var(--color-accent);">
        阅读全文
        <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>

    <!-- Hover overlay -->
    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: linear-gradient(135deg, transparent 60%, color-mix(in srgb, var(--color-accent) 8%, transparent));"></div>
  </article>
</a>
