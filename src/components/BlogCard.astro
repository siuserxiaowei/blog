---
interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  slug: string;
  image?: string;
}

const { title, description, date, tags = [], slug, image } = Astro.props;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<a href={`/blog/${slug}`} class="blog-card">
  <article>
    <div class="blog-card-meta">
      <time>{formatDate(date)}</time>
      {tags.length > 0 && (
        <span class="blog-card-tags">
          {tags.slice(0, 3).map((tag, i) => (
            <span>{tag}{i < Math.min(tags.length, 3) - 1 ? ' · ' : ''}</span>
          ))}
        </span>
      )}
    </div>

    {image && (
      <div class="blog-card-media">
        <img src={image} alt={title} loading="lazy" />
      </div>
    )}

    <h3 class="blog-card-title display-serif">{title}</h3>
    <p class="blog-card-desc">{description}</p>

    <span class="blog-card-read">阅读 <em>→</em></span>
  </article>
</a>

<style>
  .blog-card {
    display: block;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    transition: border-color 0.15s ease;
  }

  .blog-card:hover {
    color: var(--text);
    border-bottom-color: var(--border-strong);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
  }

  .blog-card-tags {
    color: var(--text-muted);
  }

  .blog-card-media {
    margin-bottom: 1.1rem;
    aspect-ratio: 2.35 / 1;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
  }

  .blog-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .blog-card-media img {
    transform: scale(1.02);
  }

  .blog-card-title {
    font-size: clamp(1.55rem, 2.6vw, 2.1rem);
    line-height: 1.1;
    margin-bottom: 0.7rem;
    color: var(--text);
    transition: color 0.15s ease;
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-accent);
  }

  .blog-card-desc {
    max-width: 48rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .blog-card-read {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .blog-card-read em {
    font-style: normal;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .blog-card:hover .blog-card-read em {
    transform: translateX(3px);
  }
</style>
