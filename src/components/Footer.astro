---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-panel">
    <div class="footer-main">
      <div class="footer-brand">
        <p class="footer-kicker">Open workbench</p>
        <h2>siuser<span>小伟</span></h2>
        <p>
          写判断、做工具、公开迭代。这里是一个持续更新的个人工作台，记录技术、产品和真实问题的处理过程。
        </p>
      </div>

      <nav class="footer-cols" aria-label="页脚导航">
        <div>
          <p class="footer-label">Read</p>
          <a href="/blog">文章</a>
          <a href="/rss.xml">RSS</a>
        </div>
        <div>
          <p class="footer-label">Build</p>
          <a href="/tools">工具箱</a>
          <a href="/projects">项目</a>
          <a href="/competitions">比赛雷达</a>
        </div>
        <div>
          <p class="footer-label">Operate</p>
          <a href="https://github.com/siuserxiaowei" target="_blank" rel="noopener">GitHub</a>
          <a href="/admin/">Admin</a>
          <a href="mailto:hi@siuserxiaowei.com">Email</a>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} siuser小伟</p>
      <p>dark workbench / public build</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: 3rem 1rem 1.25rem;
  }

  .footer-panel {
    max-width: var(--container-wide);
    margin: 0 auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--footer-bg) 86%, white 4%), var(--footer-bg));
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .footer-main {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1.85fr);
    gap: 2rem;
    padding: 2rem;
  }

  .footer-kicker,
  .footer-label,
  .footer-bottom {
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .footer-kicker {
    margin-bottom: 0.75rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .footer-brand h2 {
    margin-bottom: 0.75rem;
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    line-height: 1.05;
  }

  .footer-brand h2 span {
    color: var(--color-accent);
  }

  .footer-brand p:last-child {
    max-width: 32rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .footer-cols > div {
    min-height: 10rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-label {
    margin-bottom: 0.25rem;
    color: var(--text-muted);
  }

  .footer-cols a {
    color: var(--text-secondary);
    font-size: 0.92rem;
  }

  .footer-cols a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 2rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .footer-main {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }

    .footer-cols {
      grid-template-columns: 1fr;
    }

    .footer-cols > div {
      min-height: auto;
    }

    .footer-bottom {
      flex-direction: column;
      padding: 1rem 1.25rem;
    }
  }
</style>
